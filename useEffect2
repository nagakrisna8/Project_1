const CustomHierarchyCell = (props: any) => {
  const expanded = props.dataItem.expanded;

  const handleClick = (e: React.MouseEvent) => {
    e.stopPropagation();
    props.onChange({
      dataItem: props.dataItem,
      syntheticEvent: e
    });
  };

  return (
    <td className="k-hierarchy-cell">
      <span
        onClick={handleClick}
        style={{ cursor: "pointer", display: "flex", justifyContent: "center" }}
      >
        {expanded ? (
          <ArrowDropUpIcon style={{ fontSize: 22 }} />
        ) : (
          <ArrowDropDownIcon style={{ fontSize: 22 }} />
        )}
      </span>
    </td>
  );
};
