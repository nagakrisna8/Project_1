const expandChange = (dataItem: any) => {

  const newData = props.organizationData.map((item) =>
    item[props.KEY] === dataItem[props.KEY]
      ? { ...item, expanded: !item.expanded }
      : item
  );

  props.organizationData.splice(0, props.organizationData.length, ...newData);
};

const ContactFocals: React.ComponentType<GridCellProps> = (cellProps) => {

  const expanded = cellProps.dataItem.expanded;

  const toggleExpand = () => {
    expandChange(cellProps.dataItem);
  };

  return (
    <td>
      <span
        style={{
          display: "flex",
          alignItems: "center",
          gap: 10,
          marginLeft: 20,
          cursor: "pointer"
        }}
        onClick={toggleExpand}
      >
        <GroupIcon />

        {expanded ? (
          <ArrowDropUpIcon />
        ) : (
          <ArrowDropDownIcon />
        )}
      </span>
    </td>
  );
};


hierarchyCell={() => null}
