const [originalOrganizationTypeData, setOriginalOrganizationTypeData] = useState<OrganizationTypeMasterTable[]>([]);
const fetchOrganizationType = () => {
    let masterdataType = 0;
    EasaListService.getAdminMasterDetailsType(masterdataType)
        .then((response) => {
            let result: OrganizationTypeMasterTable[] = response?.data.map(x => ({
                ORGID: x.ORGID,
                ORGTYPE: x.ORGTYPE,
                SORT_ORDER: x.SORT_ORDER,
                USERDEFINED_FLAG: x.USERDEFINED_FLAG,
                ISACTIVE: x.ISACTIVE === "Y"
            }));

            setOrganizationTypeData(result);
            setOriginalOrganizationTypeData(result); // 🔥 store original copy
        })
        .catch((err) => console.error(err));
};


const saveOrganizationType = async () => {
    if (!dirtyFlag) {
        dispatch(showSnackbar({
            snackbarOpen: true,
            snackbarType: "error",
            snackbarMessage: "No data to save.",
        }));
        return;
    }

    const current = [...organizationTypeData];
    const original = [...originalOrganizationTypeData];

    // Validation
    if (current.some((i) => !i.ORGTYPE || i.ORGTYPE.trim() === "")) {
        dispatch(showSnackbar({
            snackbarOpen: true,
            snackbarType: "error",
            snackbarMessage: "Please fill details.",
        }));
        return;
    }

    const uniqueCount = new Set(
        current.map((i) => i.ORGTYPE.trim().toLowerCase())
    ).size;

    if (uniqueCount !== current.length) {
        dispatch(showSnackbar({
            snackbarOpen: true,
            snackbarType: "error",
            snackbarMessage: "Organization Types must be unique.",
        }));
        return;
    }

    // 🔥 Detect changed rows
    const items: MasterDataItem[] = [];

    current.forEach((row) => {
        const originalRow = original.find(o => o.ORGID === row.ORGID);

        // 🟢 NEW RECORD
        if (!originalRow) {
            items.push({
                Id: 0,
                OperationType: "add",
                Name: row.ORGTYPE.trim(),
                IsActive: row.ISACTIVE ? "Y" : "N",
                Description: "",
                Notes: "",
                Address: "",
                Department: "",
                Phone: "",
                Email: "",
                Title: "",
            });
        }
        // 🟡 MODIFIED RECORD
        else if (
            originalRow.ORGTYPE !== row.ORGTYPE ||
            originalRow.ISACTIVE !== row.ISACTIVE ||
            originalRow.SORT_ORDER !== row.SORT_ORDER
        ) {
            items.push({
                Id: row.ORGID,
                OperationType: "update",
                Name: row.ORGTYPE.trim(),
                IsActive: row.ISACTIVE ? "Y" : "N",
                Description: "",
                Notes: "",
                Address: "",
                Department: "",
                Phone: "",
                Email: "",
                Title: "",
            });
        }
    });

    // 🚨 Nothing changed
    if (items.length === 0) {
        dispatch(showSnackbar({
            snackbarOpen: true,
            snackbarType: "error",
            snackbarMessage: "No changes detected.",
        }));
        return;
    }

    const payload: MasterDataPayload = {
        MasterDataType: "OrganizationType",
        Items: items,
    };

    console.log("Final Payload:", payload);

    try {
        await EasaListService.addMasterDataType(payload);

        setDirtyFlag(false);
        fetchOrganizationType();

        dispatch(showSnackbar({
            snackbarOpen: true,
            snackbarType: "success",
            snackbarMessage: "Organization Type saved successfully.",
        }));
    } catch (error) {
        dispatch(showSnackbar({
            snackbarOpen: true,
            snackbarType: "error",
            snackbarMessage: "Error saving Organization Type.",
        }));
    }
};
