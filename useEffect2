<Select
    id="admin-table-categorytype-selector"
    style={{ maxWidth: 180, minWidth: 180, backgroundColor: "#ffffff" }}
    value={selectedCategoryType ? selectedCategoryType.ORGID : ""}
    size="small"
    onChange={(e) => {
        const selectedId = Number(e.target.value);
        const selectedObj = organizationTypeData.find(x => x.ORGID === selectedId) || null;

        setSelectedCategoryType(selectedObj);
        handleOrganizationTypeChange(selectedId);
    }}
>
    {organizationTypeData
        .filter(opt => opt.ISACTIVE)
        .map((opt) => (
            <MenuItem key={opt.ORGID} value={opt.ORGID}>
                {opt.ORGTYPE}
            </MenuItem>
        ))}
</Select>
