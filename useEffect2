const ContactFocals: React.ComponentType<GridCellProps> = (cellprops) => {

  const handleToggle = (event: React.MouseEvent<HTMLSpanElement>) => {

    if (cellprops.onChange) {

      cellprops.onChange({
        dataItem: {
          ...cellprops.dataItem,
          expanded: !cellprops.dataItem.expanded
        },
        field: "expanded",
        syntheticEvent: event,
        value: !cellprops.dataItem.expanded
      });

    }
  };

  return (
    <td>
      <span
        style={{
          display: "flex",
          alignItems: "center",
          gap: "10px",
          marginLeft: "20px",
          cursor: "pointer"
        }}
        onClick={handleToggle}
      >
        <GroupIcon style={{ color: "#555" }} />

        {cellprops.dataItem.expanded ?
          <ArrowDropUpIcon style={{ color: "#555" }} />
          :
          <ArrowDropDownIcon style={{ color: "#555" }} />
        }

      </span>
    </td>
  );
};
