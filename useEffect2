const activeCheckbox = (cellProps: GridCellProps) => {
  const field = cellProps.field!;
  const value = cellProps.dataItem[field] ?? false;

  return (
    <td>
      <div style={{ display: "flex", justifyContent: "center" }}>
        <input
          type="checkbox"
          checked={value}
          onChange={(e) =>
            cellProps.onChange?.({
              dataIndex: cellProps.dataIndex,
              dataItem: cellProps.dataItem,
              field: field,
              syntheticEvent: e,
              value: e.target.checked,
            })
          }
        />
      </div>
    </td>
  );
};
