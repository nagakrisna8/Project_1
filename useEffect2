const saveSupplierCategory = async () => {
    if (!dirtyFlag) {
        dispatch(showSnackbar({
            snackbarOpen: true,
            snackbarType: "error",
            snackbarMessage: "No data to save.",
        }));
        return;
    }

    const current = [...supplierCategoryData];
    const original = [...originalSupplierCategoryData];

    // Validation
    if (current.some((i) => !i.DESCRIPTION || i.DESCRIPTION.trim() === "")) {
        dispatch(showSnackbar({
            snackbarOpen: true,
            snackbarType: "error",
            snackbarMessage: "Please fill details.",
        }));
        return;
    }

    const uniqueCount = new Set(
        current.map((i) => i.DESCRIPTION.trim().toLowerCase())
    ).size;

    if (uniqueCount !== current.length) {
        dispatch(showSnackbar({
            snackbarOpen: true,
            snackbarType: "error",
            snackbarMessage: "Supplier Category must be unique.",
        }));
        return;
    }

    // 🔥 Detect changes
    const items: MasterDataItem[] = [];

    current.forEach((row) => {
        const originalRow = original.find(o => o.ID === row.ID);

        // 🟢 New row
        if (!originalRow) {
            items.push({
                Id: 0,
                OperationType: "add",
                Name: "",
                Description: row.DESCRIPTION.trim(),
                IsActive: row.ISACTIVE ? "Y" : "N",
                Notes: "",
                Address: "",
                Department: "",
                Phone: "",
                Email: "",
                Title: "",
            });
        }
        // 🟡 Updated row
        else if (
            originalRow.DESCRIPTION !== row.DESCRIPTION ||
            originalRow.ISACTIVE !== row.ISACTIVE ||
            originalRow.SORT_ORDER !== row.SORT_ORDER
        ) {
            items.push({
                Id: row.ID,
                OperationType: "update",
                Name: "",
                Description: row.DESCRIPTION.trim(),
                IsActive: row.ISACTIVE ? "Y" : "N",
                Notes: "",
                Address: "",
                Department: "",
                Phone: "",
                Email: "",
                Title: "",
            });
        }
    });

    if (items.length === 0) {
        dispatch(showSnackbar({
            snackbarOpen: true,
            snackbarType: "error",
            snackbarMessage: "No changes detected.",
        }));
        return;
    }

    const payload: MasterDataPayload = {
        MasterDataType: "SupplierCategory",
        Items: items,
    };

    try {
        await EasaListService.addMasterDataType(payload);

        setDirtyFlag(false);
        fetchSupplierCategory();

        dispatch(showSnackbar({
            snackbarOpen: true,
            snackbarType: "success",
            snackbarMessage: "Supplier Category saved successfully.",
        }));
    } catch (error) {
        dispatch(showSnackbar({
            snackbarOpen: true,
            snackbarType: "error",
            snackbarMessage: "Error saving Supplier Category.",
        }));
    }
};







