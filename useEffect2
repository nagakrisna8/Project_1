<GridToolbar className="organization-toolbar">
  <div className="toolbar-left">
    <Button
      startIcon={<AddCircleOutlineIcon />}
      onClick={props.createOrganization}
      variant="outlined"
      size="small"
      color="inherit"
    >
      Create New
    </Button>

    <Button
      onClick={props.saveOrganization}
      variant="outlined"
      size="small"
      color="inherit"
    >
      Save
    </Button>
  </div>

  <div className="toolbar-right">
    <span className="sort-label">Sort Order :</span>

    <Select
      value={props.sortBy || "custom"}
      className="sort-dropdown"
      onChange={(e) =>
        props.handleSortByChange(
          "organization",
          e.target.value as "custom" | "asc" | "desc"
        )
      }
      size="small"
    >
      <MenuItem value="custom">
        <SettingsIcon className="menu-icon" />
        Customize
      </MenuItem>

      <MenuItem value="asc">
        <ArrowUpwardIcon className="menu-icon" />
        Ascending
      </MenuItem>

      <MenuItem value="desc">
        <ArrowDownwardIcon className="menu-icon" />
        Descending
      </MenuItem>
    </Select>
  </div>
</GridToolbar>





.organization-toolbar {
  display: flex;
  align-items: center;
  width: 100%;
}

.toolbar-left {
  display: flex;
  gap: 8px;
}

.toolbar-right {
  margin-left: auto;
  display: flex;
  align-items: center;
  gap: 8px;
}

.sort-label {
  margin: 0;
  font-size: 14px;
}

.sort-dropdown {
  width: 160px;
}

.menu-icon {
  height: 16px;
  width: 16px;
  margin-right: 8px;
}
