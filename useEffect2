const handleChange: React.ChangeEventHandler<HTMLInputElement> = (event) => {
  if (cellProps.onChange) {
    const field = cellProps.field as keyof OrganizationTableData;

    const updatedDataItem: OrganizationTableData = { ...cellProps.dataItem };
    (updatedDataItem as any)[field] = event.target.value;

    cellProps.onChange({
      dataIndex: cellProps.dataIndex,
      dataItem: updatedDataItem,
      field: cellProps.field,
      syntheticEvent: event,
      value: event.target.value,
    });
  }
};
