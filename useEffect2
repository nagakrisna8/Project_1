const saveOrganizationType = async () => {
    if (!dirtyFlag) {
        dispatch(
            showSnackbar({
                snackbarOpen: true,
                snackbarType: "error",
                snackbarMessage: "No data to save.",
            })
        );
        return;
    }

    const copy = [...organizationTypeData];

    // 1️⃣ Empty validation
    if (copy.some((i) => !i.ORGTYPE || i.ORGTYPE.trim() === "")) {
        dispatch(
            showSnackbar({
                snackbarOpen: true,
                snackbarType: "error",
                snackbarMessage: "Please fill all Organization Type names.",
            })
        );
        return;
    }

    // 2️⃣ Duplicate validation (case-insensitive)
    const uniqueCount = new Set(
        copy.map((i) => i.ORGTYPE.trim().toLowerCase())
    ).size;

    if (uniqueCount !== copy.length) {
        dispatch(
            showSnackbar({
                snackbarOpen: true,
                snackbarType: "error",
                snackbarMessage: "Organization Types must be unique.",
            })
        );
        return;
    }

    // 3️⃣ Apply sorting if selected
    let sorted = [...organizationTypeData];

    if (sortBy.organizationType === "asc" || sortBy.organizationType === "desc") {
        sorted = _.orderBy(sorted, ["ORGTYPE"], [sortBy.organizationType]);

        let order = 1;
        sorted = sorted.map((x) => ({
            ...x,
            SORT_ORDER: order++,
        }));
    }

    // 4️⃣ Build payload (add + update support)
    const items: MasterDataItem[] = sorted.map((row) => ({
        Id: row.newFlag ? 0 : Number(row.ORGID ?? 0),
        OperationType: row.newFlag ? "add" : "update",
        Name: row.ORGTYPE.trim(),
        IsActive: row.ISACTIVE ? "Y" : "N",
        Description: "",
        Notes: "",
        Address: "",
        Department: "",
        Phone: "",
        Email: "",
        Title: "",
    }));

    const payload: MasterDataPayload = {
        MasterDataType: "OrganizationType",
        Items: items,
    };

    try {
        await EasaListService.addMasterDataType(payload);

        setOrganizationTypeData(sorted);
        setDirtyFlag(false);
        fetchOrganizationType();

        dispatch(
            showSnackbar({
                snackbarOpen: true,
                snackbarType: "success",
                snackbarMessage: "Organization Type(s) saved successfully.",
            })
        );
    } catch (error) {
        dispatch(
            showSnackbar({
                snackbarOpen: true,
                snackbarType: "error",
                snackbarMessage: "Error saving Organization Types.",
            })
        );
    }
};
