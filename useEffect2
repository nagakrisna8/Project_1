const ChecklistTypeNameCell: React.ComponentType<GridCellProps> = useCallback((cellProps) => {
  const { dataItem, field = "" } = cellProps;
  const dataValue = dataItem[field] ?? "";

  const handleChange: React.ChangeEventHandler<HTMLInputElement | HTMLTextAreaElement> = (event) => {
    if (cellProps.onChange) {
      const updatedDataItem: OrganizationTableData = {
        ...dataItem,
        [field]: event.target.value,   // ✅ dynamic field update
      };

      cellProps.onChange({
        dataIndex: cellProps.dataIndex,
        dataItem: updatedDataItem,
        field: field,
        syntheticEvent: event,
        value: event.target.value,
      });
    }
  };

  return (
    <td title={dataValue}>
      <TextField
        fullWidth
        value={dataValue}
        onChange={handleChange}
        size="small"
      />
    </td>
  );
}, []);
