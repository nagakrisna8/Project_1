useEffect(() => {

    if (savedFormData) {
        setFormData(savedFormData);
        return;
    }

    if (focalData) {
        const initial = {
            id: (focalData as any)?.newFlag ? 0 : (focalData.ID ?? 0),
            name: focalData.NAME ?? "",
            address: focalData.ADDRESS ?? "",
            phone: String(focalData.PHONENO ?? ""),
            email: focalData.EMAIL ?? "",
            position: focalData.POSITION ?? "",
            title: focalData.TITLE ?? "",
            isActive: focalData.ISACTIVE ?? false
        };

        setFormData(initial);
        onFormChange?.(initial);
    }

}, [savedFormData, focalData]);
