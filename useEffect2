const [expandedState, setExpandedState] = React.useState<any>({});
const gridData = process(
  props.organizationData.map((item) => ({
    ...item,
    expanded: expandedState[item[props.KEY]]
  })),
  props.dataState
).data;

const expandChange = (event: any) => {
  const dataItem = event.dataItem;

  setExpandedState((prev: any) => ({
    ...prev,
    [dataItem[props.KEY]]: !prev[dataItem[props.KEY]]
  }));
};
const ContactFocals: React.ComponentType<GridCellProps> = (cellProps) => {

  const expanded = cellProps.dataItem.expanded;

  const toggle = () => {
    expandChange({ dataItem: cellProps.dataItem });
  };

  return (
    <td onClick={toggle} style={{ cursor: "pointer" }}>
      <GroupIcon />
      {expanded ? <ArrowDropUpIcon /> : <ArrowDropDownIcon />}
    </td>
  );
};
