const SupplierActivityCell = (cellProps: GridCellProps) => {
  const field = cellProps.field!;
  const value = cellProps.dataItem[field] ?? "";

  return (
    <td>
      <TextField
        fullWidth
        value={value}
        onChange={(e) =>
          cellProps.onChange?.({
            dataIndex: cellProps.dataIndex,
            dataItem: cellProps.dataItem,
            field: field,
            syntheticEvent: e,
            value: e.target.value,
          })
        }
      />
    </td>
  );
};


