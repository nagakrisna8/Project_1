$text-default: #253746;
$table-header-bg: #ffffff;
$table-bg-alt-row: #eff6fa;
$table-row-bg-hover: #dce2e6;
$table-row-border-col: #ededed;
$grid-topbar-height: 48px;
$table-row-height: 32px;
$text-size-default: 14px;

.EASA-Admin-table-maintenance {
  font-size: $text-size-default;

  .EASA-Admin-table-maintenance-topbar {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    margin-left: 22px;
    gap: 8px;
    color: $text-default;
  }

  .MuiPopover-paper {
    height: 170px !important;
  }

  #admin-table-page-selector,
  #admin-table-categorytype-selector {
    margin: 0px;
    padding: 4px 8px;
  }

  #admin-table-categorytype-selector {
    width: 147px;
  }

  .EASA-Admin-table-maintenance-section {
    margin-top: 16px;
  }

  .hideCls {
    display: none !important;
  }

  #kgrid-oss-checklistType,
  #kgrid-oss-admin-table-errorCode1,
  #kgrid-oss-admin-table-errorCode1-itar,
  #kgrid-oss-admin-table-errorCode2,
  #kgrid-oss-admin-table-errorCode3,
  #kgrid-oss-admin-table-category,
  #kgrid-oss-admin-table-category-type,
  #kgrid-oss-admin-table-reasonCode,
  #kgrid-oss-admin-table-reasonCode-itar {
    min-height: 130px;
    max-height: inherit !important;
  }

  #kgrid-oss-checklistType td .deleteBtn,
  #kgrid-oss-admin-table-errorCode1 td .deleteBtn,
  #kgrid-oss-admin-table-errorCode1-itar td .deleteBtn,
  #kgrid-oss-admin-table-errorCode2 td .deleteBtn,
  #kgrid-oss-admin-table-errorCode3 td .deleteBtn,
  #kgrid-oss-admin-table-category td .deleteBtn,
  #kgrid-oss-admin-table-category-type td .deleteBtn,
  #kgrid-oss-admin-table-reasonCode td .deleteBtn,
  #kgrid-oss-admin-table-reasonCode-itar td .deleteBtn {
    padding: 0.2em 1.5em !important;
    height: 32px !important;
    border: 1px solid #a19b9b !important;
    color: #5a5a5a !important;
    font-weight: bold;
    border-radius: 4px !important;
    cursor: pointer;
    background: #ffffff;
  }

  #kgrid-oss-checklistType.k-table-tbody .k-table-row .k-dropdownlist,
  #kgrid-oss-admin-table-errorCode1.k-table-tbody .k-table-row .k-dropdownlist,
  #kgrid-oss-admin-table-errorCode1-itar.k-table-tbody .k-table-row .k-dropdownlist,
  #kgrid-oss-admin-table-errorCode2.k-table-tbody .k-table-row .k-dropdownlist,
  #kgrid-oss-admin-table-errorCode3.k-table-tbody .k-table-row .k-dropdownlist,
  #kgrid-oss-admin-table-reasonCode-itar.k-table-tbody .k-table-row .k-dropdownlist {
    background-color: rgba(0, 0, 0, 0);
    background-image: none;
    border: 1px solid rgba(118, 118, 118, 0.3);
    padding: 3px 0px;
    height: 28px;
    margin-block: 2px;
  }

  .focal-grid-compact .k-hover,
  .focal-grid-compact .k-hover td,
  .focal-grid-compact .k-table-tbody tr:hover,
  .focal-grid-compact .k-table-tbody tr:hover td {
    background-color: #ffffff !important;
  }

  .focal-grid-compact {
    --kendo-grid-row-hover-bg: #ffffff;
    --kendo-table-hover-bg: #ffffff;
  }

  .tabBox:has(.gridSupplementaryContainer) {
    padding: 20px 0px;
  }

  .categorychecklistHeaderGridContainer {
    margin-top: 16px;
  }

  .MuiAlert-filledSuccess {
    background-color: #81bc00 !important;
  }

  .Savebtn,
  .CancelBtn {
    text-transform: none;
    height: 32px;
    align-items: center;
  }

  .k-grid tr.k-selected,
  .k-grid tr.k-state-selected,
  .k-grid tr.k-focus {
    background-color: transparent !important;
  }

  .k-grid td.k-focus {
    box-shadow: none !important;
    background-color: transparent !important;
  }

  #kgrid-oss-checklistType,
  #kgrid-oss-admin-table-errorCode1,
  #kgrid-oss-admin-table-errorCode1-itar,
  #kgrid-oss-admin-table-errorCode2,
  #kgrid-oss-admin-table-errorCode3,
  #kgrid-oss-admin-table-category,
  #kgrid-oss-admin-table-category-type,
  #kgrid-oss-admin-table-reasonCode,
  #kgrid-oss-admin-table-reasonCode-itar {
    .k-table {
      width: 100% !important; /* KEEP (we override later) */
    }

    tbody tr td {
      border-bottom: 1px solid $table-row-border-col !important;
      padding: 0 8px !important;
      height: $table-row-height !important;
    }
  }

  .k-button-md.k-icon-button {
    display: none !important;
  }
}

/* ========================= */
/* 🔥 ADD ONLY THIS FIX BELOW */
/* ========================= */

/* 1. Override forced width: 100% */
.EASA-Admin-table-maintenance .k-grid-content table {
  width: auto !important;
  min-width: unset !important;
}

/* 2. Override k-table width */
.EASA-Admin-table-maintenance 
#kgrid-oss-checklistType .k-table,
.EASA-Admin-table-maintenance 
#kgrid-oss-admin-table-errorCode1 .k-table,
.EASA-Admin-table-maintenance 
#kgrid-oss-admin-table-errorCode1-itar .k-table,
.EASA-Admin-table-maintenance 
#kgrid-oss-admin-table-errorCode2 .k-table,
.EASA-Admin-table-maintenance 
#kgrid-oss-admin-table-errorCode3 .k-table,
.EASA-Admin-table-maintenance 
#kgrid-oss-admin-table-category .k-table,
.EASA-Admin-table-maintenance 
#kgrid-oss-admin-table-category-type .k-table,
.EASA-Admin-table-maintenance 
#kgrid-oss-admin-table-reasonCode .k-table,
.EASA-Admin-table-maintenance 
#kgrid-oss-admin-table-reasonCode-itar .k-table {
  width: auto !important;
}

/* 3. Kill hierarchy column width */
.focal-grid-compact.k-grid .k-hierarchy-col,
.focal-grid-compact.k-grid .k-hierarchy-cell {
  width: 0 !important;
  min-width: 0 !important;
  max-width: 0 !important;
  padding: 0 !important;
  border: none !important;
}
