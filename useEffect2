const ContactFocals: React.ComponentType<GridCellProps> = (cellProps) => {

  const dataItem = cellProps.dataItem;
  const rowKey = dataItem[props.KEY];

  const isExpanded = expandedFocalRowKey === rowKey;

  const handleToggle = () => {
    setExpandedFocalRowKey(prev => prev === rowKey ? null : rowKey);
  };

  return (
    <td>
      <div
        style={{
          display: "flex",
          justifyContent: "center",
          alignItems: "center",
          cursor: "pointer",
          gap: 8
        }}
        onClick={handleToggle}
      >
        <GroupIcon style={{ color: "#555" }} />

        {isExpanded ? (
          <ArrowDropUpIcon />
        ) : (
          <ArrowDropDownIcon />
        )}

      </div>
    </td>
  );
};



const detailRowRenderer = (
  trElement: React.ReactElement<HTMLTableRowElement>,
  dataItem: OrganizationTableData
) => {

  const rowKey = dataItem[props.KEY];

  if (expandedFocalRowKey !== rowKey) return trElement;

  const cells = React.Children.toArray(trElement.props.children);
  const colSpan = cells.length;

  return (
    <>
      {trElement}

      <tr className="k-detail-row">
        <td colSpan={colSpan} style={{ padding: "10px 20px" }}>
          <FocalPanel
            dataItem={dataItem}
            onClose={() => setExpandedFocalRowKey(null)}
          />
        </td>
      </tr>

    </>
  );
};
