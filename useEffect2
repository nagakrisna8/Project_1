const ContactFocals: React.ComponentType<GridCellProps> = (cellProps) => {

  const dataItem = cellProps.dataItem as any;

  const handleToggle = (event: React.MouseEvent<HTMLDivElement>) => {

    const gridProps: any = cellProps;

    if (gridProps.onChange) {

      const updatedDataItem = {
        ...dataItem,
        expanded: !dataItem.expanded
      };

      gridProps.onChange({
        dataItem: updatedDataItem,
        field: "expanded",
        value: updatedDataItem.expanded,
        syntheticEvent: event
      });

    }
  };

  return (
    <td>
      <div
        style={{
          display: "flex",
          justifyContent: "center",
          alignItems: "center",
          cursor: "pointer",
          gap: 8
        }}
        onClick={handleToggle}
      >
        <GroupIcon style={{ color: "#555" }} />

        {dataItem.expanded ? (
          <ArrowDropUpIcon />
        ) : (
          <ArrowDropDownIcon />
        )}
      </div>
    </td>
  );
};



