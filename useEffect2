const ContactFocals: React.ComponentType<GridCellProps> = (cellprops) => {

  const handleToggle = () => {
    const dataItem = cellprops.dataItem;

    dataItem[EXPAND_FIELD] = !dataItem[EXPAND_FIELD];

    props.itemChange({
      dataItem: dataItem,
      field: EXPAND_FIELD,
      syntheticEvent: {} as any,
      value: dataItem[EXPAND_FIELD],
      dataIndex: cellprops.dataIndex,
    });
  };

  return (
    <td>
      <span
        style={{
          display: "flex",
          alignItems: "center",
          gap: "10px",
          marginLeft: "20px",
          cursor: "pointer"
        }}
        onClick={handleToggle}
      >
        <GroupIcon style={{ color: "#555" }} />

        {cellprops.dataItem[EXPAND_FIELD] ?
          <ArrowDropUpIcon style={{ color: "#555" }} />
          :
          <ArrowDropDownIcon style={{ color: "#555" }} />
        }
      </span>
    </td>
  );
};
