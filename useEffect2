import React, { memo, useEffect, useState } from "react";
import { Grid as DataGrid, GridColumn } from "@progress/kendo-react-grid";
import { State, process } from "@progress/kendo-data-query";
import { Button } from "@mui/material";
import EasaListService from "../../EasaRegisterListService";

const AnyGrid = DataGrid as any;

interface FocalData {
  NAME: string;
  ADDRESS: string;
  PHONE: number;
  DEPARTMENT: string;
  EMAIL: string;
}

interface FocalListProps {
  orgName: string;
}

const FocalList: React.FC<FocalListProps> = memo(({ orgName }) => {

  const [focalListData, setFocalListData] = useState<FocalData[]>([]);
  const [dataState, setDataState] = useState<State>({});



  const fetchFocalList = async (organization: string) => {
    const masterdataType = 4;

    EasaListService
      .getAdminMasterDetailsTypeFocalsList(masterdataType, organization)
      .then((response) => {

        const result: FocalData[] = response?.data.map((x: any) => ({
          NAME: x.NAME,
          ADDRESS: x.ADDRESS,
          PHONE: x.PHONE,
          DEPARTMENT: x.DEPARTMENT,
          EMAIL: x.EMAIL
        }));

        setFocalListData(result);

      })
      .catch((err) => console.error(err));
  };
  useEffect(() => {
    if (!orgName) return;
    fetchFocalList(orgName);

  }, [orgName]);

  return (
    <div style={{ marginLeft: '83px', padding: "0px !important" }}>
      <div style={{
        display: "flex",
        justifyContent: "space-between",
        marginBottom: 10
      }}>
        <div>
          <span style={{
            borderBottom: "3px solid #000000",
            paddingBottom: 4,
            fontWeight: 600,
            fontSize: '16px'
          }}>
            Lists of Focals
          </span>
        </div>
      </div>
      <AnyGrid
        style={{ height: "120px", background: "white" }}
        data={process(focalListData, dataState)}
        {...dataState}
        onDataStateChange={(e: any) => setDataState(e.dataState)}
      >
        <GridColumn field="NAME" title="Focal Names" width="200px" />
        <GridColumn field="ADDRESS" title="Focal Information" width="300px" />
        <GridColumn field="PHONE" title="Phone" width="160px" />
        <GridColumn field="DEPARTMENT" title="Department" width="180px" />
        <GridColumn field="EMAIL" title="Email" width="200px" />

      </AnyGrid>

    </div>
  );
});

export default FocalList;
