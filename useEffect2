/* ---------------- Focal Panel ---------------- */

interface FocalFormData {
  focalName: string;
  phoneNo: string;
  address: string;
  email: string;
  position: string;
  title: string;
}

interface FocalPanelProps {
  dataItem: OrganizationTableData;
  organizationName: string;
  onClose: () => void;
}

const FocalPanel: React.FC<FocalPanelProps> = ({ dataItem, organizationName, onClose }) => {

  const [activeTab, setActiveTab] = useState(0);

  const [formData, setFormData] = useState<FocalFormData>({
    focalName: "",
    phoneNo: "",
    address: "",
    email: "",
    position: "",
    title: "",
  });

  const handleChange = (field: keyof FocalFormData) => (e: React.ChangeEvent<HTMLInputElement>) => {
    setFormData((prev) => ({ ...prev, [field]: e.target.value }));
  };

  const handleSave = () => {

    console.log("Organization Name:", organizationName);
    console.log("Focal Data:", formData);

    onClose();
  };

  const handleCancel = () => {
    setFormData({
      focalName: "",
      phoneNo: "",
      address: "",
      email: "",
      position: "",
      title: ""
    });

    onClose();
  };

  return (

    <div
      style={{
        border: "1px solid #e0e0e0",
        borderRadius: "4px",
        backgroundColor: "#fff",
        margin: "4px 8px 8px 8px",
        padding: "0 12px 12px 12px",
        boxShadow: "0 2px 8px rgba(0,0,0,0.08)"
      }}
    >

      <Typography style={{ fontWeight: 600, marginBottom: "10px" }}>
        Organization : {organizationName}
      </Typography>

      <Tabs
        value={activeTab}
        onChange={(_, val) => setActiveTab(val)}
        sx={{ borderBottom: "1px solid #e0e0e0", minHeight: 36 }}
      >
        <Tab label="Add New Focal" />
        <Tab label="Lists of Focals" />
      </Tabs>

      {activeTab === 0 && (

        <Box sx={{ pt: 2 }}>

          <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: "12px 24px" }}>

            <TextField label="Focal Name" size="small"
              value={formData.focalName}
              onChange={handleChange("focalName")}
            />

            <TextField label="Phone" size="small"
              value={formData.phoneNo}
              onChange={handleChange("phoneNo")}
            />

            <TextField label="Address" size="small"
              value={formData.address}
              onChange={handleChange("address")}
            />

            <TextField label="Email" size="small"
              value={formData.email}
              onChange={handleChange("email")}
            />

            <TextField label="Position" size="small"
              value={formData.position}
              onChange={handleChange("position")}
            />

            <TextField label="Title" size="small"
              value={formData.title}
              onChange={handleChange("title")}
            />

          </div>

          <div style={{ display: "flex", justifyContent: "flex-end", gap: 8, marginTop: 16 }}>

            <Button variant="outlined" size="small" onClick={handleCancel}>
              Cancel
            </Button>

            <Button variant="contained" size="small" onClick={handleSave}>
              Save
            </Button>

          </div>

        </Box>

      )}

      {activeTab === 1 && (
        <Box sx={{ pt: 2 }}>
          <Typography>No focals added yet.</Typography>
        </Box>
      )}

    </div>
  );
};

/* ---------------- Main Grid ---------------- */

interface OrganizationTypeTableProps {
  KEY: string;
  columnPropsBuilder: (field: any) => { field: any; columnMenu: (props: any) => JSX.Element; headerClassName: string };
  organizationData: OrganizationTableData[];
  dataState: State;
  dataStateChange: (event: GridDataStateChangeEvent) => void;
  itemChange: (event: GridItemChangeEvent) => void;
  createOrganization: () => void;
  saveOrganization: () => void;
  dragStart: (dataItem: OrganizationTableData) => void;
  reorder: (dataItem: OrganizationTableData) => void;
  sortBy: "custom" | "asc" | "desc" | undefined;
  handleSortByChange: (key: keyof SortByData, value: "custom" | "asc" | "desc", setScreenDirty?: boolean) => void;
}

const OrganizationTable: React.FC<OrganizationTypeTableProps> = memo((props) => {

  const gridRefBuilder = useRef<any>(null);

  const [expandedFocalRowKey, setExpandedFocalRowKey] = useState<string | number | null>(null);

  const ContactFocals: React.ComponentType<GridCellProps> = (cellprops) => {

    const rowKey = cellprops.dataItem[props.KEY];
    const isOpen = expandedFocalRowKey === rowKey;

    const handleToggle = () => {
      setExpandedFocalRowKey(isOpen ? null : rowKey);
    };

    return (

      <td>

        <span
          style={{
            display: "flex",
            alignItems: "center",
            gap: "10px",
            marginLeft: "20px",
            cursor: "pointer"
          }}
          onClick={handleToggle}
        >

          <GroupIcon />

          {isOpen ? <ArrowDropUpIcon /> : <ArrowDropDownIcon />}

        </span>

      </td>

    );
  };

  const detailRowRenderer = (trElement: React.ReactElement<HTMLTableRowElement>, dataItem: OrganizationTableData) => {

    const rowKey = dataItem[props.KEY];

    if (expandedFocalRowKey !== rowKey) return trElement;

    const colSpan = React.Children.count(trElement.props.children) || 6;

    return (
      <>
        {trElement}

        <tr>

          <td colSpan={colSpan} style={{ padding: 0, border: "none" }}>

            <FocalPanel
              dataItem={dataItem}
              organizationName={dataItem.ORGANIZATIONNAME}
              onClose={() => setExpandedFocalRowKey(null)}
            />

          </td>

        </tr>

      </>
    );
  };

  return (

    <div style={{ paddingBottom: 20 }}>

      <Card style={{ borderLeft: "4px solid #0033A1", marginLeft: "22px" }}>

        <AnyGrid
          id="kgrid-oss-checklistType"
          ref={gridRefBuilder}
          style={{ height: "60vh", minHeight: 400 }}
          data={process(props.organizationData, props.dataState).data}
          dataItemKey={props.KEY}
          {...props.dataState}
          rowRender={detailRowRenderer}
        >

          <GridToolbar>

            <Button
              startIcon={<AddCircleOutlineIcon />}
              onClick={props.createOrganization}
              variant="outlined"
              size="small"
            >
              Create New
            </Button>

          </GridToolbar>

          <GridColumn {...props.columnPropsBuilder("ORGANIZATIONNAME")}
            title="Organization Name"
            width="300px"
          />

          <GridColumn
            title="Contact Focals"
            cells={{ data: ContactFocals }}
            width="200px"
          />

        </AnyGrid>

      </Card>

    </div>
  );
});

export default OrganizationTable;
