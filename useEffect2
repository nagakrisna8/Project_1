import React, { memo, useEffect, useState } from "react";
import { Grid as DataGrid, GridColumn } from "@progress/kendo-react-grid";
import { State, process } from "@progress/kendo-data-query";
import { Card } from "@mui/material";

const AnyGrid = DataGrid as any;

interface FocalData {
  ID: number;
  FOCALNAME: string;
  EMAIL: string;
  ORGANIZATION: string;
  ISACTIVE: boolean;
}

interface FocalListProps {
  orgName: string;
}

const FocalList: React.FC<FocalListProps> = memo((props) => {

  const { orgName } = props;

  const [focalListData, setFocalListData] = useState<FocalData[]>([]);
  const [dataState, setDataState] = useState<State>({
    skip: 0,
    take: 10
  });

  // API Call
  useEffect(() => {
    if (orgName) {
      fetchFocalList(orgName);
    }
  }, [orgName]);

  const fetchFocalList = async (organization: string) => {
    try {

      const response = await fetch(
        `/api/focallist?organization=${organization}`
      );

      const data = await response.json();

      setFocalListData(data);

    } catch (error) {
      console.error("Error fetching focal list:", error);
    }
  };

  return (
    <div style={{ paddingBottom: 20 }}>
      <Card
        style={{
          borderLeft: "4px solid #0033A1",
          marginLeft: "22px",
        }}
      >
        <h3 style={{ marginLeft: 20 }}>{orgName} - Focal List</h3>

        <AnyGrid
          style={{ height: "400px" }}
          data={process(focalListData, dataState)}
          {...dataState}
          pageable
          sortable
          filterable
          onDataStateChange={(e) => setDataState(e.dataState)}
        >
          <GridColumn field="FOCALNAME" title="Focal Name" width="250px" />
          <GridColumn field="EMAIL" title="Email" width="300px" />
          <GridColumn field="ORGANIZATION" title="Organization" width="200px" />
          <GridColumn field="ISACTIVE" title="Active" width="120px" />
        </AnyGrid>

      </Card>
    </div>
  );
});

export default FocalList;
