data={process(
  props.organizationData.map(item => ({
    ...item,
    expanded: item.expanded || false
  })),
  props.dataState
).data}

const expandChange = (event: any) => {
  const dataItem = event.dataItem;

  const newData = props.organizationData.map(item =>
    item[props.KEY] === dataItem[props.KEY]
      ? { ...item, expanded: !dataItem.expanded }
      : item
  );

  props.dataStateChange({
    data: newData
  } as any);
};
