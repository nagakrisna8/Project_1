const organizationItemChange = (event: GridItemChangeEvent) => {

    const field = event.field as keyof OrganizationTableData;

    const newData = organizationData.map(item => {

        const id = item.ID ?? item.ORGANIZATIONID;
        const eventId = event.dataItem.ID ?? event.dataItem.ORGANIZATIONID;

        if (id === eventId) {
            return {
                ...item,
                [field]: event.value
            };
        }

        return item;
    });

    setOrganizationData(newData);
    setDirtyFlag(true);
};
