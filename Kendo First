    handleBreadcrumsNavigation(value) {
        const menuSubmenu = new easaMenuSubmenu();
        const storageServiceTemp = new StorageService();
        if (value === "Easa Workspace") {
            if (window.location.href.indexOf(WorkAppRoutes.PMDB_ProjectRegister.APP_ROOT + "/#" + WorkAppRoutes.PMDB_ProjectRegister.EASA_PROJECT_DETAIL) > -1)
                 {
                // PROJECT DETAILS PAGE OF EASA WORKSPACE
                let routeDataArray = window.location.hash.split('/');
                window.easaMyWorkspaceProjectId = routeDataArray[routeDataArray.length - 1];
                storageServiceTemp.setApplicationDataByKey(`${process.env.REACT_APP_ROOT_NAME}-easaActiveSubMenu`, 'easaMyWorkspaceProjectId', routeDataArray[routeDataArray.length - 1]);
                menuSubmenu.setMenuSectionVisibility(true);
                storageServiceTemp.setApplicationDataByKey(`${process.env.REACT_APP_ROOT_NAME}-easaActiveSubMenu`, 'easaActiveMenu', "#nav-OSS-easaProjectDtl-tab");
                storageServiceTemp.setApplicationDataByKey(`${process.env.REACT_APP_ROOT_NAME}-easaActiveSubMenu`, 'easaActiveSubMenu', "projectDetailsBttn")                
                menuSubmenu.activateSubmenuButton();
                $('#oss-menu-breadcrums').html('');
                $('#oss-menu-breadcrums')
                    .append($('<a>').text('Home').addClass("homeBreadcurm clickable")
                        .attr("id", "idhomeBreadcurm")
                        .click(() => this.handleEASAHomeBreadcrumsClick(value)))
                    .append($('<div>').addClass("gg-chevron-right"))
                    .append($('<div>').addClass("breadcrumsStyles clickable").text("EASA My Workspace")
                        .attr("id", value)
                        .click(() => this.handleEASABreadcrumsClick(value))
                    );
             }
                else if (window.location.href.indexOf("/#" + WorkAppRoutes.CertTool.WORK_APPS_DETAILS) > -1) {
                    var projectNo = localStorage.getItem(`${process.env.REACT_APP_ROOT_NAME}-CertToolProjectNo`);
                    var CertToolReportId = localStorage.getItem(`${process.env.REACT_APP_ROOT_NAME}-CertToolReportId`);
                    storageServiceTemp.setApplicationDataByKey(`${process.env.REACT_APP_ROOT_NAME}-easaActiveSubMenu`, 'easaActiveMenu', "#nav-OSS-easaDesignDoc-tab");
                    storageServiceTemp.setApplicationDataByKey(`${process.env.REACT_APP_ROOT_NAME}-easaActiveSubMenu`, 'easaActiveSubMenu', "cclBuilderBttn")
                    menuSubmenu.activateSubmenuButton();
                    const newBreadcrumbs = storageServiceTemp.getApplicationDataByKey(`${process.env.REACT_APP_ROOT_NAME}-easaActiveSubMenu`, 'currentProjectBreadcrumbs');
                    menuSubmenu.setMenuSectionVisibility(true);
                    $("#oss-home-gridster").hide();
                    $('#oss-menu-breadcrums').html('');
                    $('#oss-menu-breadcrums')
                        .append($('<a>').text('Home').addClass("homeBreadcurm clickable")
                            .attr("id", "idhomeBreadcurm")
                            .click(() => handleCertToolBreadcrumbClick("home", value)))
                        .append($('<div>').addClass("gg-chevron-right"))
                        .append($('<div>').addClass("breadcrumsStyles clickable").text("EASA My Workspace")
                            .attr("id", value)
                            .click(() => handleCertToolBreadcrumbClick("easaworkspace", value))
                        ).append($('<div>').addClass("gg-chevron-right"))
                        .append($('<div>').addClass("breadcrumsStyles clickable").text(newBreadcrumbs)
                            .attr("id", value)
                            .click(() => handleCertToolBreadcrumbClick("projdetails", "projectDetailsBttn"))
                        ).append($('<div>').addClass("gg-chevron-right")).append($('<div>').addClass("breadcrumsStyles").text("Cert Strategy").attr("id", value))
            }
            else if (window.location.href.indexOf(WorkAppRoutes.PROJECTSCHEDULE_DETAILS.APP_ROUTE) > -1) {
                const newBreadcrumbs = storageServiceTemp.getApplicationDataByKey(`${process.env.REACT_APP_ROOT_NAME}-easaActiveSubMenu`, 'currentProjectBreadcrumbs');
                $('#oss-menu-breadcrums').html('');
                $('#oss-menu-breadcrums')
                .append($('<a>').text('Home').addClass("homeBreadcurm clickable")
                    .attr("id", "idhomeBreadcurm")
                    .click(() => this.handleEASAHomeBreadcrumsClick(value)))
                .append($('<div>').addClass("gg-chevron-right"))
                .append($('<div>').addClass("breadcrumsStyles clickable").text(value)
                    .attr("id", value)
                    .click(() => this.handleEASABreadcrumsClick(value))
                ).append($('<div>').addClass("gg-chevron-right"))
                .append($('<div>').addClass("breadcrumsStyles clickable").text(newBreadcrumbs)
                    .attr("id", value)
