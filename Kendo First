export default EASAWorkapp;

export const checkForCertToolUnsavedChanges = () => {
    const storageServiceTemp = new StorageService();
    var cacheObj = storageServiceTemp.getApplicationDataByKey(
        `${process.env.REACT_APP_ROOT_NAME}`,
        `${process.env.REACT_APP_EASA_CertTool}`
    );
    if (cacheObj) {
        if (JSON.parse(cacheObj)[0].IsCertToolInEdit) {
            if (JSON.parse(cacheObj)[0].templatedirtyFlag) {
                return false;
            } else {
                resetApplicationDataForCertTool();
                return true;
            }
        } else {
            resetApplicationDataForCertTool();
            return true;
        }
    } else {
        return true;
    }
};

export function handleCertToolBreadcrumbClick(switchCaseValue, forwardValue) {
    const storageServiceTemp = new StorageService();
    const dirtyflag = !checkForCertToolUnsavedChanges();
    if (switchCaseValue == "home") {
        if (dirtyflag) {
            const newJson = {
                home: forwardValue,
                easaworkspace: false,
                projdetails: false,
            };
            storageServiceTemp.setApplicationDataByKey(`${process.env.REACT_APP_ROOT_NAME}`, `${process.env.REACT_APP_EASA_CertTool}-breadcrumbs`, newJson);
            $('#unsavedChanges').modal('show');
        } else {
            const easaWorkappTemp = new EASAWorkapp();
            easaWorkappTemp.handleEASAHomeBreadcrumsClick(forwardValue);
        }
    } else if(switchCaseValue == "easaworkspace") {
        if (dirtyflag) {
            const newJson = {
                home: false,
                easaworkspace: forwardValue,
                projdetails: false,
            };
            storageServiceTemp.setApplicationDataByKey(`${process.env.REACT_APP_ROOT_NAME}`, `${process.env.REACT_APP_EASA_CertTool}-breadcrumbs`, newJson);
            $('#unsavedChanges').modal('show');
        } else {
            const easaWorkappTemp = new EASAWorkapp();
            easaWorkappTemp.handleEASABreadcrumsClick(forwardValue);
        }
    } else if (switchCaseValue == "projdetails") {
        if (dirtyflag) {
            const newJson = {
                home: false,
                easaworkspace: false,
                projdetails: forwardValue,
            };
            storageServiceTemp.setApplicationDataByKey(`${process.env.REACT_APP_ROOT_NAME}`, `${process.env.REACT_APP_EASA_CertTool}-breadcrumbs`, newJson);
            $('#unsavedChanges').modal('show');
        } else {
            const menuSubmenu = new easaMenuSubmenu();
            menuSubmenu.handleSubMenuButtonClick(forwardValue);
        }
    } else if (switchCaseValue == "menusubmenu") {
        const menuSubmenu = new easaMenuSubmenu();
        menuSubmenu.handleSubMenuButtonClick(forwardValue);
    }
}

export const resetApplicationDataForCertTool = () => {
    var storageService = new StorageService();
    var jsonValue = [
        {
            IsCertToolInEdit: false,
            templatedirtyFlag: false,
            moduledirtyFlag: false,
            hoursdirtyFlag: false,
        },
    ];
    var newJson = JSON.stringify(jsonValue);
    storageService.setApplicationDataByKey(`${process.env.REACT_APP_ROOT_NAME}`,
        `${process.env.REACT_APP_EASA_CertTool}`,
        newJson
    );
};
