    receiveWorkappData(tempWorkAppData) {
        if (process.env.REACT_APP_DDTL == tempWorkAppData["AppName"] && tempWorkAppData["Action"] == "Navigate_Project_Register") {
            let navigationTo = tempWorkAppData["Detail"];
            singleSpa.navigateToUrl(WorkAppRoutes.PMDB_ProjectRegister.APP_ROOT + "/#" + navigationTo["BerdCrumb"] + "&ddtl");
            this.handleBreadcrumsNavigation("Project Register");
