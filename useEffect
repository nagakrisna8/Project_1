const isModified = () => {
    if (!focalData) return true;

    return (
        formData.name !== (focalData.NAME ?? "") ||
        formData.address !== (focalData.ADDRESS ?? "") ||
        formData.phone !== String(focalData.PHONENO ?? "") ||
        formData.email !== (focalData.EMAIL ?? "") ||
        formData.position !== (focalData.POSITION ?? "") ||
        formData.title !== (focalData.TITLE ?? "") ||
        formData.isActive !== (focalData.ISACTIVE ?? false)
    );
};

const handleSave = async () => {

    // For new row → check if user entered anything
    if ((focalData as any)?.newFlag) {

        const hasData =
            formData.name ||
            formData.address ||
            formData.phone ||
            formData.email ||
            formData.position ||
            formData.title;

        if (!hasData) {
            dispatch(showSnackbar({
                snackbarOpen: true,
                snackbarType: "warning",
                snackbarMessage: "No data to save."
            }));
            return;
        }
    }

    // For existing row → check if modified
    if (!(focalData as any)?.newFlag && !isModified()) {
        dispatch(showSnackbar({
            snackbarOpen: true,
            snackbarType: "info",
            snackbarMessage: "No changes to save."
        }));
        return;
    }
