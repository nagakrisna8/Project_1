// 1️⃣ Empty validation (both fields)
if (
  current.some(
    (i) =>
      !i.ACTIVITYCATEGORY ||
      i.ACTIVITYCATEGORY.trim() === "" ||
      !i.ACTIVITYDESCRIPTION ||
      i.ACTIVITYDESCRIPTION.trim() === ""
  )
) {
  dispatch(
    showSnackbar({
      snackbarOpen: true,
      snackbarType: "error",
      snackbarMessage: "Please fill details.",
    })
  );
  return;
}

// 2️⃣ Combined duplicate validation
const uniqueCombinationCount = new Set(
  current.map(
    (i) =>
      `${i.ACTIVITYCATEGORY.trim().toLowerCase()}__${i.ACTIVITYDESCRIPTION.trim().toLowerCase()}`
  )
).size;

if (uniqueCombinationCount !== current.length) {
  dispatch(
    showSnackbar({
      snackbarOpen: true,
      snackbarType: "error",
      snackbarMessage:
        "Activity Category + Description combination must be unique.",
    })
  );
  return;
}
