try {

    const response = await EasaListService.addMasterDataType(payload);

    if (response === -1) {

        dispatch(showSnackbar({
            snackbarOpen: true,
            snackbarType: "error",
            snackbarMessage: "Error in saving the data."
        }));

        return;
    }

    dispatch(showSnackbar({
        snackbarOpen: true,
        snackbarType: "success",
        snackbarMessage: "Focal saved successfully."
    }));

    fetchFocal?.();
    handleCancel();

} catch (error) {

    dispatch(showSnackbar({
        snackbarOpen: true,
        snackbarType: "error",
        snackbarMessage: "Error saving Focal."
    }));

    console.error("Error saving focal:", error);
}
