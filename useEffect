useEffect(() => {
    if (focalData) {
        const fromSaved = savedFormData;
        const freshId = (focalData as any)?.newFlag ? 0 : (focalData.ID ?? 0);

        // Only restore savedFormData if it belongs to same record AND has unsaved edits
        const hasSavedEdits = fromSaved && fromSaved.id === freshId;

        if (hasSavedEdits) {
            setFormData(fromSaved); // ← restore unsaved typing
        } else {
            // Always load fresh from focalData
            const initial = {
                id: freshId,
                name: focalData.NAME ?? "",
                address: focalData.ADDRESS ?? "",
                phone: String(focalData.PHONENO ?? ""),
                email: focalData.EMAIL ?? "",
                position: focalData.POSITION ?? "",
                title: focalData.TITLE ?? "",
                isActive: focalData.ISACTIVE ?? false
            };
            setFormData(initial);
            onFormChange?.(initial);
        }
    }
}, []);
