import React, { memo, useEffect, useState } from "react";
import { Grid as DataGrid, GridColumn } from "@progress/kendo-react-grid";
import { State, process } from "@progress/kendo-data-query";
import { Card } from "@mui/material";
import EasaListService from "../../EasaRegisterListService";

const AnyGrid = DataGrid as any;

interface FocalData {
  NAME: string,
  ADDRESS: string,
  PHONE: number,
  DEPARTMENT: string,
  EMAIL: string
}

interface FocalListProps {
  orgName: string;
}

const FocalList: React.FC<FocalListProps> = memo((props) => {

  const { orgName } = props;

  const [focalListData, setFocalListData] = useState<FocalData[]>([]);
  const [dataState, setDataState] = useState<State>({
    skip: 0,
    take: 10
  });

  // API Call
  useEffect(() => {
    if (orgName) {
      fetchFocalList(orgName);
    }
  }, [orgName]);
  useEffect(() => {
   if (!orgName) return;
   fetchFocalList(orgName);
}, [orgName]);

  const fetchFocalList = async (organization: string) => {
    const masterdataType = 4;
    EasaListService.getAdminMasterDetailsTypeFocalsList(masterdataType, organization)
      .then((response) => {
        let result: FocalData[] = response?.data.map(x => ({
          NAME: x.NAME,
          ADDRESS: x.ADDRESS,
          PHONE: x.PHONE,
          DEPARTMENT: x.DEPARTMENT,
          EMAIL: x.EMAIL
        }));
        setFocalListData(result);
      })
      .catch((err) => console.error(err));
  };

  return (
    <div style={{ paddingBottom: 20 }}>

      <AnyGrid
        style={{ height: "200px" }}
        data={process(focalListData, dataState)}
        {...dataState}
        onDataStateChange={(e) => setDataState(e.dataState)}
      >
        <GridColumn field="NAME" title="Focal Name" width="250px" />
        <GridColumn field="ADDRESS" title="Focal Information" width="300px" />
        <GridColumn field="PHONE" title={'\u00A0'} width="200px" />
        <GridColumn field="DEPARTMENT" title={'\u00A0'} width="120px" />
        <GridColumn field="EMAIL" title={'\u00A0'} width="300px" />

      </AnyGrid>


    </div>
  );
});

export default FocalList;
