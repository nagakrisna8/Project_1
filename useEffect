import React, { memo, useState, useEffect } from "react";
import { Grid as DataGrid } from "@progress/kendo-react-grid";
import { State } from "@progress/kendo-data-query";
import EasaListService from "../../EasaRegisterListService";
import { Button, TextField } from "@mui/material";
import "./FocalForm.scss";

const AnyGrid = DataGrid as any;

interface FocalData {
    NAME: string;
    ADDRESS: string;
    PHONE: number;
    DEPARTMENT: string;
    EMAIL: string;
    TITLE?: string;
}

interface FocalListProps {
    focalData?: any;
}

const focalCache: { [key: string]: FocalData[] } = {};

const FocalForm: React.FC<FocalListProps> = memo(({ focalData }) => {

    const [focalListData, setFocalListData] = useState<FocalData[]>([]);
    const [dataState, setDataState] = useState<State>({});

    const [formData, setFormData] = useState({
        name: "",
        address: "",
        phone: "",
        email: "",
        position: "",
        title: ""
    });

    // Populate form when focalData changes
    useEffect(() => {
        if (focalData) {
            setFormData({
                name: focalData.NAME || "",
                address: focalData.ADDRESS || "",
                phone: String(focalData.PHONE || ""),
                email: focalData.EMAIL || "",
                position: focalData.DEPARTMENT || "",
                title: focalData.TITLE || ""
            });
        }
    }, [focalData]);

    const fetchFocalList = async (organization: string) => {

        if (focalCache[organization]) {
            setFocalListData(focalCache[organization]);
            return;
        }

        const masterdataType = 4;

        try {
            const response =
                await EasaListService.getAdminMasterDetailsTypeFocalsList(
                    masterdataType,
                    organization
                );

            const result: FocalData[] = response?.data.map((x: any) => ({
                NAME: x.NAME,
                ADDRESS: x.ADDRESS,
                PHONE: x.PHONE,
                DEPARTMENT: x.DEPARTMENT,
                EMAIL: x.EMAIL
            }));

            focalCache[organization] = result;
            setFocalListData(result);

        } catch (error) {
            console.error("Error fetching focal list:", error);
        }
    };

    const handleChange = (e: any) => {
        setFormData({
            ...formData,
            [e.target.name]: e.target.value
        });
    };

    const handleSave = () => {
        console.log("Save Focal:", formData);
    };

    const handleCancel = () => {
        setFormData({
            name: "",
            address: "",
            phone: "",
            email: "",
            position: "",
            title: ""
        });
    };

    return (
        <div className="focal-container">

            <div className="focal-form">

                <div className="form-header">
                    Add Focal
                </div>

                <div className="form-grid">

                    <div className="form-row">
                        <label>Focal Name</label>
                        <TextField
                            name="name"
                            value={formData.name}
                            onChange={handleChange}
                            size="small"
                            fullWidth
                        />
                    </div>

                    <div className="form-row">
                        <label>Phone No</label>
                        <TextField
                            name="phone"
                            value={formData.phone}
                            onChange={handleChange}
                            size="small"
                            fullWidth
                        />
                    </div>

                    <div className="form-row">
                        <label>Address</label>
                        <TextField
                            name="address"
                            value={formData.address}
                            onChange={handleChange}
                            size="small"
                            fullWidth
                        />
                    </div>

                    <div className="form-row">
                        <label>Email</label>
                        <TextField
                            name="email"
                            value={formData.email}
                            onChange={handleChange}
                            size="small"
                            fullWidth
                        />
                    </div>

                    <div className="form-row">
                        <label>Position</label>
                        <TextField
                            name="position"
                            value={formData.position}
                            onChange={handleChange}
                            size="small"
                            fullWidth
                        />
                    </div>

                    <div className="form-row">
                        <label>Title</label>
                        <TextField
                            name="title"
                            value={formData.title}
                            onChange={handleChange}
                            size="small"
                            fullWidth
                        />
                    </div>

                </div>

                <div className="form-actions">

                    <Button
                        variant="contained"
                        onClick={handleSave}
                    >
                        Save
                    </Button>

                    <Button
                        variant="outlined"
                        onClick={handleCancel}
                    >
                        Cancel
                    </Button>

                </div>

            </div>

        </div>
    );
});

export default FocalForm;
