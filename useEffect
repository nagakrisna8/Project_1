import React, { memo, useCallback, useEffect, useRef, useState } from "react";
import { OrganizationTypeMasterTable, SortByData } from "../AdminModal";
import { getter, State, process } from "@progress/kendo-data-query";
import { Grid as DataGrid, GridCellProps, GridColumn, GridColumnMenuFilter, GridColumnMenuProps, GridDataStateChangeEvent, GridItemChangeEvent, GridToolbar } from "@progress/kendo-react-grid";
import { Box, Button, Card, FormControl, MenuItem, Select, TextField, Typography } from "@mui/material";
import AddCircleOutlineIcon from "@mui/icons-material/AddCircleOutline";
import { filterIcon } from "@progress/kendo-svg-icons";
import { useDispatch } from "react-redux";
import SettingsIcon from '@mui/icons-material/Settings';
import ArrowUpwardIcon from '@mui/icons-material/ArrowUpward';
import ArrowDownwardIcon from '@mui/icons-material/ArrowDownward';
import SortIcon from '@mui/icons-material/Sort';

const editField = "inEdit";
const SELECTED_FIELD: string = "selected";
const AnyGrid = DataGrid as any;
const GridFilterMenuWithoutSort = (props: GridColumnMenuProps) => {
  return (
    <div>
      <GridColumnMenuFilter {...props} expanded={true} />
    </div>
  );
};
interface OrganizationTypeTableProps {
  KEY: string;
  columnPropsBuilder: (field: any) => {
    field: any;
    columnMenu: (props: any) => JSX.Element;
    headerClassName: string;
  };
  organizationTypeData: OrganizationTypeMasterTable[];
  dataState: State;
  dataStateChange: (event: GridDataStateChangeEvent) => void;
  itemChange: (event: GridItemChangeEvent) => void;
  createOrganizationType: () => void;
  saveOrganizationType: () => void;
  dragStart: (dataItem: OrganizationTypeMasterTable) => void;
  reorder: (dataItem: OrganizationTypeMasterTable) => void;
  sortBy: "custom" | "asc" | "desc" | undefined
  handleSortByChange: (key: keyof SortByData, value: "custom" | "asc" | "desc", setScreenDirty?: boolean) => void
}

const OrganizationTypeTable: React.FC<OrganizationTypeTableProps> = memo((props) => {
  const gridRefBuilder = useRef<any>(null);
  const [calculatedDynamicColWidth, setCalculatedDynamicColWidth] = useState(0);
  const [totalColumnFixedWidth, setTotalColumnFixedWidth] = useState(0);
  const OrganizationTypeNameCell: React.ComponentType<GridCellProps> = useCallback((cellProps) => {
    const { dataItem } = cellProps;
    const field = cellProps.field || "";
    const dataValue = dataItem[field] === null ? "" : dataItem[field];

    const handleChange: React.ChangeEventHandler<HTMLInputElement | HTMLTextAreaElement> = (event) => {
      if (cellProps.onChange) {
        const updatedDataItem: OrganizationTypeMasterTable = { ...cellProps.dataItem };
        updatedDataItem.ORGANIZATIONTYPE = event.target.value;
        cellProps.onChange({
          dataIndex: cellProps.dataIndex,
          dataItem: updatedDataItem,
          field: cellProps.field,
          syntheticEvent: event,
          value: event.target.value,
        });
      }
    };

    return (
      <td title={dataValue}>
        <TextField
          fullWidth
          className="dc-easa-input"
          value={dataValue}
          onChange={handleChange}
        />

      </td>
    );
  }, []);
  const DragCell: React.ComponentType<GridCellProps> = (dragcellprops) => {
    return (
      <td
        onDragOver={(e) => {
          e.preventDefault();
          e.dataTransfer.dropEffect = "copy";
          props.reorder(dragcellprops.dataItem);
        }}
      >
        <span
          className="k-icon k-i-reorder"
          draggable={true}
          style={{
            cursor: "move",
            color: "#737373",
            display: "flex",
            justifyContent: "center",
          }}
          onDragStart={(e) => {
            props.dragStart(dragcellprops.dataItem);
            e.dataTransfer.setData("dragging", "");
          }}
        >
          <SortIcon />
        </span>
      </td>
    );
  };
  useEffect(() => {
    if (gridRefBuilder?.current) {
      const headerCells = gridRefBuilder.current.element.querySelectorAll('.k-header');
      let calculatedFixedColumnWidth = 0;
      let dynamicWidth = 0;
      headerCells.forEach((cell, index) => {
        if (gridRefBuilder.current.columns[index].width != undefined) {
          if (gridRefBuilder.current.columns[index].width.toString().indexOf('px') > -1) {
            calculatedFixedColumnWidth = calculatedFixedColumnWidth + parseInt(gridRefBuilder.current.columns[index].width)
          }
          else {
            dynamicWidth = dynamicWidth + gridRefBuilder.current.columns[index].width;
          }
        };
        const columnHeader = gridRefBuilder.current.columns[index].title;
        cell.title = columnHeader;
      });
      setCalculatedDynamicColWidth(dynamicWidth);
      setTotalColumnFixedWidth(calculatedFixedColumnWidth)
    }
  }, [gridRefBuilder])

  const setPercentage = (width = 0, percentage = 0, minWidth = 0) => {
    let k_grid_width = document.querySelector("#kgrid-oss-checklistType")?.clientWidth;
    let fixedWidth = totalColumnFixedWidth;
    let dynamicWidth = 0;
    let minScreenWidth = 1250;
    let maxScreenWidth;
    if (k_grid_width) {
      if (k_grid_width <= minScreenWidth) {
        return minWidth;
      }
      else {
        dynamicWidth = k_grid_width - fixedWidth;
        if (width == 0 && dynamicWidth > 0 && percentage > 0) {
          const dynamicColumnWidth = Math.round(dynamicWidth * (percentage / 100));
          return Math.max(minWidth, dynamicColumnWidth);
        }
        else {
          return calculatedDynamicColWidth != 0 ? minWidth > (dynamicWidth - calculatedDynamicColWidth) ? minWidth : undefined : undefined
        }
      }
    }

  }

  const activeCheckbox: React.ComponentType<GridCellProps> = (cellProps) => {
    const dataItem: OrganizationTypeMasterTable = cellProps.dataItem;
    const handleActiveChange: React.ChangeEventHandler<HTMLInputElement> = async (e) => {
      if (cellProps.onChange) {
        const updatedDataItem: OrganizationTypeMasterTable = { ...dataItem };
        updatedDataItem.ISACTIVE = e.target.checked;

        if (cellProps.onChange) {
          cellProps.onChange({
            dataIndex: cellProps.dataIndex,
            dataItem: updatedDataItem,
            field: cellProps.field,
            syntheticEvent: {} as React.SyntheticEvent,
            value: e.target.value,
          });
        }


      }
    }
    return (
      <td title={dataItem.ISACTIVE ? "True" : "False"}>
        <div style={{ width: "100%", height: "100%", display: "flex", justifyContent: "center", alignItems: "center" }}>
          <input type="checkbox" style={{ marginLeft: "3px", cursor: "pointer" }} checked={dataItem.ISACTIVE} onChange={handleActiveChange}
          />
        </div>
      </td>
    );
  };

  return (
     <div style={{ height: "calc(100vh - 240px)" }}>
      <Card
        style={{
          borderLeft: "4px solid #0033A1",
          marginLeft: "22px",
          overflow: "hidden",
          maxHeight: "calc(100vh - 240px)",
        }}
      >
        <AnyGrid
          id="kgrid-oss-checklistType"
          ref={gridRefBuilder}
          scrollable="scrollable"
          data={process(props.organizationTypeData, props.dataState).data}
          selectable={{ enabled: true, drag: false, cell: false, mode: "multiple" }}
          editField={editField}
          onItemChange={props.itemChange}
          resizable
          dataItemKey={props.KEY}
          sortable={false}
          rowHeight={30}
          {...props.dataState}
          selectedField={SELECTED_FIELD}
          onDataStateChange={props.dataStateChange}
          columnMenuIcon={filterIcon}
        >
          <GridToolbar key="grid-toolbar">
            {
              <Button
                className="easalist-marginLeft10"
                id="createBtn"
                title="Create New"
                onClick={props.createOrganizationType}
                size={"small"}
                color={"inherit"}
                variant={"outlined"}

              >
                <AddCircleOutlineIcon className="iconClass" />
                <Typography
                  variant={"button"}
                  sx={{ textTransform: "none", fontSize: "14px" }}
                >
                  Create New
                </Typography>
              </Button>
            }

            {
              < Button
                className="easalist-marginLeft10"
                id="deleteBtn"
                title="Delete"
                onClick={props.saveOrganizationType}
                variant={"outlined"}
                size={"small"}
                color={"inherit"}
              >
                <Typography
                  variant={"button"}
                  sx={{ textTransform: "none", fontSize: "14px" }}
                >
                  Save
                </Typography>
              </Button >
            }
            {
              <Box
                sx={{
                  display: "flex",
                  alignItems: "center",
                  gap: 1.5,
                  position: "absolute",
                  right: 20,
                }}
              >
                <Typography
                  variant="body2"
                  sx={{
                    color: "#253746",
                    fontWeight: 500,
                    whiteSpace: "nowrap",
                  }}
                >
                  Sort Order :
                </Typography>
                <FormControl variant="outlined">
                  <Select
                    id="register-type-select-dropdown"
                    className="text-normal"
                    style={{
                      width: "200px",
                      height: "32px",
                      fontSize: "14px",
                      color: "#253746",
                    }}
                    value={props.sortBy || "custom"}
                    onChange={(e) =>
                      props.handleSortByChange(
                        "organizationType",
                        e.target.value as "custom" | "asc" | "desc"
                      )
                    }
                  >
                    <MenuItem value="custom">
                      <SettingsIcon style={{ height: 16, width: 16, marginRight: 8 }} />
                      Customize
                    </MenuItem>
                    <MenuItem value="asc">
                      <ArrowUpwardIcon style={{ height: 16, width: 16, marginRight: 8 }} />
                      Organization Type : Ascending
                    </MenuItem>
                    <MenuItem value="desc">
                      <ArrowDownwardIcon style={{ height: 16, width: 16, marginRight: 8 }} />
                      Organization Type : Descending
                    </MenuItem>
                  </Select>
                </FormControl>
              </Box>
            }
          </GridToolbar>

          <GridColumn title="Sort" cells={{ data: DragCell }} width="90px" />

          <GridColumn
            {...props.columnPropsBuilder("ORGANIZATIONTYPE")}
            title="Organization Type"
            cells={{ data: OrganizationTypeNameCell }}
            width={setPercentage(undefined, 0, 272)}
            columnMenu={GridFilterMenuWithoutSort}
          />

          <GridColumn
            {...props.columnPropsBuilder("ISACTIVE")}
            title="Active"
            cells={{ data: activeCheckbox }}
            width="165px"
            columnMenu={GridFilterMenuWithoutSort}
          />
        </AnyGrid>
      </Card>
    </div>
  );
});

export default OrganizationTypeTable;
