const convertToApiSort = (sortDataState: State): { Field: string | null, Dir: "asc" | "desc" | null | undefined } => {
    const sortVal = {
        Field: sortDataState?.sort != undefined && sortDataState?.sort?.length != 0 ? sortDataState?.sort[0].field : null,
        Dir: sortDataState?.sort != undefined && sortDataState?.sort?.length != 0 ? sortDataState?.sort[0].dir : null,
    }
    return sortVal;
};

const convertToApiFilter = (filterDataState) => {
    let filterVal: ParameterObject[] = [];
    let filterObjects: FilterParam[] = [];

    if (filterDataState?.filter != undefined && filterDataState?.filter?.length != 0) {
        if (filterDataState?.filter?.filters?.length != 0) {
            for (let i = 0; i < filterDataState?.filter?.filters?.length; i++) {
                if (filterDataState?.filter?.filters[i]?.filters?.length != 0) {
                    filterVal = [];
                    for (let j = 0; j < filterDataState?.filter?.filters[i]?.filters?.length; j++) {
                        const parameterObject: ParameterObject = {
                            Field: filterDataState?.filter?.filters[i]?.filters[j]?.field,
                            Operator: filterDataState?.filter?.filters[i]?.filters[j]?.operator,
                            Value: filterDataState?.filter?.filters[i]?.filters[j]?.value
                        };
                        filterVal.push(parameterObject);
                    }
                    const filterObj: FilterParam = {
                        FilterObject: filterVal,
                        Logic: filterDataState?.filter?.filters[i]?.logic
                    };
                    filterObjects.push(filterObj);
                    filterObjectsparam.push(filterObj);
                }
            }
        }
    }
    return filterObjects;
}

