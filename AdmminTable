const template = selectedTemplate?.TemplateTitle;

// ✅ Only for DDTL / DQN
if (template === ReportType.DDTL || template === ReportType.DQN) {

    // Organization Name
    if (!csrHeaderData[0]?.SupplierName?.trim()) {
        newErrors.SupplierName = "* Organization name is required";
        validationFlag = false;
    } else {
        newErrors.SupplierName = "";
    }

    // Organization Type (multi checkbox)
    if (!csrHeaderData[0]?.OrganizationTypeList?.length) {
        newErrors.OrganizationType = "* Organization type is required";
        validationFlag = false;
    } else {
        newErrors.OrganizationType = "";
    }
}
