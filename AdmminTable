useEffect(() => {
  return () => {
    // 🔥 This runs when you leave the page
    if (eventData?.Detail) {
      eventData.Detail.isFromNavigation = false;
    }

    // If you're using storage, clear it there too
    const storageService = new StorageService();
    storageService.set('isFromNavigation', false);
  };
}, []);
