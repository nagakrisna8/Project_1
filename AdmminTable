   const handleChange = (e: SelectChangeEvent<any>) => {
            const value =
                typeof e.target.value === "string"
                    ? e.target.value
                        .split(",")
                        .map((x) => Number(x))
                    : (e.target.value as number[]);

            setSelectedTasks(value);
            if (props.onChange) {
                props.onChange({
                    dataIndex: props.dataIndex,
                    dataItem: props.dataItem,
                    field: canonicalField,
                    syntheticEvent: e as unknown as SyntheticEvent,
                    value: value.length > 0 ? value.join(",") : "",
                } as GridItemChangeEvent);
            }
            props.dataItem["TaskId"] = value.join(",");
            props.dataItem[canonicalField] = value.join(",");
            _handleDirtyFlag(true);
        };
