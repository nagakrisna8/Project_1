  const openPDFForView = () => {
    CSRDetailsBaseService.GetSignedDocument((parseInt(reportId || "0")), csrHeaderData?.[0]?.EnvelopeId).then(response => {
      //Create a Blob from the PDF Stream
      const file = new Blob([response.data], { type: "application/pdf" });
      //Build a URL from the file
      const fileURL = URL.createObjectURL(file);

      // Show different preview option once report got released
      const isReleased = csrHeaderData?.[0]?.RELEASE_DATE != null;
      if (isReleased) {
        // Create a temporary anchor element to trigger the download
        const link = document.createElement('a');
        link.href = fileURL;
        // Use the filename from the C# backend's Content-Disposition header if available, otherwise use the passed filename
        const contentDisposition = response.headers['content-disposition'];
        // By default generate Random GUID
        let downloadFileName = crypto.randomUUID() + ".pdf";

        if (contentDisposition) {
          const fileNameMatch = contentDisposition.match(/filename="(.+)"/);
          if (fileNameMatch.length === 2) downloadFileName = fileNameMatch[1];
        }
        link.setAttribute('download', downloadFileName);
        // Append link to body, click it, and remove it
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
      } else {
        //Open the URL in Browser Window
        var strWindowFeatures = "location=yes,height=600,width=720,scrollbars=yes,status=yes";
        const pdfWindow: any = window.open(fileURL, '_blank', strWindowFeatures);
      }
    });
  }

