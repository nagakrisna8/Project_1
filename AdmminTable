    { text: "Overview", url: PathConstants.CCL, state: "", dontShowStatus: true, page: "overview" },
    { text: "Cert Classification", url: PathConstants.CCN, state: "", page: "ccn" },
    { text: "Description Of Change", url: PathConstants.DOC, state: "", disabled: true, page: "doc" },
    { text: "CCL Matrix", url: PathConstants.CCLMATRIX, state: "", disabled: true, page: "ccl" },
    { text: "CRI Applicability", url: PathConstants.CRI, state: "", disabled: true, page: "cri" },
    { text: "Cert Checklist", url: PathConstants.CERTCHECKLIST, state: "", disabled: true, page: "ccldoc" },
    { text: "Cert Memoranda", url: PathConstants.CM, state: "", disabled: true, page: "cm" },
    { text: "Cert LOI", url: PathConstants.LOI, state: "", disabled: true, page: "loi" },
    { text: "Cert Plan", url: PathConstants.CP, state: "", disabled: true, page: "cpdoc" },
];
