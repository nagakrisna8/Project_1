    function generateUnique5DigitId(existingItems: CclReportdata[], maxAttempts = 10000): number {
        const existingIds = new Set(existingItems.map(item => item.Report_Id));
        let attempts = 0;
        while (attempts < maxAttempts) {
            const candidate = random5DigitsInt();
            if (!existingIds.has(candidate)) return candidate;
            attempts++;
        }
