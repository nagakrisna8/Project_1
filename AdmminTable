    function normalizeToNumberArray(sdid): number[] {
        if (sdid === undefined || sdid === null || sdid === "") return [];

        if (Array.isArray(sdid)) {
            return sdid.map(Number).filter(n => !Number.isNaN(n));
        }

        // handle comma-separated string or single value (string or number)
        return String(sdid)
            .split(",")
            .map(v => v.trim())
            .filter(Boolean)
            .map(Number)
            .filter(n => !Number.isNaN(n));
    }

