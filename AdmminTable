    if (tabIndex && tabIndex.toString().indexOf(FixedTabTitle.CONFIGURE_SUBSTANTIATION_TAB_INDEX) > -1) {
      currentRef = configureSubstantiationRef;
    } else if (tabIndex && tabIndex.toString().indexOf(FixedTabTitle.CONFIGURE_REFERENCES_TAB_INDEX) > -1) {
      currentRef = configureReferencesRef;
    }

    if (currentRef && currentRef.current) {
      const checkCompGrid = currentRef.current.handleConfigRefInsert();
      if (checkCompGrid && checkCompGrid.loadedGrid == null && tabIndex == FixedTabTitle.CONFIGURE_REFERENCES_TAB_INDEX) {
        return true;
      } else {
        return false;
      }
    }
  };

  const checkIsComplainceGridTab = () => {
    if ((tabIndex == FixedTabTitle.CONFIGURE_REFERENCES_TAB_INDEX && !checkIsRefGrid) || checkIsBoeingSection() || (tabIndex == FixedTabTitle.CONFIGURE_SUBSTANTIATION_TAB_INDEX && checkISubComp === null)) {
      return true;
    } else {
      return false;
    }
  };

  const disableSaveOnRefTab = () => {
    if ((tabIndex == FixedTabTitle.CONFIGURE_REFERENCES_TAB_INDEX && checkIsRefGrid === null) || (tabIndex == FixedTabTitle.CONFIGURE_SUBSTANTIATION_TAB_INDEX && checkISubComp === null)) {
      return true;
    } else {
      return false;
    }
  };

  const MemoizedOutlet = useMemo(() => <Outlet context={{ ParentData: { refreshPage: refreshPage, tabList: tabList, ref: childRef, genRef: generalRef, revRef: revisionRef, revLogRef: revisionLogRef, signRef: signatureRef, configureSubstantiationRef: configureSubstantiationRef, configureReferencesRef: configureReferencesRef, commentSummaryRef: commentSummaryRef, tabContentMaxHeight: scrollableMaxHeight, refreshTabList: refreshTabList, getProjectCommentCount: GetProjectCommentCount, handleTabTitle: handleTabTitle, loadSupportingData: loadSupportingData, loadSubStantiationData: loadSubStantiationData, selectedTab: selectedTab, tabRefresh, updateTableResize, isTableResizeRef } }} />,
    [tabList, childRef, generalRef, revisionRef, revisionLogRef, signatureRef, scrollableMaxHeight, configureSubstantiationRef, configureReferencesRef, commentSummaryRef, loadSupportingData, loadSubStantiationData, selectedTab, tabRefresh, updateTableResize]);

  const handleScrollPosition = () => {
    const setScrollPosition = window.pageYOffset;
    let scrollableDiv;
    if (scrollPositionTop) {
      scrollableDiv = document.querySelector('#compliance-report-base-page');
      const divScrollOffset = scrollableDiv.scrollTop;
      window['compliance-report-base-page'] = divScrollOffset;
      window.scroll(0, divScrollOffset);
    } else {
      window['rightPaneScrollPosition'] = setScrollPosition;
    }
    scrollPositionTop = false;
  };

  const handleComparer = () => {
    let checkIsTabDirty = storageService.getApplicationDataByKey(`${EnvDetail.ParentAppName}-${EnvDetail.AppName}`, 'IsTabDirty');
    if (checkIsTabDirty) {
      userDefinedConfirm({
        message: "There are unsaved changes in the current session. Do you want to proceed without saving?",
        okBtnText: "Yes",
        cancelBtnText: "Cancel",
      }).then(({ button, input }) => {
        storageService.setApplicationDataByKey(`${EnvDetail.ParentAppName}-${EnvDetail.AppName}`, `IsTabDirty`, false);
        setOpenCompareModal(true);
      }, () => {
        return;
      });
    } else {
      setOpenCompareModal(true);
    }
  }

  const shouldShowPreviewOrViewButton = () => {
    const isReleased = csrHeaderData?.[0]?.RELEASE_DATE != null;
    if (isReleased) return true;
    if (csrHeaderData?.[0]?.EnvelopeId !== null) {
      const isInFocalList = Array.isArray(allFocalList) && allFocalList.some(focal =>
        Array.isArray(focal?.ApproverDetailList) &&
        focal.ApproverDetailList.some(detail => detail?.BemsId === parseInt(userBemsId))
      );
      return isInFocalList;
    }
    return true;
  }

  const handleComapreBtnVisibility = () => {
    if (csrHeaderData && csrHeaderData[0]?.PARENT_RPT_ID != null && csrHeaderData[0]?.PARENT_RPT_ID > 0) {
      return true;
    } else {
      return false;
    };
  };

  const shouldDisplayWFButton = () => {
    return (csrHeaderData.length > 0 && csrHeaderData[0].PendingWithBemsId.includes(userBemsId) && csrHeaderData[0].ShowButtonFlag == "Y" && csrHeaderData[0].WFButtonTitle && (csrHeaderData[0].SignEnabledFlag == "N" || csrHeaderData[0].SignatureStatus[userBemsId] == "Y"));
  }
  const isNavigatedFromCert = storageService.getApplicationDataByKey(`${EnvDetail.ParentAppName}-${EnvDetail.AppName}`, "isFromNavigation");

  return (
    <>
      {delRptFlag === true
        ? (
          <Card className="cardSection" sx={{ minWidth: 275, height: '100%' }} style={{ marginLeft: 0, display: 'flex', alignItems: 'center', justifyContent: 'center', height: '65vh' }}>
            <CardContent style={{ padding: 24, textAlign: 'center' }}>
              <Box>
                <Typography variant="h6" component="div" color="textPrimary" gutterBottom>
                  Report is not found.
                </Typography>
                <Typography variant="body2" color="textSecondary">
                  The requested report was not found. It may have been deleted or unavailable.
                </Typography>
              </Box>
            </CardContent>
          </Card>)
        : (delRptFlag === false ? (
          <div id="compliance-report-base-page" onClick={() => handleScrollPosition()} style={{
            height: '100%',
            // maxHeight: shellWorkappContainerMaxHeight != 0 ? shellWorkappContainerMaxHeight : `${window.innerHeight}px`
          }}
            className={`adobe-FINDCSR-CSRReport ${checkIsEasaWorkSpace ? 'easa-report' : 'non-easa-report'}`}
          >
            <div className="fixedHeader"
            // style={shellMainSection != undefined ? { position: 'relative' } : { top: 0, position: 'fixed' }}
            >
              <Box sx={{ borderBottom: 0, borderColor: 'divider', display: 'flex', alignItems: 'center', justifyContent: 'space-between' }}>
                <Stack className="buttonRows" direction="row" spacing={2}>

                  {/* <Button size="medium" variant="contained" className='saveButton' onClick={saveTabDetails} disabled={parseInt(tabIndex) > 0 ? (commonFunction.isReview(csrHeaderData[0]?.STATE) ? (tabList[0]?.TabId == parseInt(tabIndex) ? false : commonFunction.isAllDisable(csrHeaderData[0]?.STATE)) : commonFunction.isAllDisable(csrHeaderData[0]?.STATE)) : tabIndex == "" && commonFunction.isReview(csrHeaderData[0]?.STATE) ? false : (parseInt(tabIndex) < 0 ? false : commonFunction.isAllDisable(csrHeaderData[0]?.STATE))}>Save</Button> */}
                  {(tabIndex && checkIsComplainceGridTab() && isCurrentUserAuthor() && !(new CommonFunction().IsEASAReport()) && csrHeaderData[0]?.WorkFlowStep == ReportStepId.CREATE_STEP) && <Button size="medium" variant="contained" className='insertButton' onClick={handleClickConfigRefInsertBtn} disabled={checkIsRefGrid === "0"} title="Insert">Insert</Button>}

                  <Button id="SaveCSR" size="medium" variant="contained" className='saveButton' onClick={saveTabDetails} disabled={disableSave()} title="Save">Save</Button>
                  {(csrHeaderData.length > 0 && csrHeaderData[0].TemplateTitle?.toUpperCase() == ReportType.Drawing.toUpperCase()
                    && csrHeaderData[0].DrawingFileName) &&
                    <>
                      {(drawingReviewInitiated == false && csrHeaderData[0].CurrentState.toUpperCase() != "DRWPDFEXTRACT" && isLoggedInUserIsDrawingDe() == true) && <Button size="medium" variant="contained" className='ReviewButton' title="Initiate Review" onClick={() => { drawingInitiateReviewClick(false) }}>Initiate Review</Button>}
                      {(drawingReviewInitiated == true && isLoggedInUserIsDrawingDe() == true && csrHeaderData[0].WorkFlowStep == 1 && csrHeaderData[0].PendingWithBemsId.includes(userBemsId)) && <Button size="medium" variant="contained" className='ReviewButton' title="Reinitiate Review" onClick={() => { drawingInitiateReviewClick(true) }}>Reinitiate Review</Button>}
                      {(csrHeaderData[0].WorkFlowCycle == 2 || (csrHeaderData[0].RPT_ID > 0
                        && userBemsId == csrHeaderData[0].AuthorBemsId) ||
                        (csrHeaderData[0].WorkFlowCycle == 1 && csrHeaderData[0].PendingWithBemsId.includes(userBemsId) == false)) &&
                        <Button size="medium" variant="contained" className='ReviewButton' title="View" onClick={() => { drawingViewReviewClick("view") }}>View</Button>
                      }
                      {(!(csrHeaderData?.[0]?.RELEASE_DATE == null && !csrHeaderData?.[0]?.EnvelopeId)) &&
                        <Button size="medium" variant="contained" className='ReviewButton' title="View" onClick={() => { openPDFForView() }}>View signed document</Button>
                      }
                      {drawingReviewInitiated == true && <>
                        {(csrHeaderData[0].WorkFlowCycle == 1 && csrHeaderData[0].PendingWithBemsId.includes(userBemsId)
                          && userBemsId != csrHeaderData[0].AuthorBemsId) &&
                          <Button size="medium" variant="contained" className='ReviewButton' title="Review" onClick={() => { drawingViewReviewClick("review") }}>Review</Button>
                        }
                      </>}
                      {/* {drawingReviewInitiated == true && <Button size="medium" variant="contained" className='ReviewButton' title="Review" onClick={() => { drawingViewReviewClick() }}>{drawingReviewButtonText}</Button>} */}
                    </>
                  }
                  {(csrHeaderData.length == 0 || (csrHeaderData.length > 0 && csrHeaderData[0].TemplateTitle?.toUpperCase() != ReportType.Drawing.toUpperCase())) &&
                    <>
                      {isFromNavigation && (<Button id="SaveCSR" size="medium" variant="contained" className='saveButton' onClick={navigationCSRtoCERT} title="Continue to Cert Strategy">Continue to Cert Strategy</Button>)}
                      {/*shouldShowPreviewOrViewButton() && */ <Button id="ViewCSR" size="small" variant="contained" className='previewIcon' disabled={!isCreateReport} onClick={handlePdfPreview} title={csrHeaderData?.[0]?.EnvelopeId !== null || csrHeaderData?.[0]?.RELEASE_DATE !== null ? "View" : "Preview"}>{csrHeaderData?.[0]?.EnvelopeId !== null || csrHeaderData?.[0]?.RELEASE_DATE !== null ? "View" : "Preview"}</Button>}
                      {shouldDisplayWFButton() && (<Button id="SubmitCSR" size="medium" variant="contained" className='approvalButton' onClick={() => WorkFlowClick("WFSubmit")} title={editReqCommentPresent ? 'Request Edit' : csrHeaderData[0].WFButtonTitle}>{editReqCommentPresent ? 'Request Edit' : csrHeaderData[0].WFButtonTitle}</Button>)}
                      {shouldDisplayButtonPullBackToEdit(csrHeaderData[0]) && (<Button id="PullBackCSR" size="medium" variant="contained" className='approvalButton' onClick={() => WorkFlowClick("WFPullback")} title='Pull Back'>Pull Back</Button>)}
                      {shouldDisplayControl(ButtonCode.FixedTableRegCode) && <Button id="ProjRegCSR" size="medium" variant="contained" className='approvalButton' onClick={() => handleConfigureRegulations()} disabled={!isCreateReport} title='Configure Regulations'>Project Regulations</Button>}
                      {shouldDisplayControl(ButtonCode.FixedTableRegCode) && <Button id="SubstantiationCSR" size="medium" variant="contained" className='approvalButton' ref={substantiationBtnRef} onClick={() => handleConfigureSubstantiation()} disabled={!isCreateReport} title='Configure Substantiation'>Substantiation</Button>}
                      {shouldDisplayControl(ButtonCode.FixedTableRefCode) && <Button id="ReferencesCSR" size="medium" variant="contained" className='approvalButton' ref={referenceBtnRef} onClick={() => handleConfigureReferences()} disabled={!isCreateReport} title='Configure References'>References</Button>}
                      {handleComapreBtnVisibility() && (<Button size="small" variant="contained" className='compareBtn' onClick={handleComparer} title="Compare">Compare</Button>)}
                      {/* {hasEditors && csrHeaderData.length > 0 && csrHeaderData[0]?.EditEnabledFlag === "Y" &&
                      csrHeaderData[0]?.WorkFlowStep == ReportStepId.CREATE_STEP && (
                        <Button size="small" variant="contained" className="compareBtn" title="Find & Replace" onClick={() => setOpenGlobalFindReplace(true)}
                        ><SvgIcon icon={binocularsIcon} size="medium" style={{ color: '#737373' }} />
                        </Button>
                      )} */}
                      <Badge id="badge"
                        anchorOrigin={{
                          vertical: "top",
                          horizontal: "right",
                        }}
                        style={{ marginRight: "15px", marginLeft: "0px" }}
                        badgeContent={commentCountDetails && commentCountDetails.TotalCommentCount}
                        color={commentCountDetails && commentCountDetails.UnResolvedCommentCount > 0 ? 'error' : 'success'}
                        showZero
                      >
                        <Button size="small" variant="contained" disabled={parseInt(reportId) <= 0} className='cmtSummaryBtn' id="commentSumBtn" title="Comment Summary"
                          onClick={handleOpenCommentSumPanel}
                        >
                          <SpeakerNotesOutlinedIcon style={{ color: '#737373' }} />
                        </Button>
                      </Badge>
                    </>
                  }
                </Stack>
              </Box>

            </div >
            <div className="scrollableBody" style={{ top: shellMainSection == undefined ? scrollableBodyTopHeight : '4px', }}>
              {/* height: scrollableBodyHeight, maxHeight: shellMainSection == undefined ? scrollableBodyHeight : scrollableMaxHeight  */}
              <Box style={{ display: 'flex', gap: '8px' }}>
                <div className={expanPanel == true ? "open-drawer" : "close-drawer"}
                  style={{
                    //height: leftSectionHeight >= window.innerHeight ? "100vh" : `${window.innerHeight}px`,
                    minHeight:
                      leftPanleContainerMaxHeight != 0
                        ? leftPanleContainerMaxHeight + 30
                        : `${window.innerHeight + 30}px`,
                    //width: `${window.innerWidth}px`,
                    overflowY: "auto",
                    overflowX: "hidden"
                  }}
                >
                  <div className={expanPanel == true ? "left-panel-open-header" : "left-panel-closed-header"}>
                    {expanPanel == true ?
                      <span id="section_header" className="leftPanel_mainLabel">
                        Section
                      </span>
                      : ''}
                    <div className="section-rightheader">
                      <span title="Manage Section">
                        {(csrHeaderData[0]?.EditEnabledFlag == "N") ? (<>
                          <EditOutlinedIcon className="disable-color editIcon" sx={{ visibility: "hidden" }} ></EditOutlinedIcon>
                        </>
                        ) : (
                          <>
                            {parseInt(reportId) > 0 && tabList.length > 0 && <EditOutlinedIcon className="editIcon cursor-pointer manage_section" onClick={() => handleOpenManageTabListPopup()}></EditOutlinedIcon>}
                          </>
                        )}
                      </span>
                      <span className={expanPanel ? "expanded-button" : "collapse-button"}>
                        {expanPanel ? (<KButton className="drawer-button" id="drawer-button" svgIcon={chevronLeftIcon}
                          size={"small"} themeColor={"primary"} onClick={handleCloseLeftTab}>
                        </KButton>) : (<KButton className="drawer-button" id="drawer-button" svgIcon={chevronRightIcon}
                          size={"small"} themeColor={"primary"} onClick={handleOpenLeftTab}>
                        </KButton>)}
                      </span>
                    </div>
                  </div>
                  <Drawer
                    className='kdrawer-oss-csr-tab-panel k-drawer-left'
                    expanded={expanPanel}
                    position={"start"}
                    mode={"push"}
                    mini={true}
                    style={{
                      minHeight: "inherit"
                    }}
                    items={updatedTabList.map((item, index) => ({
                      ...item,
                    }))}
                    item={CustomItem}
                    onSelect={onSelect}
                  >
                  </Drawer>
                </div>

                {tabList.length > 0 && MemoizedOutlet}
                {openTabListPopup ? (csrHeaderData[0].ResequenceSectionFlag == "Y" ?
                  <SortableManageTabListPopup allTabs={tabList} certType={csrHeaderData.length > 0 ? csrHeaderData[0].CERTIFICATION : ""} isOpen={openTabListPopup} handleCloseManageTabListPopup={handleCloseManageTabListPopup} handleSaveManageTabListPopup={handleSaveManageTabListPopup} STATE={csrHeaderData[0]?.STATE} />
                  : <ManageTabListPopup allTabs={tabList} certType={csrHeaderData.length > 0 ? csrHeaderData[0].CERTIFICATION : ""} isOpen={openTabListPopup} handleCloseManageTabListPopup={handleCloseManageTabListPopup} handleSaveManageTabListPopup={handleSaveManageTabListPopup} STATE={csrHeaderData[0]?.STATE} />) : null}

                {/* {openTabListPopup && <SortableManageTabListPopup allTabs={tabList} certType={csrHeaderData.length > 0 ? csrHeaderData[0].CERTIFICATION : ""} isOpen={openTabListPopup} handleCloseManageTabListPopup={handleCloseManageTabListPopup} handleSaveManageTabListPopup={handleSaveManageTabListPopup} STATE={csrHeaderData[0]?.STATE}/> } */}

                {openSupportingInsertPopup && <SupportingInsertPopupData supGridLenght={0} checkedItem={[]} isOpen={openSupportingInsertPopup} onCloseSupportingModelPopup={handleCloseInsSupportingPopup} IsManageSupTab={false} revision={csrHeaderData.length > 0 ? csrHeaderData[0].REVISION : null} configRefSourceId={configRefSourceId} refTableCode={refTableCode} refGridTitle={refGridTitle} sequenceStartWith={getSequence} isOpenedFromDocumentNumber={false} />}
                {openSubstantitionPopup && <SubstantiationInsertPopup isOpen={openSubstantitionPopup} onCloseInsSubStantiationPopup={handleCloseInsSubStantiationPopup} contentOwner={csrHeaderData.length > 0 ? csrHeaderData[0].CONTENT_OWNER : ''} projectId={csrHeaderData.length > 0 ? csrHeaderData[0].PROJECT_ID : ''} revision={csrHeaderData.length > 0 ? csrHeaderData[0].REVISION : null} parentReportId={csrHeaderData.length > 0 ? csrHeaderData[0].PARENT_RPT_ID : null} regTableCode={regTableCode} />}
                {<ReportCompareModal open={openCompareModal} onClose={() => setOpenCompareModal(false)} />}
                {/* {openPdfPreviewPopup && <PdfPreviewPopup isOpen={openPdfPreviewPopup} rptId={reportId} handleClosePdfPreviewPopup={handleClosePdfPreviewPopup} />} */}
              </Box>
            </div>
            {/* {openGlobalFindReplace && <GlobalFindReplaceDialog open={openGlobalFindReplace} onClose={() => setOpenGlobalFindReplace(false)} />} */}
          </div >) : (<div></div>))
      }
    </>
  );
}
export default CSRDetailsBase;
