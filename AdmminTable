<Box
  sx={{
    display: "grid",
    gridTemplateColumns: "2fr 2fr 2fr auto",
    gap: 2,
    alignItems: "end",
    width: "100%",
  }}
>
  {/* CVE Panels */}
  <Box>
    <Box
      sx={{
        display: "flex",
        alignItems: "center",
        gap: 0.5,
        mb: 0.7,
      }}
    >
      <Typography
        variant="subtitle2"
        sx={{
          fontWeight: 600,
          color: "#1f2937",
        }}
      >
        CVE Panels
      </Typography>

      <Tooltip title="Search CVE Panels">
        <InfoOutlinedIcon
          sx={{
            fontSize: 16,
            color: "#6b7280",
            cursor: "pointer",
          }}
        />
      </Tooltip>
    </Box>

    <TextField
      fullWidth
      size="small"
      value={updatedCve
        ?.toSorted((a, b) => a.Cve_Id - b.Cve_Id)
        .map((x) => x.Panel)
        .join(", ")}
      onClick={handleOpenCveDialog}
      InputProps={{
        readOnly: true,
        endAdornment: (
          <InputAdornment position="end">
            <SearchIcon
              sx={{
                fontSize: 18,
                color: "#6b7280",
                cursor: "pointer",
              }}
              onClick={openCveModal}
            />
          </InputAdornment>
        ),
      }}
      sx={{
        "& .MuiOutlinedInput-root": {
          height: 44,
          backgroundColor: "#fff",
        },
      }}
    />
  </Box>

  {/* CDI */}
  <Box>
    <Box
      sx={{
        display: "flex",
        alignItems: "center",
        gap: 0.5,
        mb: 0.7,
      }}
    >
      <Typography
        variant="subtitle2"
        sx={{
          fontWeight: 600,
          color: "#1f2937",
        }}
      >
        CDI
      </Typography>

      <Tooltip title="Search CDI">
        <InfoOutlinedIcon
          sx={{
            fontSize: 16,
            color: "#6b7280",
            cursor: "pointer",
          }}
        />
      </Tooltip>
    </Box>

    <FormControl fullWidth size="small">
      <Select
        multiple
        value={
          editingTask?.cdi
            ?.toSorted((a, b) => a.Cdi_Id - b.Cdi_Id)
            .map((x) => x.Cdi_Id) || []
        }
        onOpen={cdiDropdown}
        onChange={cdihandleChange}
        renderValue={(selected) =>
          (selected as number[])
            .map(
              (id) =>
                editingTask?.cdi.find((m) => m.Cdi_Id === id)
                  ?.Combined_Description ?? ""
            )
            .join(", ")
        }
        sx={{
          height: 44,
          backgroundColor: "#fff",
        }}
      >
        <MenuItem value={SELECT_ALL}>
          <Checkbox
            checked={
              cdi.length > 0 &&
              cdi.every((x) =>
                editingTask?.cdi.some((y) => y.Cdi_Id === x.Cdi_Id)
              )
            }
          />

          <ListItemText primary={SELECT_ALL} />
        </MenuItem>

        {cdi.map((m) => (
          <MenuItem key={m.Cdi_Id} value={m.Cdi_Id}>
            <Checkbox
              checked={editingTask?.cdi.some(
                (s) => s.Cdi_Id === m.Cdi_Id
              )}
            />

            <ListItemText primary={m.Combined_Description} />
          </MenuItem>
        ))}
      </Select>
    </FormControl>
  </Box>

  {/* Regulations */}
  <Box>
    <Box
      sx={{
        display: "flex",
        alignItems: "center",
        gap: 0.5,
        mb: 0.7,
      }}
    >
      <Typography
        variant="subtitle2"
        sx={{
          fontWeight: 600,
          color: "#1f2937",
        }}
      >
        Regulations
      </Typography>

      <Tooltip title="Search Regulations">
        <InfoOutlinedIcon
          sx={{
            fontSize: 16,
            color: "#6b7280",
            cursor: "pointer",
          }}
        />
      </Tooltip>
    </Box>

    <TextField
      fullWidth
      size="small"
      value={editingTask?.regulations
        ?.map((x) => `${x.CS_25_Reg} ${x.Sub_Para ?? ""}`)
        .join(", ")}
      onClick={handleOpenRegDialog}
      InputProps={{
        readOnly: true,
        endAdornment: (
          <InputAdornment position="end">
            <SearchIcon
              sx={{
                fontSize: 18,
                color: "#6b7280",
                cursor: "pointer",
              }}
              onClick={openRegulationModal}
            />
          </InputAdornment>
        ),
      }}
      sx={{
        "& .MuiOutlinedInput-root": {
          height: 44,
          backgroundColor: "#fff",
        },
      }}
    />
  </Box>

  {/* Button */}
  <Box
    sx={{
      display: "flex",
      alignItems: "flex-end",
    }}
  >
    <Button
      variant="outlined"
      onClick={() => editingTask && handleGenerate(editingTask)}
      disabled={markedAsCompleteData.ccl}
      sx={{
        height: 44,
        px: 3,
        textTransform: "none",
        whiteSpace: "nowrap",
        borderColor: "#d1d5db",
        color: "#111827",
        minWidth: "180px",
      }}
    >
      Assign CVE & CDI
    </Button>
  </Box>
</Box>
