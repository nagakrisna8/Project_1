useEffect(() => {
  if (
    getRefDataSource.length > 0 &&
    selectedValue &&
    getPurposeList.length > 0
  ) {
    const idToUse =
      isTemplate === "DQN" &&
      getSelectedSourceName(selectedValue) !== ReferenceDataSourceName.DC
        ? ddtlSearchId
        : searchId;

    if (idToUse !== "") {
      handleSearchTextChange(idToUse, selectedValue);
    }
  }
}, [getRefDataSource, selectedValue, getPurposeList]);
