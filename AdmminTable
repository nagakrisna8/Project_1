    if (getPurposeList.length > 0 && getRowWiseRefData?.Purpose) {
        const matched = getPurposeList.find(
            (item) => item.MasterValue === getRowWiseRefData.Purpose
        );

        setSelectedValue(matched || null);
    }
}, [getPurposeList, getRowWiseRefData]);


