useEffect(() => {
  if (getReasonList.length > 0 && getRowWiseRefData?.ReasonCode) {

    const reasonCodes = getRowWiseRefData.ReasonCode
      .split(",")
      .map(code => code.trim());

    const selected = getReasonList.filter(r =>
      reasonCodes.includes(r.ReasonCode?.trim())
    );

    setSelectedReason(selected);
  }
}, [getReasonList, getRowWiseRefData?.ReasonCode]);
