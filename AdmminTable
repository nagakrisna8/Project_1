const [isFromNavigation, SetIsFromNavigation] = useState(false);
useEffect(() => {
  const storageServ = new StorageService();
  const key = `${EnvDetail.ParentAppName}-${EnvDetail.AppName}`;

  const isNav = storageServ.getApplicationDataByKey(key, "isFromNavigation");

  // ✅ set state
  SetIsFromNavigation(!!isNav);

  // 🔥🔥 CRITICAL FIX → clear after reading
  storageServ.setApplicationDataByKey(key, {
    ...storageServ.getApplicationDataByKey(key),
    isFromNavigation: false
  });

}, []);
