renderTags={(value, getTagProps) =>
    value.map((option, index) => (
        <span
            {...getTagProps({ index })}   // 🔥 IMPORTANT
            style={{
                fontSize: "12px",
                background: "#EFF4FA",
                padding: "2px 6px",
                borderRadius: "4px",
                marginRight: "4px"
            }}
        >
            {option.ReasonCode}
        </span>
    ))
}
