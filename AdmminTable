const handleOrganization = async (event) => {
    const storageService = new StorageService();

    // ✅ Show popup if unsaved changes
    const dirtyResponse = await storageService.getUserConfirmationWithDirtyScreenCheck();
    if (!dirtyResponse) return;

    const orgId = event.target.value;
    setSelectedOrganizationId(orgId);

    fetchFocal(selectedOrgId as number, orgId);

    setDirtyFlag(false); // ✅ reset after switching
};
