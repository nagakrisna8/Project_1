renderTags={(value) => {
  const labels = value.map(v => v.ReasonCode);

  let displayText = "";

  if (labels.length <= 2) {
    displayText = labels.join(", ");
  } else {
    displayText = `${labels[0]}, ${labels[1]} +${labels.length - 2} more`;
  }

  return (
    <span
      style={{
        width: "100%",
        overflow: "hidden"
      }}
      title={labels.join(", ")} // full text on hover
    >
      {displayText}
    </span>
  );
}}
