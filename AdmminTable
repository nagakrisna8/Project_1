        // helper: compute available max and adjust height
        const computeMaxAndAdjust = () => {
            const wrapper = localEditorWrapperRef.current;
            const gridContainer = gridContainerRef.current;
            if (!wrapper || !gridContainer) return;

            const editorTop = wrapper.getBoundingClientRect().top;
            const gridBottom = gridContainer.getBoundingClientRect().bottom;
            const padding = 12;
            const MIN_H = 150;
            const MAX = Math.max(MIN_H, gridBottom - editorTop - padding);

            const contentEl = wrapper.querySelector<HTMLElement>('.k-editor-content');
            const contentRaw = contentEl ? contentEl.scrollHeight : wrapper.scrollHeight;
            const contentHeight = (contentRaw || 0) + 12; // buffer

            const clamped = Math.min(Math.max(MIN_H, contentHeight), MAX);
            const overflowing = contentHeight > MAX;

            setRowMaxEditorHeight(prev => (prev === MAX ? prev : MAX));
            setRowEditorHeight(prev => (prev === clamped ? prev : clamped));
        };

        // effect: observe grid container resizing and scrolling, and window resize
        useEffect(() => {
            let rafId: number | null = null;

            const scheduledCompute = () => {
                if (rafId != null) cancelAnimationFrame(rafId);
                rafId = requestAnimationFrame(() => {
                    computeMaxAndAdjust();
                    rafId = null;
                });
            };

            const compute = () => scheduledCompute();

            // ResizeObserver on grid container (schedules via RAF)
            const ro = new ResizeObserver(() => compute());
            try {
                if (gridContainerRef.current) ro.observe(gridContainerRef.current);
            } catch (err) {
                // fallback to window resize
                window.addEventListener('resize', compute);
            }

            // window resize
            const onWinResize = () => compute();
            window.addEventListener('resize', onWinResize);

            // grid container scroll (vertical) - schedule compute
            const gridEl = gridContainerRef.current;
            const onGridScroll = () => compute();
            if (gridEl) gridEl.addEventListener('scroll', onGridScroll, { passive: true });

            // initial compute
            compute();

            return () => {
                if (rafId != null) cancelAnimationFrame(rafId);
                try { ro.disconnect(); } catch (e) { /* ignore */ }
                window.removeEventListener('resize', onWinResize);
                if (gridEl) gridEl.removeEventListener('scroll', onGridScroll);
            };
