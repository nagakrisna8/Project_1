@mixin line-clamp($lines: 2, $line-height: 1.3) {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: $lines;
  line-clamp: $lines;


  overflow: hidden;
  text-overflow: ellipsis;
  white-space: normal;
  line-height: $line-height;
  max-height: calc(#{$line-height} * #{$lines} * 1em);
  box-sizing: border-box;
  word-break: break-word;
}

.textarea-cell {
  width: 100%;
  box-sizing: border-box;
  resize: none;
  border: 1px solid #cccccc;
  border-radius: 4px;
  padding: 7px 10px;
  height: 32px;
  margin-top: 4px !important;
  cursor: default;


  @include line-clamp(3, 1.3);
}

.textarea-container {
  padding: 0;
  width: 100%;
  height: 62px;
}



