.oss-ccl-highlight, .oss-ccl-highlight td {
  animation: clonedHighlightFade 10s ease forwards;
  box-shadow: inset 0 0 100px 100px oklch(0.7914 0 0);
}

@keyframes clonedHighlightFade {
  0% { box-shadow: inset 0 0 100px 100px oklch(0.7914 0 0); }
  60% { box-shadow: inset 0 0 100px 100px oklch(0.9914 0 0); }
  100% { box-shadow: none; }
}

