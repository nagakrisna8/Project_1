    const pushToCaClick = async () => {
        const storageServiceTemp = new StorageService();
        const projNum = storageServiceTemp.getApplicationDataByKey(`${EnvDetail.ParentAppName}-easaActiveSubMenu`, 'easamyworkspaceprojectid');
        const projId = storageServiceTemp.getApplicationDataByKey(`${EnvDetail.ParentAppName}-easaActiveSubMenu`, 'easaprojectno');
        const bu = storageServiceTemp.getApplicationDataByKey(`${EnvDetail.ParentAppName}-Shell`, 'currentbusinessunit');
        const di = storageServiceTemp.getApplicationDataByKey(`${EnvDetail.ParentAppName}-Shell`, 'currentdiscipline');
        const buid = storageServiceTemp.getApplicationDataByKey(`${EnvDetail.ParentAppName}-Shell`, 'currentbusinessunitid');
        const discid = storageServiceTemp.getApplicationDataByKey(`${EnvDetail.ParentAppName}-Shell`, 'currentdisciplineid');
        const docName = localStorage.getItem(`${EnvDetail.ParentAppName}-CertToolReportId`)!;

        try {
            const saveResp = await saveDataPushCA();
            if (!saveResp) {
                return;
            }
            const currentStatus = await CclBuilderGridService.GetCSRReportStatus(projNum, bu, di);
            const reportStatusDetails: GetCSRReportStatusResponse | null = currentStatus.data;
            if (currentStatus.status == 204) {
                const response = await CclBuilderGridService.PushToCA({
                    Project_Number: projNum,
                    Project_Id: projId,
                    Document_Name: docName,
                    Business_Unit_Name: bu,
                    Discipline_Name: di,
                    Business_Unit_Id: buid,
                    Discipline_Id: discid,
                });
                if (response) {
                    navigateToCSRSearchPage(response.data);
                    dispatch(
                        showSnackbar({
                            snackbarOpen: true,
                            snackbarType: "success",
                            snackbarMessage: "Generated CCL Document successfully",
                        })
                    );
                }
            } else if (reportStatusDetails?.RptStatus == CSRReportStage.CREATE) {
                const confirmation = await userDefinedConfirm({
                    message: "Report already exists, do you want to overwrite the data?",
                    okBtnText: "Confirm",
                    cancelBtnText: "Cancel",
                }).catch(() => { });
                if (confirmation) {
                    const response = await CclBuilderGridService.DeleteAndPushToCA({
                        Project_Number: projNum,
                        Project_Id: projId,
                        Document_Name: docName,
                        Business_Unit_Name: bu,
                        Discipline_Name: di,
                        Business_Unit_Id: buid,
                        Discipline_Id: discid,
                    });
                    if (response) {
                        navigateToCSRSearchPage(response.data);
                        dispatch(
                            showSnackbar({
                                snackbarOpen: true,
                                snackbarType: "success",
                                snackbarMessage: "Updated CCL Document successfully",
                            })
                        );
                    }
                } else {
                    return;
                }
            } else if (reportStatusDetails?.RptStatus == CSRReportStage.EDIT) {
                // create minor revision
                const confirmation = await userDefinedConfirm({
                    message: "Report is being Edited, do you want to create a minor revision?",
                    okBtnText: "Confirm",
                    cancelBtnText: "Cancel",
                }).catch(() => { });
                if (confirmation) {
                    const response = await CclBuilderGridService.CreateCSRMinorRevision(docName, projId, projNum, buid, discid, bu, di);
                    if (response && response.data != 0) {
                        navigateToCSRSearchPage(response.data);
                        dispatch(
                            showSnackbar({
                                snackbarOpen: true,
                                snackbarType: "success",
                                snackbarMessage: "Succesfully created minor revision",
                            })
                        );
                    }
                } else {
                    return;
                }

            } else if (reportStatusDetails?.RptStatus == CSRReportStage.RELEASE) {
                // create revision
                const confirmation = await userDefinedConfirm({
                    message: "Report is released, do you want to create a revision?",
                    okBtnText: "Confirm",
                    cancelBtnText: "Cancel",
                }).catch(() => { });
                if (confirmation) {
                    const response = await CclBuilderGridService.CreateCSRRevision(docName, projId, projNum, buid, discid, bu, di);
                    if (response && response.data != 0) {
                        navigateToCSRSearchPage(response.data);
                        dispatch(
                            showSnackbar({
                                snackbarOpen: true,
                                snackbarType: "success",
                                snackbarMessage: "Succesfully created revision",
                            })
                        );
                    }
                } else {
                    return;
                }
            } else {
                const confirmation = await userDefinedConfirm({
                    editorUnSavedDataCheck: true,
                    message: "Report is already in review",
                    cancelBtnText: "Ok"
                }).catch(() => { });;
                if (confirmation) {

                } else {
                    return;
                }
            }
        } catch (error) {
            dispatch(
                showSnackbar({
                    snackbarOpen: true,
                    snackbarType: "error",
                    snackbarMessage: "Error generating CCL Document",
                })
            );
        }

    };

    const saveDataPushCA = async () => {
        // VALIDATIONS
        let duplicateValidationFlag = false
        cclGridData.forEach((rec, ind) => {
            if (!duplicateValidationFlag) {
                const singleCondition = cclGridData.some((newRec, newIndex) => {
                    const validationFlag = (newRec.Report_Id != rec.Report_Id) &&
                        (rec.Cve_Panel == newRec.Cve_Panel &&
                            rec.Cdi == newRec.Cdi &&
                            rec.Regulation == newRec.Regulation &&
                            rec.Para == newRec.Para &&
                            rec.Amendment == newRec.Amendment &&
                            rec.Moc == newRec.Moc &&
