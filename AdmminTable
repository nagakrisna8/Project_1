    const revisionTitle = revision?.Title?.trim() ?? '';

    const revisionLog = tabList?.find(item => item?.Title?.toUpperCase().trim() === 'REVISION LOG');
    const revisionlogTitle = revisionLog?.Title?.trim() ?? '';

    const signature = tabList?.find(item => item?.Title?.toUpperCase().trim() === 'SIGNATURE');
    const signatureTitle = signature?.Title?.trim() ?? '';

    const general = tabList?.find(item => item?.Title?.toUpperCase().trim() === 'GENERAL');
    const generalTitle = general?.Title?.trim() ?? '';
    let tabIdForData: string = event.itemTarget.props.id.replace('simple-tab-', '');
    let selectedtabTitle: string = event.itemTarget.props.title?.trim();
    const shouldLoad = (titleToMatch: string): boolean =>
      !!(
        titleToMatch &&
        titleToMatch === selectedtabTitle &&
        csrHeaderData?.[0]?.EnvelopeId &&
        isPendingWithUser()
      );
    setIsRevisionTabloaded(shouldLoad(revisionTitle));
    setIsSignatureTabloaded(shouldLoad(signatureTitle));
    setIsRevisionLogTabloaded(shouldLoad(revisionlogTitle));
    setIsGeneralTabloaded(generalTitle == selectedtabTitle ? true : false);

