import * as React from 'react';
import {
  Box,
  Typography,
  Chip,
  Grid as MuiGrid,
  Switch,
  styled,
  FormControlLabel,
} from '@mui/material';
import { Editor, EditorChangeEvent, EditorTools } from '@progress/kendo-react-editor';
import { Grid as DataGrid, GridColumn } from '@progress/kendo-react-grid';
import {
  EditLevelOfInvolmentProps,
  DocumentRow,
  LOIData,
} from './LOITypes';
import { handleDirtyFlag } from '../drawer-home/Drawer';

const {
  Bold,
  Italic,
  Underline,
  AlignLeft,
  AlignCenter,
  AlignRight,
  AlignJustify,
  OrderedList,
  UnorderedList,
  Indent,
  Outdent,
  Superscript,
  Subscript,
  Strikethrough
} = EditorTools;

const toolbarTools = [
  [Bold, Italic, Underline], [Superscript, Subscript], [Strikethrough],
  [AlignLeft, AlignCenter, AlignRight, AlignJustify],
  [OrderedList, UnorderedList],
  [Indent, Outdent],
];

export type EditLOIDetailsRef = {
  save: () => LOIData;
};

const EditLOIDetails = React.forwardRef<EditLOIDetailsRef, EditLevelOfInvolmentProps>(
  (
    {
      LoiData,
      onRiskClassChange,
      riskClassMasterList,
    },
    ref
  ) => {
    const [novel, setNovel] = React.useState(LoiData.Novel === 'Y');
    const [complex, setComplex] = React.useState(LoiData.Complex === 'Y');
    const [critical, setCritical] = React.useState(LoiData.Critical === 'Y');

    const [doaRating, setDOARating] = React.useState(LoiData.DOA_Rating ?? '');

    const [novelText, setNovelText] = React.useState(LoiData.Novelty ?? '');
    const [complexText, setComplexText] = React.useState(LoiData.Complexity ?? '');
    const [criticalText, setCriticalText] = React.useState(LoiData.Criticality ?? '');
    const [complianceText, setComplianceText] = React.useState(LoiData.MOE ?? '');

    const [lOIDocument, setLOIDocuments] = React.useState<DocumentRow[]>(
      LoiData.LOIDocument ?? []
    );

    const matchedRule = React.useMemo(() => {
      return riskClassMasterList.length > 0
        ? riskClassMasterList.find(
          (rule) =>
            rule.Critical === (critical ? 'Y' : 'N') &&
            rule.Novel === (novel ? 'Y' : 'N') &&
            rule.Complex === (complex ? 'Y' : 'N') &&
            rule.DOA_RATING === doaRating
        )
        : null;
    }, [riskClassMasterList, critical, novel, complex, doaRating]);

    React.useEffect(() => {
      if (riskClassMasterList.length > 0) {
        const riskClass = matchedRule?.RISK_CLASS ?? 'Unknown';
        onRiskClassChange(LoiData.LOI_Id, riskClass);
      }
    }, [
      critical,
      novel,
      complex,
      doaRating,
      matchedRule,
      riskClassMasterList,
      LoiData.LOI_Id,
      onRiskClassChange,
    ]);

    const handleLoiChange = (docId: string, checked: boolean) => {
      setLOIDocuments((prev) =>
        prev.map((doc) =>
          doc.DOC_ID === docId
            ? { ...doc, DOC_STATUS: checked ? 'Y' : 'N' }
            : doc
        )
      );
      handleDirtyFlag(true);
    };

    const buildUpdatedData = (): LOIData => {
      return {
        ...LoiData,
        Novel: novel ? 'Y' : 'N',
        Complex: complex ? 'Y' : 'N',
        Critical: critical ? 'Y' : 'N',
        DOA_Rating: doaRating,
        Novelty: novelText,
        Complexity: complexText,
        Criticality: criticalText,
        MOE: complianceText,
        LOIDocument: lOIDocument,
        Risk_Class: matchedRule?.RISK_CLASS ?? LoiData.Risk_Class,
      };
    };

    React.useImperativeHandle(ref, () => ({
      save: () => buildUpdatedData(),
    }));

    const getDoaChipStyles = (doaRating) => {
      if (doaRating === 'High') {
        return {
          bgcolor: '#e8f5e9',
          border: '1px solid #fe0000fe',
          '& .MuiChip-label': {
            color: '#fe0000fe',
            fontWeight: 600,
          },
        };
      }

      if (doaRating === 'Medium') {
        return {
          bgcolor: '#fff3e0',
          border: '1px solid #d3e508',
          '& .MuiChip-label': {
            color: '#d3e508',
            fontWeight: 600,
          },
        };
      }

      return {
        bgcolor: '#ffebee',
        border: '1px solid #4f4d4d',
        '& .MuiChip-label': {
          color: '#121010ab ',
          fontWeight: 600,
        },
      };
    };

    const CustomSwitchHR = styled(Switch)(({ theme }) => ({
      padding: 0,
      width: 44,
      height: 24,
      '& .MuiSwitch-track': {
        borderRadius: 25,
        '&::before, &::after': {
          content: '""',
          position: 'absolute',
          top: '50%',
          transform: 'translateY(-50%)',
          width: 16,
          height: 16
        },
        '&::before': {
          content: '""',
          left: 17,
          color: '#fff',
          top: 22
        },
        '&::after': {
          content: '""',
          right: 22,
          color: '#253746',
          top: 21
        },
      },
      '& .MuiSwitch-thumb': {
        boxShadow: 'none',
        width: 24,
        height: 24,
        border: '1px solid #ccc',
      },
    }));

    return (
      <Box className="involvement-level__edit-container">
        <MuiGrid container spacing={2} className="involvement-level__summary-grid">
          <MuiGrid item xs={12} md={3}>
            <Typography variant="body2" className="involvement-level__field-label">
              Novel
            </Typography>


            <FormControlLabel
              className='toggleCCLProjectSwitch'
              control={<CustomSwitchHR
                name="Togglechecked"
                inputProps={{ 'aria-label': 'Switch A' }}
                checked={novel}
                onChange={(e) => {
                  handleDirtyFlag(true);
                  setNovel(e.target.checked);
                }}
              />}
              label=""
              id="toggle-switch-ccl"
            />
          </MuiGrid>

          <MuiGrid item xs={12} md={3}>
            <Typography variant="body2" className="involvement-level__field-label">
              Critical
            </Typography>
            <FormControlLabel
              className='toggleCCLProjectSwitch'
              control={<CustomSwitchHR
                name="Togglechecked"
                inputProps={{ 'aria-label': 'Switch A' }}
                checked={critical}
                onClick={() => { handleDirtyFlag(true); setCritical((p) => !p); }}
              />}
              label=""
              id="toggle-switch-ccl"
            />
          </MuiGrid>

          <MuiGrid item xs={12} md={3}>
            <Typography variant="body2" className="involvement-level__field-label">
              Complex
            </Typography>
            <FormControlLabel
              className='toggleCCLProjectSwitch'
              control={<CustomSwitchHR
                name="Togglechecked"
                inputProps={{ 'aria-label': 'Switch A' }}
                checked={complex}
                onClick={() => { handleDirtyFlag(true); setComplex((p) => !p); }}
              />}
              label=""
              id="toggle-switch-ccl"
            />
          </MuiGrid>

          <MuiGrid item xs={12} md={3}>
            <Typography variant="body2" className="involvement-level__field-label">
              DOA Rating
            </Typography>
            <Box className="involvement-level__chip-container">
              <Chip
                label={doaRating}
                size="small"
                className="involvement-level__doa-chip"
                variant="outlined"
                sx={{
                  ...getDoaChipStyles(doaRating),
                }}
              />
            </Box>
          </MuiGrid>
        </MuiGrid>

        <Box className="involvement-level__detail-section">
          <Typography variant="body2" className="involvement-level__field-label">
            Novelty
          </Typography>
          <Editor
            tools={toolbarTools}
            value={novelText}
            onChange={(e: EditorChangeEvent) => { handleDirtyFlag(true); setNovelText(e.html); }}
            contentStyle={{ minHeight: '60px', maxHeight: '300px', overflow: 'auto' }}
            defaultEditMode="div"
          />
        </Box>

        <Box className="involvement-level__detail-section">
          <Typography variant="body2" className="involvement-level__field-label">
            Complexity
          </Typography>
          <Editor
            tools={toolbarTools}
            value={complexText}
            onChange={(e: EditorChangeEvent) => { handleDirtyFlag(true); setComplexText(e.html); }}
            contentStyle={{ minHeight: '60px', maxHeight: '300px', overflow: 'auto' }}
            defaultEditMode="div"
          />
        </Box>

        <Box className="involvement-level__detail-section">
          <Typography variant="body2" className="involvement-level__field-label">
            Criticality
          </Typography>
          <Editor
            tools={toolbarTools}
            value={criticalText}
            onChange={(e: EditorChangeEvent) => { handleDirtyFlag(true); setCriticalText(e.html); }}
            contentStyle={{ minHeight: '60px', maxHeight: '300px', overflow: 'auto' }}
            defaultEditMode="div"
          />
        </Box>

        <Box className="involvement-level__detail-section">
          <Typography variant="body2" className="involvement-level__field-label">
            Planned Means of Compliance
          </Typography>
          <Typography variant="body2" className="involvement-level__detail-text">
            {complianceText}
          </Typography>
        </Box>

        <Box className="involvement-level__detail-section">
          <Typography
            variant="body2"
            className="involvement-level__field-label involvement-level__field-label--documents"
          >
            Documents (from Compliance Shown In)
          </Typography>

          <div style={{ width: '100%', overflow: 'hidden' }}>
            <DataGrid
              data={lOIDocument}
              dataItemKey="DOC_ID"
              rowHeight={30}
              className="involvement-level__documents-grid"
            >
              <GridColumn
                field="DOC_ID"
                title="Doc ID / Test Activity"
                width="220px"
                cell={(props) => (
                  <td className="involvement-level__documents-grid-cell" title={props.dataItem.DOC_ID}>
                    {props.dataItem.DOC_ID}
                  </td>
                )}
              />

              <GridColumn
                field="title"
                title="Title"
                width="320px"
                cell={(props) => (
                  <td className="involvement-level__documents-grid-cell" title={props.dataItem.title}>
                    {props.dataItem.title}
                  </td>
                )}
              />

              <GridColumn
                field="DOC_STATUS"
                title="LOI [Y/N]"
                width="120px"
                cell={(props) => {
                  const checked = props.dataItem.DOC_STATUS === 'Y';

                  return (
                    <td className="involvement-level__documents-grid-cell">
                      <FormControlLabel
                        className='toggleCCLProjectSwitch'
                        control={<CustomSwitchHR
                          name="Togglechecked"
                          inputProps={{ 'aria-label': 'Switch A' }}
                          checked={checked}
                          onClick={() =>
                            handleLoiChange(props.dataItem.DOC_ID, !checked)
                          }
                        />}
                        label=""
                        id="toggle-switch-ccl"
                      />
                    </td>
                  );
                }}
              />
            </DataGrid>
          </div>
        </Box>
      </Box>
    );
  }
);

export default EditLOIDetails;
