function highlightAndCombine(dataSource) {
    var components = dataSource.split(",");
    var highlightedComponents = components.map(function (component) {
        var span = document.createElement('span');
        var textNode = document.createTextNode(component);
        var container = document.createElement('span');
        container.classList.add('highlight');
        container.appendChild(textNode);
        return container.outerHTML;
    });
    return highlightedComponents.join(" ");
}

function bindAttributeDrpDown(data) {

    let selectedBusinessUnit = storageService.getApplicationDataByKey(fullShellAppName, 'CurrentBusinessUnit');
    let selectedDiscipline = storageService.getApplicationDataByKey(fullShellAppName, 'CurrentDiscipline');
    var attributesList = data.AttributeDetails;
    if (selectedBusinessUnit === "BGS Mods EASA") { //for EASA search 
        attributesList = data.AttributeDetails.filter(attr => attr.IsEasaAttr == 'Y');
    }
    else {
        attributesList = data.AttributeDetails.filter(attr => attr.IsEasaAttr == 'N');
    }

    var staticItem = $('<li>').addClass("custom-li static-child").text("Search for");
    $('#oss-shell-search-dropdwn').append(staticItem);
    $.each(attributesList, function (index, item) {
        var optionValue = $('<li>').addClass("custom-li").val(item.AttributeId).attr('name', item.AttributeName).attr('IsEasa', item.IsEasaAttr);
        var spanElement = document.createElement('span');
        if (item.DataSource === "WF") {
            spanElement.textContent = item.AttributeTitle
        }
        else {
        spanElement.textContent = item.AttributeTitle + " in ";
        spanElement.innerHTML += highlightAndCombine(item.DataSource);
        }
        spanElement.classList.add('outer-span');
        optionValue.append(spanElement);
        $('#oss-shell-search-dropdwn').append(optionValue);

        //setting default first drpdwn value 
        if (index == 0) {
            var spanElement = document.createElement('span');
            if (item.DataSource === "WF") {
                spanElement.textContent = item.AttributeTitle
            }
            else {
            spanElement.textContent = item.AttributeTitle + " in ";
            spanElement.innerHTML += highlightAndCombine(item.DataSource);
            }
            var tempDiv = $('<div>').append(spanElement.innerHTML);
            var mainText = '';
            var firstHighlightText = '';
            var highlightCount = 0;
            tempDiv.contents().each(function () {
                if (this.nodeType === Node.TEXT_NODE) {
                    mainText += this.nodeValue.trim() + ' ';
                } else if (this.nodeType === Node.ELEMENT_NODE && $(this).hasClass('highlight')) {
                    if (highlightCount === 0) {
                        firstHighlightText = $(this).text();
                    }
                    highlightCount++;
                }
            });
            var outputText = `${mainText.trim()} ${firstHighlightText}`;
            if (highlightCount > 1) {
                outputText += `+${highlightCount - 1}`;
            }
            document.getElementById("oss-shell-search-option").innerHTML = outputText;
            topSearchData.AttributeTitle = item.AttributeTitle;
            topSearchData.AttributeName = item.AttributeName;
            topSearchData.IsEasa = item.IsEasaAttr == 'Y' ? true : false;
        }
    });
}

function getSelectedDisciplineId(businessUnitDisciplineData, selectedBusinessUnit, selectedDiscipline) {
    let selectedDisciplineId = 0;

    for (let index = 0; index < businessUnitDisciplineData.length; index++) {
        const element = businessUnitDisciplineData[index];

        if (element?.BusinessUnitName?.toLowerCase() == selectedBusinessUnit?.toLowerCase()) {
            for (let j = 0; j < element?.DisciplineList.length; j++) {
                const tempElement = element?.DisciplineList[j];
                if (tempElement.DisciplineName?.toLowerCase() == selectedDiscipline?.toLowerCase()) {
                    selectedDisciplineId = tempElement.BusinessUnitId + "-" + tempElement.DisciplineId;
                    break;
                }
            }
        }
    }
    return selectedDisciplineId;
}

