    $("#oss-shell-search-dropdwn").on("click", "li", function (e) {
        e.preventDefault();
        var res = $(this).html();
        var outerSpan = $(this).find('.outer-span');
        var selectedValue = outerSpan.length > 0 ? outerSpan.html() : $(this).html();
        var tempDiv = $('<div>').html(selectedValue);
        var mainText = '';
        var firstHighlightText = '';
        var highlightCount = 0;
        tempDiv.contents().each(function () {
            if (this.nodeType === Node.TEXT_NODE) {
                mainText += this.nodeValue.trim() + ' ';
            } else if (this.nodeType === Node.ELEMENT_NODE && $(this).hasClass('highlight')) {
                if (highlightCount === 0) {
                    firstHighlightText = $(this).text();
                }
                highlightCount++;
            }
        });
        var outputText = `${mainText.trim()} ${firstHighlightText}`;
        if (highlightCount > 1) {
            outputText += `+${highlightCount - 1}`;
        }

        document.getElementById("oss-shell-search-option").innerHTML = outputText;
        topSearchData.AttributeTitle = selectedValue;
        topSearchData.AttributeName = $(this).attr('name');
        topSearchData.IsEasa = $(this).attr('IsEasa') == 'Y' ? true : false;
    });

