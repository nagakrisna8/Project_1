//Function to Delete User Favourite
function DeleteUserFavourite(ossShellToken, fav_id) {
    $.ajax({
        url: `${process.env.REACT_APP_ROOT_BASE_API_URL}ossshell/DeleteUserFavourite?fav_id=${fav_id}`,
        headers: { "Authorization": `Bearer ${ossShellToken}` },
        data: { fav_id: fav_id },  // send as an object
        method: 'DELETE',
        success: function (result) {
            if (result) {
                // Remove from DOM after successful delete
                const projectToDeleteElem = document.getElementById('projectToDelete');
                if (currentProjectElement) {
                    currentProjectElement.remove();
                    // Optionally remove from projects array if you want to keep data in sync
                    if (projectToDeleteElem) {
                        const projectText = projectToDeleteElem.textContent;
                        const index = projects.findIndex(p => `${p.label} ${p.id}` === projectText);
                        if (index !== -1) {
                            projects.splice(index, 1);
                        }
                    }
                    $('#deleteConfirmModal').modal('hide');

                    $('#deleteConfirmModal').on('hidden.bs.modal', function onHidden() {
                        showSnackbar("Deleted Successfully.", "success");
                        $('#deleteConfirmModal').off('hidden.bs.modal', onHidden);
                        refreshUserFavourites(ossShellToken);
                    });
                    currentProjectElement = null;
                }
            }
        },
        error: function (error) {
            WorkAppRequest.shellActiveApiCall = WorkAppRequest.shellActiveApiCall - 1;
            $('#deleteConfirmModal').modal('hide');
            $('#deleteConfirmModal').on('hidden.bs.modal', function onHidden() {
                showSnackbar(error.responseText, "error");
                $('#deleteConfirmModal').off('hidden.bs.modal', onHidden);
            });
        }
    });
}

