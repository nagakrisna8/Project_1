const taskdropdownlist = (props: GridCellProps) => {
    const canonicalField = props.field ?? "Task";
    const matchedTasks = task ?? [];

    const initialValue =
        props.dataItem[canonicalField] ??
        props.dataItem["TaskId"] ??
        props.dataItem["Task"] ??
        [];

    // FIXED NORMALIZATION
    const normalizedTasks = Array.isArray(initialValue)
        ? initialValue
              .map((x) => Number(x))
              .filter((x) => !isNaN(x) && x > 0)
        : String(initialValue ?? "")
              .split(",")
              .map((x) => x.trim())
              .filter((x) => x !== "")
              .map((x) => Number(x))
              .filter((x) => !isNaN(x) && x > 0);

    const [selectedTasks, setSelectedTasks] =
        useState<number[]>(normalizedTasks);

    const selectedTaskNames = selectedTasks
        .map((id) => {
            const found = matchedTasks.find(
                (t) => Number(t.TaskId) === Number(id)
            );

            return found ? found.TaskName : id;
        })
        .join(", ");

    const handleChange = (e: SelectChangeEvent<any>) => {
        const value =
            typeof e.target.value === "string"
                ? e.target.value
                      .split(",")
                      .map((x) => Number(x))
                : (e.target.value as number[]);

        setSelectedTasks(value);

        // store TaskId values
        props.dataItem["TaskId"] = value.join(",");

        // optional if needed elsewhere
        props.dataItem[canonicalField] = value.join(",");

        _handleDirtyFlag(true);
    };

    return (
        <td title={selectedTaskNames}>
            <FormControl fullWidth size="small">
                <Select
                    multiple
                    value={selectedTasks}
                    onChange={handleChange}
                    disabled={allControlEnable}
                    className="task-dropdownlist"
                    MenuProps={{
                        keepMounted: true,
                        disableAutoFocusItem: true,
                    }}
                    renderValue={(selected) =>
                        (selected as number[])
                            .map((id) => {
                                const found = matchedTasks.find(
                                    (t) =>
                                        Number(t.TaskId) === Number(id)
                                );

                                return found
                                    ? found.TaskName
                                    : id;
                            })
                            .join(", ")
                    }
                >
                    {matchedTasks.map((t) => (
                        <MenuItem
                            key={t.TaskId}
                            value={Number(t.TaskId)}
                        >
                            <Checkbox
                                checked={selectedTasks.includes(
                                    Number(t.TaskId)
                                )}
                            />

                            <ListItemText
                                primary={t.TaskName}
                            />
                        </MenuItem>
                    ))}
                </Select>
            </FormControl>
        </td>
    );
};
