let isDuplicate = false;
const isNewRecord = (focalData as any)?.newFlag;

if (formData.email && formData.email.trim() !== "") {
    isDuplicate = focalList?.some((item: FocalData) => {
        const sameEmail =
            (item.EMAIL ?? "").trim().toLowerCase() === formData.email.trim().toLowerCase();

        return isNewRecord
            ? sameEmail
            : sameEmail && item.ID !== formData.id;
    });
} else {
    isDuplicate = focalList?.some((item: FocalData) => {
        const sameName =
            (item.NAME ?? "").trim().toLowerCase() === formData.name.trim().toLowerCase();

        return isNewRecord
            ? sameName
            : sameName && item.ID !== formData.id;
    });
}
