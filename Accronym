      new Plugin({
        appendTransaction: (transactions, oldState, newState) => {
          // run only if doc changed
          if (!transactions.some((tr) => tr.docChanged)) return;
          const { selection } = newState;
          const $from = selection.$from;
          // walk up the selection to find the nearest "table" node
          for (let depth = $from.depth; depth > 0; depth--) {
            const node = $from.node(depth);
            if (node.type.name === "table") {
              const pos = $from.before(depth);
              const attrs: any = node.attrs || {};
              const style: string = (attrs.style || "").trim();
              // If width is already set, don't touch it prevents infinite loops & respects user edits
              if (/(^|;)\s*width\s*:/i.test(style)) return;
              const nextStyle = [
                style.replace(/;\s*$/, ""), // remove trailing ;
                `width: ${widthPx}px`,
                `max-width: 100%`
              ]
                .filter(Boolean)
                .join("; ");
              const tr = newState.tr;
              tr.setNodeMarkup(pos, undefined, { ...attrs, style: nextStyle });
              return tr;
            }
          }
          return;
        }
