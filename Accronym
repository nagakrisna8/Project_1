const handleOrg = async (event) => {
    const storageService = new StorageService();

    // ✅ Show popup if unsaved changes
    const dirtyResponse = await storageService.getUserConfirmationWithDirtyScreenCheck();
    if (!dirtyResponse) return;

    const orgTypeId = event.target.value;
    setSelectedOrgId(orgTypeId);
    setSelectedOrganizationId("");

    try {
        const response = await EasaListService.getAdminMasterDetailsOrgType(1, orgTypeId);

        let result: OrganizationTableData[] = response?.data.map(org => ({
            ORGANIZATIONID: org.ORGANIZATIONID,
            ORGANIZATIONNAME: org.ORGANIZATIONNAME,
            ORGANIZATIONDESCRIPTION: org.ORGANIZATIONDESCRIPTION,
            NOTES: org.NOTES,
            SORT_ORDER: org.SORT_ORDER,
            ISACTIVE: org.ISACTIVE === "Y"
        }));

        const finalResult = [...result];

        setOrganizationData(finalResult);
        setOriginalOrganizationData(finalResult);

        if (finalResult.length > 0) {
            setSelectedOrganizationId(finalResult[0].ORGANIZATIONID);
        } else {
            setSelectedOrganizationId("");
            setFocalData([]);
            setOriginalFocalData([]);
        }

        setDirtyFlag(false); // ✅ reset after switching
    } catch (err) {
        console.error(err);
    }
};
