const handleCancel = async () => {
    const storageService = new StorageService();

    // ✅ Show popup only if unsaved changes exist
    const dirtyResponse = await storageService.getUserConfirmationWithDirtyScreenCheck();
    if (!dirtyResponse) return; // ❌ User clicked NO → do nothing

    clearFormData?.();
    setDirtyFlag?.(false);

    if (debounceTimer.current) clearTimeout(debounceTimer.current);

    if ((focalData as any)?.newFlag) {
        setFormData({
            id: 0,
            name: "",
            address: "",
            phone: "",
            email: "",
            position: "",
            title: "",
            isActive: false,
            isBemsRecord: false
        });
    } else {
        setFormData({
            id: focalData?.ID ?? 0,
            name: focalData?.NAME ?? "",
            address: focalData?.ADDRESS ?? "",
            phone: String(focalData?.PHONE ?? ""),
            email: focalData?.EMAIL ?? "",
            position: focalData?.DEPARTMENT ?? "",
            title: focalData?.TITLE ?? "",
            isActive: focalData?.ISACTIVE ?? false,
            isBemsRecord: formData.isBemsRecord ?? false
        });
    }

    // ✅ Row will disappear ONLY after confirmation
    if (cancelFocal && focalData?.ID !== undefined) {
        cancelFocal(focalData.ID);
    }
};
