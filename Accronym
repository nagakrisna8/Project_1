function fetchNotifications(ossShellToken, notificationId) {
    WorkAppRequest.shellActiveApiCall = WorkAppRequest.shellActiveApiCall + 1;
    let workApp = "";
    if (window.location.pathname.endsWith(`/${process.env.REACT_APP_SUB_PATH}`) || window.location.pathname.endsWith(`/${process.env.REACT_APP_SUB_PATH}/`)
        || window.location.pathname == '/') {
        workApp = "Home Page";
        currentWorkApp = workApp;
        prevWorkApp = workApp;
    }
    else {
        workApp = helpGuideService.getWorkAppForRoute(window.location.href);
        workApp = workApp.replaceAll('_', ' ');

        if (workApp === "") {
            workApp = "Home Page"
        }
        currentWorkApp = workApp;
        prevWorkApp = workApp;
    }
    $.ajax({
        url: `${process.env.REACT_APP_ROOT_BASE_API_URL}` + 'ossshell/GetNotificationDataForBell?workAppName=' + workApp + '&notificationId=' + notificationId,
        headers: { "Authorization": `Bearer ${ossShellToken}` },
        method: 'GET',
        dataType: 'json',
        async: false,
        success: function (response) {
            WorkAppRequest.shellActiveApiCall = WorkAppRequest.shellActiveApiCall - 1;
            const notificationList = $('#oss-home-notificationList');

            if (notificationId == 0) {
                notificationList.empty();
            }
            const notificationsToDisplay = response;
            if (notificationsToDisplay.length > 0) {
                notificationsToDisplay.forEach(notification => {
                    //Notification Content
                    $("#oss-home-NotificationContent").text(notification.Content);
                    if (notificationId == 0) {
                        notificationList.append('<li id=' + notification.Nid + '-&-' + notification.NOTIFICATION_READ + ' class=' + notification.CreatedDate + '><a  style="color: #0078B8;">' + notification.TITLE + '</a></li>');
                    }
                });
            } else {
                notificationList.append('<li style="pointer-events: none; cursor:none">No new notifications</li>');
            }
        },
        error: function () {
            WorkAppRequest.shellActiveApiCall = WorkAppRequest.shellActiveApiCall - 1;
        }
    });
}
