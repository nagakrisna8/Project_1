  const checkIsAuthorReport = () => {
    if ((headerData?.AuthorBemsId == parseInt(userBemsId)) && headerData?.WorkFlowStep == ReportStepId.CREATE_STEP) {
      return true;
    }
  };

  const sanitizeClassAttr = (attr: Attr) => {
    const element = attr.ownerElement;
    if (element && element.tagName.toLowerCase() === 'span' && element.classList.contains('uneditable')) {
      return;
    }
    element?.removeAttribute(attr.name);
  };

  const checkIsNonoEditableSpan = (attr: Attr) => {
    const el = attr.ownerElement;
    return el && el.tagName.toLowerCase() === 'span' && el.classList.contains('uneditable');
  };

  const commonAttrRemovedFunction = (attr: Attr) => {
    if (attr && !checkIsNonoEditableSpan(attr)) {
      const element = attr.ownerElement;
      if (!element) return;
      element.removeAttribute(attr.name);
    }
  };

  const pasteSettings: PasteCleanupSettings = {
    convertMsLists: true,
    // stripTags: 'span|font'
    attributes: {
      class: sanitizeClassAttr,
      style: sanitizeStyleAttr,
      // keep `width`, `height` and `src` and other attributes
      width: () => { },
      height: () => { },
      src: () => { },
      tagid: (attr: Attr) => { commonAttrRemovedFunction(attr) },
      name: (attr: Attr) => { commonAttrRemovedFunction(attr) },
      tagcolor: (attr: Attr) => { commonAttrRemovedFunction(attr) },
      contenteditable: (attr: Attr) => { commonAttrRemovedFunction(attr) },
      // Removes `lang` attribute
      // lang: removeAttribute,
      // removes other (unspecified above) attributes
      '*': removeAttribute
    }
  };

  const copiedFromExcel = (html) => {
    return /<meta (?:name=Generator )?content="Microsoft Excel \d+/.test(html);
  };

  const cleanExcelContent = (html) => {
    const template = document.createElement('template');
    template.innerHTML = html;
    const fragment = template.content;
    const table: any = Array.from(fragment.childNodes).find(
      (n) => n.nodeName === 'TABLE'
    );
    const style: any = Array.from(fragment.childNodes).find(
      (n) => n.nodeName === 'STYLE'
    );
    if (table && style) {
      const strStyles = style.innerHTML;
      Array.from(table.rows).forEach((row: any) => {
        Array.from(row.cells).forEach((cell: any) => {
          const styleMatch =
            cell.className &&
            strStyles.match(
              new RegExp('.' + cell.className + '\\s*{(' + '[^}]+)}')
            );
          if (styleMatch) {
            cell.className = '';
            styleMatch[1]
              .replace(new RegExp(';\\s+', 'g'), ';')
              .split(';')
              .filter(Boolean)
              .forEach((st) => {
                const [style, value] = st.split(':');
                if (typeof cell.style[style] !== 'undefined') {
                  cell.style[style] = value.replace('windowtext', 'black');
                }
              });
          }
        });
      });
      return table.outerHTML;
    }
    return html;
  };

  const onPasteContent = useCallback((event: EditorPasteEvent) => {
    const pastedData = event.pastedHtml;
    // Parse the HTML string into a document
    let parser = new DOMParser();
    let doc = parser.parseFromString(pastedData, 'text/html');
    // For Excel content
    if (pastedData && copiedFromExcel(pastedData)) {
      return cleanExcelContent(pastedData);
    }
    // For Word Content
    if (pastedData && pastedData.indexOf("Word.Document") > -1) {
      let html = pasteCleanup(sanitize(event.pastedHtml), pasteSettings);
      // let html = pastedData;
      if (event.nativeEvent.clipboardData) {
        html = replaceImageSourcesFromRtf(html, event.nativeEvent.clipboardData);
      }
      // check for table present in copy content
      // if(doc.querySelectorAll('table').length > 0){
      //   return html;
      // }
      return html;
    }

    // For other pasted content
    if (pastedData && (pastedData.indexOf(BookMarkType.LINKCLASS) > -1 ||
      pastedData.indexOf(BookMarkType.BOOKMARKCLASS) > -1 || pastedData.indexOf("uneditable") > -1)) {
      let html = pasteCleanup(sanitize(event.pastedHtml), pasteSettings);
      if (event.nativeEvent.clipboardData) {
        html = replaceImageSourcesFromRtf(html, event.nativeEvent.clipboardData);
      }
      return html;
    } else if (doc.querySelectorAll('span').length > 0) {
      let spanTagList = doc.querySelectorAll('span');
      if (spanTagList.length > 0) {
        let html = pasteCleanup(sanitize(event.pastedHtml), pasteSettings);
        if (event.nativeEvent.clipboardData) {
          html = replaceImageSourcesFromRtf(html, event.nativeEvent.clipboardData);
        }
        return html;
      }
    }
    return pastedData;
  }, []);

  const memoOnEditorChange = useCallback((event: EditorChangeEvent) => {
    onEditorChange && onEditorChange(event as EditorChangeEvent, item as any, contentKey as string);
    setValue(event.html);
  }, [onEditorChange, item, contentKey]);

  const contentKeyRef = useRef(0);
  const prevContentRef = useRef(content);
  if (prevContentRef.current !== content) {
    prevContentRef.current = content;
    contentKeyRef.current += 1;
  }

  const memoizedEditor = useMemo(() => {
    return (
      <>
        <Editor
          key={`${contentKeyRef.current}-${editorRefreshKey}`}
          defaultEditMode="div"
          className="ai-custom-editor"
          style={{
            maxWidth: dynamicScreenSize.maxWidth,
            minWidth: IsNonDynamicTab ? "200px" : dynamicScreenSize.minWidth,
            borderRadius: "4px",
            border: "none",
          }}
          ref={editorViewRef}
          onPasteHtml={onPasteContent}
          // tools={stableToolbar}
          tools={getToolbarDetail()}
          contentStyle={{ minHeight: CompGridDetails ? '100px' : 'auto' }}
          defaultContent={content}
          onChange={memoOnEditorChange}
          onMount={onEditorMount}
          onFocus={handleOnFocus}
          onBlur={handleOnBlur}
        />
      </>
    );
  }, [content, editorRefreshKey]);

  const verticalLine = useCallback((): JSX.Element | null => {
    const lineWidth = landScapeFlag ? A4Dimensions.landscape.width : A4Dimensions.portrait.width;
    const editorElement = document.querySelector('.ai-custom-editor');
    let editorWidth: number | undefined;
    if (editorElement instanceof HTMLElement) {
      editorWidth = editorElement.offsetWidth;
    }
    if (editorWidth && lineWidth < editorWidth) {
      // Skip for Figure Title
      if (item && item.IsFigure === 'N') {
        if (item.IsTable === 'Y') {
          return enableDottedLine();
        }
        if (easaReportFlag) {
          return enableDottedLine();
        }
      }
    }
    return null;
  }, [landScapeFlag, A4Dimensions]);

  return (
    <>
      <div style={{
        position: "relative",
        width: "100%",
      }}>
        {verticalLine()}
        {memoizedEditor}
      </div>
      {/* {showFindReplaceDialog && editorViewRef.current && editorViewRef.current.view &&
        React.createElement(
          EditorDialogs.FindAndReplaceDialog as unknown as React.ComponentType<any>,
          { view, onClose: onFindClose })} */}
      {openAddAcronymPopup && <AddAcronymPopup isOpen={openAddAcronymPopup} reportId={reportId} selectedText={selectedText} handleCloseAcronymPopup={handleCloseAcronymPopup} />}
      {openContentCommentPopup && <ContentCommentPopup handleCheckbox={handleCheckbox} RptId={reportId} headerData={headerData} handleOpenCommentHistoryPopup={handleOpenCommentHistoryPopup} openContentCommentPopup={openContentCommentPopup} handleCloseContentCommentPopup={handleCloseContentCommentPopup} contentCommentData={contentCommentData} position={position} />}
      {openCommentHistoryPopup && <CommentHistoryPopup isControlLevelComment={false} tabName={tabName} controlName={controlName} selectedTabRowId={selectedTabRowId} selectedRowId={selectedRowId} editFileCount={editFileCount} IsNonDynamicTab={IsNonDynamicTab} IsBadgeIconClick={IsBadgeIconClick} addNewComment={addNewComment} updateAddNewComment={updateAddNewComment} CompGridDetails={getCompGridDetails} contentID={contentID} openHistoryPopup={openHistoryPopup} handleCloseHistoryPopup={handleCloseHistoryPopup} RptId={reportId} item={item} TabSectionId={item?.TabSectionId} headerData={headerData} getFormatedHtmlData={GetUpdatedHtmlWithCommentId(true)} getFormatedEditorHtml={GetUpdatedHtmlWithCommentId(false)}
        showEditModeForCommentID={showEditModeForCommentID} comment={comment} commetType={commetType} SectionSerialNumber={SectionSerialNumber} seletedTargetText={seletedTargetText} addCommentAsAuthor={addCommentAsAuthor} currentContentID={currentContentID} openCommentHistoryPopup={openCommentHistoryPopup} handleCloseCommentHistoryPopup={handleCloseCommentHistoryPopup} currentTabComments={currentTabComments} showReplyCommentId={showReplyCommentId} />}
      {openAddRevisionPopup && <AddRevisionPopup openRevisionPopup={openAddRevisionPopup} reportId={reportId} selectedText={selectedText} handleCloseRevisionPopup={handleCloseRevisionPopup} tabId={tabIndex} TabSectionId={item?.TabSectionId} ContentID={item?.ContentId} secIndex={SectionSerialNumber} item={item} sectionTitle={sectionTitle} tableCode={tableCode} />}
      {openAddMentionPopup && <AddMentionPopup openMentionPopup={openAddMentionPopup} handleCloseMentionPopup={handleCloseMentionPopup} />}
      {openMentionPopup && <MentionPopup RptId={reportId} headerData={headerData} openMentionOnPopup={openMentionPopup} handleCloseMentionOnPopup={handleCloseMentionOnPopup} position={position} mentionData={getMentionData} />}
      {openBookmarkPopup && <AddBookMarkPopup isOpen={openBookmarkPopup} handleCloseBookmarkPopup={handleCloseBookmarkPopup} handleAddBookMark={handleAddBookMark} />}
      {openInsertLinkPopup && <InsertBookmarkLinkPopup isOpen={openInsertLinkPopup} handleCloseInsertLinkPopup={handleCloseInsertLinkPopup} handleInsertBookmarkLink={handleInsertBookmarkLink} contentId={item?.ContentId} getTargetHtmlText={getHtml()} saveTabDetails={saveTabDetails} IsNonDynamicTab={IsNonDynamicTab} />}
      {(ShowPrompt && checkIsAuthorReport()) && (
        <InlineAIPromptWrapper
          width={544}
          streaming={Streaming}
          enableSpeechToText={true}
          outputs={Outputs}
          anchor={AnchorEl}
          commands={Commands}
          onCommandExecute={onCommandExecute}
          onPromptRequest={onPromptRequest}
          onPromptCancel={onPromptCancel}
          outputActions={outputActions}
          onOutputAction={onOutputAction}
          onDiscard={(o) => setOutputs((prev) => prev.filter((x) => x.id !== o.id))}
          show={ShowPrompt}
          promptRoot={promptRoot}
        />
      )}
    </>
  );
}

const areEqual = (prev: KendoEditorProps, next: KendoEditorProps) => {
  if (prev.content !== next.content) return false; //=> render
  if (prev.currentTabComments !== next.currentTabComments) return false; //=> render to update ref
  return true; //=> skip render
}

export default React.memo(KendoEditor, areEqual);
