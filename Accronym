import React, { useEffect, useState } from 'react';
import { Grid as DataGrid, GridCellProps, GridColumn, GridColumnMenuFilter, GridToolbar, GridColumnMenuSort, GridCustomHeaderCellProps, GridDataStateChangeEvent, GridDetailRowProps, GridEvent, GridItemChangeEvent, GridPageChangeEvent, isColumnMenuFilterActive, isColumnMenuSortActive } from "@progress/kendo-react-grid";
import { filterIcon } from "@progress/kendo-svg-icons";
import { CSRReportStage, GetCRIMappingResponse, GetCSRReportStatusResponse } from '../../../model/Model';
import './CRIMappingGrid.scss';
import { logFilterAction } from '@boeing-fsit/react-oss-adobe-analytics-lib';
import { process, State } from '@progress/kendo-data-query';
import StorageService from "../../../utils/StorageService";
import EnvDetail from '../../../utils/EnvDetail';
import { SaveCRIMappingPayload } from "../../../model/Model";
import CclBuilderGridService from "../project-grid/CclBuilderGridService";
import { showSnackbar } from "../../core/snackbar/CustomSnackBarSlice";
import { useDispatch } from "react-redux";
import { Button } from "@mui/material";
import HeaderDetails from '../header-details/HeaderDetails';
import { CCLTEMPLATEID, CCLTEMPLATENAME, MarkAsCompleteButton, navigateToCSRReportIDPage } from '../overview-home/Overview';
import { useOutletContext } from 'react-router-dom';
import { OverallDataContext } from '../overview-home/Overview';
import MainDrawerService from '../drawer-home/MainDrawerService';
import { userDefinedConfirm } from '../utils/ConfirmDialog';


// interface CRIMappingGridProps {
