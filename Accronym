 if (currentGroupBU === GroupBU.EASA) {
                setMenuSectionVisibility(false);
                EASAMenuSubmenu.setMenuSectionVisibility(true);

                const storageServiceTemp = new StorageService();

                const isFromNavigation = storageServiceTemp.getApplicationDataByKey(
                    `${process.env.REACT_APP_ROOT_NAME}-${process.env.REACT_APP_FIND_CSR}`,
                    "isfromnavigation"
                );

                let originalTitle = storageServiceTemp.getApplicationDataByKey(
                    `${process.env.REACT_APP_ROOT_NAME}-easaActiveSubMenu`,
                    'easaActiveSubMenuTitle'
                );

                const isFromCertStrategy =
                    (isFromNavigation && originalTitle && originalTitle === "Airworthiness");

                const currentProject = storageServiceTemp.getApplicationDataByKey(
                    `${process.env.REACT_APP_ROOT_NAME}-easaActiveSubMenu`,
                    'currentProjectBreadcrumbs'
                );

                const currentActiveDesignDocTab = storageServiceTemp.getApplicationDataByKey(
                    `${process.env.REACT_APP_ROOT_NAME}-easaActiveSubMenu`,
                    'easaActiveSubMenu'
                );

                $('#oss-menu-breadcrums').html('');

                // Home
                $('#oss-menu-breadcrums')
                    .append($('<a>')
                        .text('Home')
                        .attr("id", "idhomeBreadcurm")
                        .addClass("homeBreadcurm")
                        .click(() => handleHomeBreadcrumsClick(event))
                    )
                    .append($('<div>').addClass("gg-chevron-right"))

                    // Workspace
                    .append($('<div>')
                        .addClass("breadcrumsStyles")
                        .text('EASA My Workspace')
                        .click(() =>
                            singleSpa.navigateToUrl(
                                WorkAppRoutes.PMDB_ProjectRegister.APP_ROOT + "/#" +
                                WorkAppRoutes.PMDB_ProjectRegister.EASA_WORKSPACE_HOME
                            )
                        )
                    )
                    .append($('<div>').addClass("gg-chevron-right"))

                    // Project
                    .append($('<div>')
                        .addClass("breadcrumsStyles")
                        .text(currentProject)
                        .click(() => {
                            EASAMenuSubmenu.handleSubMenuButtonClick("projectdetailsbttn");
                        })
                    )
                    .append($('<div>').addClass("gg-chevron-right"));

                if (isFromCertStrategy) {
                    $('#oss-menu-breadcrums')
                        .append($('<div>')
                            .addClass("breadcrumsStyles")
                            .text("Cert Strategy")
                            .click(() => {
                                EASAMenuSubmenu.handleSubMenuButtonClick("cclbuilderbttn");
                            })
                        )
                        .append($('<div>').addClass("gg-chevron-right"));
                }

                $('#oss-menu-breadcrums')
                    .append($('<div>')
                        .addClass("breadcrumsStyles")
                        .text(originalTitle)
                        .attr("id", "oss-csrsearch-breadcrums")
                        .click(() => {
                            EASAMenuSubmenu.handleSubMenuButtonClick(currentActiveDesignDocTab);
                        })
                    )
                    .append($('<div>').addClass("gg-chevron-right"));

                // Document Number
                $('#oss-menu-breadcrums')
                    .append($('<div>')
                        .addClass("breadcrumsStyles")
                        .text(`Document Number: ${docNumber ? docNumber : ''}`)
                        .attr("id", "oss-csr-docnumber")
                        .click(() => {
                            if (window.location.hash.indexOf(WorkAppRoutes.FIND_CSR.MANAGE_REGULATION) > -1) {
                                let reportId = storageService.getApplicationDataByKey(
                                    process.env.REACT_APP_ROOT_NAME + '-' + process.env.REACT_APP_FIND_CSR,
                                    'reportId'
                                );
                                singleSpa.navigateToUrl(
                                    WorkAppRoutes.FIND_CSR.APP_ROUTE + "/#" +
                                    WorkAppRoutes.FIND_CSR.CSR_REPORT + "/" + reportId
                                );
                            }
                        })
                    );

                // Revision
                if (docRev && docRev !== "" && docRev.toLowerCase() !== '00') {
                    document.getElementById("oss-csr-docnumber").innerHTML += `<span> Rev ${docRev}</span>`;
                }

                // Regulations (optional)
                if (window.location.hash.indexOf(WorkAppRoutes.FIND_CSR.MANAGE_REGULATION) > -1) {
                    $('#oss-menu-breadcrums')
                        .append($('<div>').addClass("gg-chevron-right"))
                        .append($('<div>')
                            .attr("id", "oss-csr-regulation")
                            .addClass("font-size-md")
                            .text("Regulations")
                        );
                }

                return;
            }
