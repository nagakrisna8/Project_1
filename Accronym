function updateBreadcrumbColors() {
    const lastBreadcrumb = document.getElementById('oss-additional-breadcrumb');
    if (!lastBreadcrumb) return;

    // Always make last breadcrumb non-clickable
    lastBreadcrumb.classList.remove('clickable');
    lastBreadcrumb.classList.add('non-clickable');

    // Get previous two breadcrumb divs
    let prevBreadcrumb1 = lastBreadcrumb.previousElementSibling;
    let prevBreadcrumb2 = prevBreadcrumb1 ? prevBreadcrumb1.previousElementSibling : null;

    // Helper function to set clickable/non-clickable classes
    function setBreadcrumbClickable(breadcrumb, clickable) {
        if (!breadcrumb || !breadcrumb.classList.contains('breadcrumsStyles')) return;
        if (clickable) {
            breadcrumb.classList.remove('non-clickable');
            breadcrumb.classList.add('clickable');
        } else {
            breadcrumb.classList.remove('clickable');
            breadcrumb.classList.add('non-clickable');
        }
    }

    if (lastBreadcrumb.textContent.trim() === 'Project Details') {
        // Set previous two breadcrumbs non-clickable
        setBreadcrumbClickable(prevBreadcrumb1, false);
        setBreadcrumbClickable(prevBreadcrumb2, false);
    } else {
        // Set previous two breadcrumbs clickable
        setBreadcrumbClickable(prevBreadcrumb1, true);
        setBreadcrumbClickable(prevBreadcrumb2, true);
    }
}

function appendAdditionalBreadcrumb() {

    setTimeout(() => {
        const storedActiveTest2SubMenuId = localStorage.getItem('activeTest2SubMenuId');
        if (storedActiveTest2SubMenuId) {
            var additionalBreadcrumText = $(`#nav-div-${storedActiveTest2SubMenuId}-wrap`).text().trim();
            $('[id^="nav-div-"][id$="-wrap"]').removeClass('activeSubmenuBtn');
            $(`#nav-div-${storedActiveTest2SubMenuId}-wrap`).addClass('activeSubmenuBtn');
            if (additionalBreadcrumText) {
                // Check if breadcrumb with same text already exists
                let exists = false;
                $('#oss-menu-breadcrums > div, #oss-menu-breadcrums > a').each(function () {
                    if ($(this).text().trim() === additionalBreadcrumText) {
                        exists = true;
                        return false; // break loop
                    }
                });

                if (!exists) {
                    $('#oss-menu-breadcrums').append($('<div>').addClass("gg-chevron-right"));

                    $('#oss-menu-breadcrums').append(
                        $('<div>')
                            .addClass("breadcrumsStyles font-size-md")
                            .attr("id", "oss-additional-breadcrumb")
                            .text(additionalBreadcrumText)
                            .click(() => handleBreadcrumsClick('oss-additional-breadcrumb'))
                    );
                    updateBreadcrumbColors();
                }
            }
        }
    }, 1000);
}

