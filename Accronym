 const taskdropdownlist = (props: GridCellProps) => {
        const canonicalField = props.field ?? "Task";
        const matchedTasks = task ?? [];

        const currentValue = props.dataItem[canonicalField] ?? props.dataItem["Task"] ?? [];
        const valueArray = Array.isArray(currentValue) ? currentValue : (currentValue ? [currentValue] : []);

        const selectedTaskNames = valueArray
            .map((id) => {
                const found = matchedTasks.find(t => t.TaskId === id);
                return found ? found.TaskName : id;
            })
            .join(", ");

        const handleChange = (e: SelectChangeEvent<string[]>) => {
            if (props.onChange) {
                const selectedValue = e.target.value;
                const newValue = selectedValue.includes("") ? [] : selectedValue;

                props.onChange({
                    dataIndex: props.dataIndex,
                    dataItem: props.dataItem,
                    field: canonicalField,
                    syntheticEvent: e as unknown as SyntheticEvent,
                    value: newValue,
                } as GridItemChangeEvent);

                _handleDirtyFlag(true);
            }
        };

        return (
            <td title={selectedTaskNames}>
                <Select
                    className="task-dropdownlist"
                    size="small"
                    multiple
                    value={valueArray}
                    onChange={handleChange}
                    disabled={allControlEnable}
                    renderValue={(selected) =>
                        (selected as string[])
                            .map((id) => {
                                const found = matchedTasks.find(t => t.TaskId === id);
                                return found ? found.TaskName : id;
                            })
                            .join(", ")
                    }
                >
                    {matchedTasks.length > 0 &&
                        matchedTasks.map((t) => (
                            <MenuItem key={t.TaskId} value={t.TaskId}>
                                <Checkbox
                                    checked={valueArray.indexOf(t.TaskId) > -1}
                                    sx={{ padding: 0, marginRight: 2 }}
                                />
                                <ListItemText
                                    primary={t.TaskName}
                                    primaryTypographyProps={{ sx: { fontSize: "14px", color: "#253746" } }}
                                />
                            </MenuItem>
                        ))}
                </Select>
            </td>
        );
    };
