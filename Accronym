const taskdropdownlist = (props: GridCellProps) => {
    const canonicalField = props.field ?? "Task";
    const matchedTasks = taskNameOptions ?? [];

    const currentValue =
        props.dataItem[canonicalField] ??
        props.dataItem["Task"] ??
        [];

    const valueArray = Array.isArray(currentValue)
        ? currentValue.map(Number)
        : [];

    const selectedTaskNames = valueArray
        .map((id) => {
            const found = matchedTasks.find(
                (t) => Number(t.TaskId) === Number(id)
            );

            return found ? found.TaskName : id;
        })
        .join(", ");

    const handleChange = (e: SelectChangeEvent<any>) => {
        e.stopPropagation();

        const selectedValue = e.target.value as number[];

        // Prevent immediate grid rerender
        props.dataItem[canonicalField] = selectedValue;

        _handleDirtyFlag(true);

        // Update grid after selection
        setTimeout(() => {
            props.onChange?.({
                dataIndex: props.dataIndex,
                dataItem: props.dataItem,
                field: canonicalField,
                syntheticEvent: e as unknown as SyntheticEvent,
                value: selectedValue,
            } as GridItemChangeEvent);
        }, 0);
    };

    return (
        <td title={selectedTaskNames}>
            <Select
                className="task-dropdownlist"
                size="small"
                multiple
                value={valueArray}
                onChange={handleChange}
                disabled={allControlEnable}
                MenuProps={{
                    keepMounted: true,
                }}
                renderValue={(selected) =>
                    (selected as number[])
                        .map((id) => {
                            const found = matchedTasks.find(
                                (t) =>
                                    Number(t.TaskId) === Number(id)
                            );

                            return found
                                ? found.TaskName
                                : id;
                        })
                        .join(", ")
                }
            >
                {matchedTasks.map((t) => (
                    <MenuItem
                        key={t.TaskId}
                        value={Number(t.TaskId)}
                    >
                        <Checkbox
                            checked={valueArray.includes(
                                Number(t.TaskId)
                            )}
                            sx={{
                                padding: 0,
                                marginRight: 2,
                            }}
                        />

                        <ListItemText
                            primary={t.TaskName}
                            primaryTypographyProps={{
                                sx: {
                                    fontSize: "14px",
                                    color: "#253746",
                                },
                            }}
                        />
                    </MenuItem>
                ))}
            </Select>
        </td>
    );
};
