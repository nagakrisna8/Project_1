const [openDropdown, setOpenDropdown] = useState<number | null>(null);

<Select
    className="task-dropdownlist"
    size="small"
    multiple
    open={openDropdown === props.dataIndex}
    onOpen={() => setOpenDropdown(props.dataIndex)}
    onClose={() => setOpenDropdown(null)}
    value={valueArray}
    onChange={(e) => {
        handleChange(e);

        // KEEP DROPDOWN OPEN
        setTimeout(() => {
            setOpenDropdown(props.dataIndex);
        }, 0);
    }}
    disabled={allControlEnable}
    renderValue={(selected) =>
        (selected as number[])
            .map((id) => {
                const found = matchedTasks.find(
                    (t) => Number(t.TaskId) === Number(id)
                );
                return found ? found.TaskName : id;
            })
            .join(", ")
    }
>
