const handleCreateNewReport = () => {
    handleCloseCreateNew();

    const storageServ = new StorageService();
    const key = `${EnvDetail.ParentAppName}-${EnvDetail.AppName}`;

    // ✅ ADD THIS LINE
    storageServ.setApplicationDataByKey(key, "isFromNavigation", false);

    if (!csrWorkAppFlag) {
        storageServ.setApplicationDataByKey(key, 'ProjectId', projectId);
    }

    storageServ.setApplicationDataByKey(key, 'DocNumber', '');
    storageServ.setApplicationDataByKey(key, `DocRev`, '');
    storageServ.setApplicationDataByKey(key, `ReportTemplate`, selectedReportTemplate);

    navigate(PathConstants.DYNAMIC_TAB.replace(":reportId", "0").replace(":tabIndex", "-1"), { state: null });
}
