      const editorContentEl = rootEl?.getElementsByClassName('k-editor-content')?.[0];
      
      // Use requestAnimationFrame to ensure the DOM is fully painted before focusing
      requestAnimationFrame(() => {
        try {
          // Hide any previously open toolbars first
          const allToolbars = document.querySelectorAll('.k-editor-toolbar');
          allToolbars.forEach(toolbar => {
            if (toolbar !== toolbarEl) {
              (toolbar as HTMLElement).style.display = 'none';
