useEffect(() => {
    if (
        selectedPage === "Focal Management" &&
        selectedOrganizationId &&
        selectedOrgId
    ) {
        const load = async () => {

            // ✅ STEP 1: load list FIRST
            await fetchFocal(selectedOrgId, selectedOrganizationId);

            // ✅ STEP 2: THEN create new row (form)
            if (shouldAutoCreateFocal) {

                const newFocal = {
                    ID: new Date().getTime(),
                    NAME: "",
                    PHONENO: "",
                    ADDRESS: "",
                    EMAIL: "",
                    POSITION: "",
                    TITLE: "",
                    newFlag: true,
                    SORT_ORDER: 1,
                    ISACTIVE: true,
                };

                setFocalData(prev => [newFocal, ...prev]);

                setShouldAutoCreateFocal(false);
            }
        };

        load();
    }
}, [selectedPage, selectedOrganizationId, selectedOrgId]);
