  const insertTablePlugin = new Plugin({
    appendTransaction(transactions, oldState, newState) {
      // Check if the document content has changed
      if (!transactions.some(tr => tr.docChanged)) return null;
      const { tr } = newState;
      let modified = false;

      // 1. Check if any transaction inserted a table
      const tableInserted = transactions.some(tr =>
        tr.steps.some(step => {
          let hasTable = false;
          step.getMap().forEach((oldStart, oldEnd, newStart, newEnd) => {
            newState.doc.nodesBetween(newStart, newEnd, node => {
              if (node.type.name === 'table') {
                hasTable = true;
              }
            });
          });
          return hasTable;
        })
      );
      if (!tableInserted) return null;

      // 2. Find the table and ensure a paragraph follows it
      newState.doc.descendants((node, pos) => {
        const after = pos + node.nodeSize;
        const nextNode = newState.doc.nodeAt(after);
        // If it's a table and not followed by a paragraph, add extra space
        if (node.type.name === 'table' && (!nextNode || nextNode.type.name !== 'paragraph') && tableInserted) {
          tr.insert(after, newState.schema.nodes.paragraph.create());
          modified = true;
        }
      });
      return modified ? tr : null;
    }
  });

