const forceBorderImportantPlugin = new Plugin({
  appendTransaction(transactions, oldState, newState) {
    if (!transactions.some(tr => tr.docChanged)) return null;

    const tr = newState.tr;
    let modified = false;

    newState.doc.descendants((node, pos) => {
      if (node.type.name === "table_cell" || node.type.name === "table_header") {
        const attrs = node.attrs || {};
        let style: string = attrs.style || "";

        if (style && style.includes("border")) {
          const updatedStyle = style.replace(
            /border(-top|-right|-bottom|-left)?\s*:\s*([^;]+)/g,
            (match) => {
              if (match.includes("!important")) return match;
              return `${match} !important`;
            }
          );

          if (updatedStyle !== style) {
            tr.setNodeMarkup(pos, undefined, {
              ...attrs,
              style: updatedStyle
            });
            modified = true;
          }
        }
      }
    });

    return modified ? tr : null;
  }
});


plugins = [...state.plugins, editorClickPlugin, selectionToolsPlugin(), insertImagePlugin(onImageInsert), textHighlight(),
forceBorderImportantPlugin,
keymap({
  'Mod-f': () => {
    if ((headerData?.AuthorBemsId == parseInt(userBemsId)) && headerData?.WorkFlowStep == ReportStepId.CREATE_STEP) {
      setshowFindReplaceDialog(true);
      return true;
    }
    return false;
  }
})];

