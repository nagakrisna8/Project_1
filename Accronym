.focal-header {
  display: flex;
  gap: 10px;
  border-bottom: 2px solid #e0e0e0;
}

.focal-tab {
  position: relative;
  border: none !important;
  background: transparent !important;
}

.focal-tab.active::after {
  content: "";
  position: absolute;
  bottom: -2px;
  left: 0;
  width: 100%;
  height: 3px;
  background-color: #1976d2; // blue highlight
  border-radius: 2px;
}
