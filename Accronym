const cvehandleChange = async (event: SelectChangeEvent<string[]>) => {
    if (!checkUnsavedChanges()) {
        const confirmed = await userDefinedConfirm({
            message: "There are unsaved changes in the current session. Do you want to proceed without saving?",
            okBtnText: "Yes",
            cancelBtnText: "Cancel",
        });

        if (confirmed) {
            _handleDirtyFlag(false);
        } else {
            return;
        }
    }

    const newValue = event.target.value as string;
    const finalSelected: number[] = [];

    if (newValue === "All") {
        gridGeneratedCvePanels.forEach(x => finalSelected.push(x.Cve_Id));
    } else {
        finalSelected.push(parseInt(newValue));
    }

    setSelectCve(event.target.value as string[]);

    try {
        const CdiId =
            Array.isArray(selectCDI) && selectCDI.length > 0
                ? selectCDI.join(",")
                : "0";

        const resp = await CclBuilderGridService.GetcdiById(
            finalSelected.join(","),
            CdiId
        );

        // Filtered CDI list
        setSecondCDI(resp.data);

        // Valid CDI ids returned from API
        const validIds = resp.data.map(x => x.Cdi_Id);

        // Preserve selected CDI values that still exist
        const updatedSelectedCDI = selectCDI.filter(id =>
            validIds.includes(id)
        );

        setSelectCDI(updatedSelectedCDI);

        // Update second dropdown selection
        if (updatedSelectedCDI.length > 0) {
            const selectedDescriptions = resp.data
                .filter(x => updatedSelectedCDI.includes(x.Cdi_Id))
                .map(x => x.Combined_Description);

            setSecondSelectedCDI(
                selectedDescriptions as unknown as string[]
            );
        } else {
            setSecondSelectedCDI("All" as unknown as string[]);
        }

        const reportId = localStorage.getItem("OSS-CertToolReportId")!;

        await fetchCclGridData(
            { skip: 0, take: 50 },
            "cvecdi",
            reportId,
            finalSelected.join(","),
            updatedSelectedCDI.join(",")
        );
    } catch (error) {
        dispatch(
            showSnackbar({
                snackbarOpen: true,
                snackbarType: "error",
                snackbarMessage: "Error getting CVE Data.",
            })
        );
    }
};
