// Function to add user favorite
async function AddUserFavourite() {

    // validations
    const validationFlag = addFavoriteValidate();
    if (validationFlag) {
        return;
    }

    let userToken = new UserToken();
    let ossShellToken = userToken.getAppToken();

    const currentUrl = window.location.href; // Use the current page URL as the favorite page URL
    const selectedData = getSelectedDisciplineData();
    const bu_id = selectedData.businessUnitId || 0;
    const dsc_id = selectedData.disciplineId || 0;

    // TODO: Update
    let group_id = 0;
    let tab_id = 0;
    let easa_projectno = null;
    let easa_revno = null;
    let faa_rev = null;
    let doc_no = null;
    // currently set all records as active by default as per business logic
    const is_active = 'Y';
    let project_Id;
    const groupBU = new UserToken().getGroupBU();

    if (window.projectId && window.projectId > 0) {
        project_Id = window.projectId;
    }

    if (currentUrl.includes(App_paths.csr_tab)) {
        tab_id = extractProjectNoFromUrl(currentUrl);
    }
    else if (currentUrl.includes(App_paths.qmap_doc)) {
        doc_no = extractProjectNoFromUrl(currentUrl);
    }

    if (currentUrl.includes(App_paths.easa_project_register) || currentUrl.includes(App_paths.csr_list_search) || (currentUrl.includes(App_paths.find_csr) && groupBU === GroupBU.EASA)) {
        const storageServiceTemp = new StorageService();
        const easaworkspaceprojectid = parseInt(storageServiceTemp.getApplicationDataByKey(`${process.env.REACT_APP_ROOT_NAME}-easaActiveSubMenu`, 'easamyworkspaceprojectid')) || 0;
        easa_projectno = storageServiceTemp.getApplicationDataByKey(`${process.env.REACT_APP_ROOT_NAME}-easaActiveSubMenu`, 'easaProjectNo');
        easa_revno = storageServiceTemp.getApplicationDataByKey(`${process.env.REACT_APP_ROOT_NAME}-easaActiveSubMenu`, 'easaRevision');
        const EasaActiveSubMenuId = storageServiceTemp.getApplicationDataByKey(`${process.env.REACT_APP_ROOT_NAME}-easaActiveSubMenu`, 'easaActiveSubMenu');

        if (easaworkspaceprojectid && easaworkspaceprojectid > 0) {
            project_Id = easaworkspaceprojectid;
        }
        else {
            project_Id = extractProjectNoFromUrl(currentUrl);
        }

        if (Number.isFinite(parseInt(EasaActiveSubMenuId))) {
            group_id = EasaActiveSubMenuId;
        }

        // TODO: Remove when not required
        if (easa_revno.trim().length == 1) {
            easa_revno = "0" + easa_revno;
        }
    }

    if (groupBU === GroupBU.FAA || groupBU === 0 || groupBU === "") {
        if (currentUrl.includes(WorkAppRoutes.FIND_CSR.CSR_REPORT)) {
            const storageServiceTemp = new StorageService();
            const DocRev = storageServiceTemp.getApplicationDataByKey(process.env.REACT_APP_ROOT_NAME + '-' + process.env.REACT_APP_FIND_CSR, 'DocRev');
            faa_rev = DocRev === "" ? null : DocRev;
        }
        else if (currentUrl.includes(App_paths.fpq_checklist_entry)) {
            const DocRev = JSON.parse(localStorage.getItem(`${process.env.REACT_APP_ROOT_NAME}-${process.env.REACT_APP_FPQ_DEATILS}-FPQChecklistNo`)).FPQChecklistNo || "";
            if (DocRev == null || DocRev.trim() == "") {
                faa_rev = extractProjectNoFromUrl(currentUrl);
            } else {
                faa_rev = DocRev.trim();
            }
            faa_rev = faa_rev === "" ? null : faa_rev;
        }
    }

    const url = `${process.env.REACT_APP_ROOT_BASE_API_URL}ossshell/adduserfavourite?fav_url=${encodeURIComponent(currentUrl)}&bu_id=${bu_id}&dsc_id=${dsc_id}&project_id=${project_Id}
                    &group_id=${group_id}&tab_id=${tab_id}&easa_projectno=${easa_projectno}&easa_revno=${easa_revno}&is_active=${is_active}&doc_no=${doc_no}&faa_rev=${faa_rev}`;

    $.ajax({
        traditional: true,
        url: url,
        headers: { "Authorization": `Bearer ${ossShellToken}` },
        method: 'POST',
        contentType: "application/json",
        async: false,
        success: function (result) {
            if (result) {
                showSnackbar("Successfully added to favorite", "success");
                refreshUserFavourites(ossShellToken);
            }
        },
        error: function (error) {
            if (error.responseText.includes("Already added as a favourite")) {
                showSnackbar("Already added as a favorite", "info");
            }
            else {
                showSnackbar(error.responseText, "error");
            }
        }
    });
}

function addFavoriteValidate() {
    // return true if all cases pass, else return false
    const currentUrl = window.location.href;
    const currentUrlParts = currentUrl.split('/');
    // csr create-new case
    if (currentUrl.indexOf(WorkAppRoutes.FIND_CSR.CSR_REPORT) > -1 && currentUrlParts[currentUrlParts.length - 1] == -1) {
        showSnackbar("Please save the report first.", "info");
        return true;
    }
    // fpq create-new case
    if (currentUrl.includes(App_paths.fpq_checklist_entry_new)) {
        showSnackbar("Please save the checklist first.", "info");
        return true;
    }
    return false;
}

