const cvehandleChange = async (event: SelectChangeEvent<string[]>) => {
    if (!checkUnsavedChanges()) {
        const confirmed = await userDefinedConfirm({
            message: "There are unsaved changes in the current session. Do you want to proceed without saving?",
            okBtnText: "Yes",
            cancelBtnText: "Cancel",
        });

        if (!confirmed) {
            return;
        }

        _handleDirtyFlag(false);
    }

    const newValue = event.target.value as string;
    const finalSelected: number[] = [];

    if (newValue === "All") {
        gridGeneratedCvePanels.forEach(x => finalSelected.push(x.Cve_Id));
    } else {
        finalSelected.push(Number(newValue));
    }

    setSelectCve(event.target.value as string[]);

    try {

        // ******************************
        // Get CDI by selected CVE
        // ******************************
        const resp = await CclBuilderGridService.GetcdiById(
            finalSelected.join(","),
            null          // <-- IMPORTANT
        );

        const filteredCDI = resp.data;

        setSecondCDI(filteredCDI);

        // ******************************
        // Preserve selected CDI
        // ******************************
        const filteredIds = filteredCDI.map(x => x.Cdi_Id);

        const newSelectedCDI = selectCDI.filter(id =>
            filteredIds.includes(id)
        );

        setSelectCDI(newSelectedCDI);

        // Update second dropdown
        if (newSelectedCDI.length > 0) {

            const selectedDescriptions = filteredCDI
                .filter(x => newSelectedCDI.includes(x.Cdi_Id))
                .map(x => x.Combined_Description);

            setSecondSelectedCDI(
                selectedDescriptions as unknown as string[]
            );

        } else {

            setSecondSelectedCDI(
                "All" as unknown as string[]
            );

        }

        const reportId = localStorage.getItem("OSS-CertToolReportId")!;

        await fetchCclGridData(
            { skip: 0, take: 50 },
            "cvecdi",
            reportId,
            finalSelected.join(","),
            newSelectedCDI.join(",")
        );

    } catch (error) {
        dispatch(
            showSnackbar({
                snackbarOpen: true,
                snackbarType: "error",
                snackbarMessage: "Error getting CVE Data.",
            })
        );
    }
};
