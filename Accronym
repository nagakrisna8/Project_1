const taskdropdownlist = (props: GridCellProps) => {
    const canonicalField = "TaskId";
    const matchedTasks = task ?? [];

    const initialValue =
        props.dataItem["TaskId"] ??
        [];

    const normalizedTasks = Array.isArray(initialValue)
        ? initialValue.map(Number)
        : String(initialValue)
              .split(",")
              .map((x) => Number(x.trim()))
              .filter((x) => !isNaN(x));

    const [selectedTasks, setSelectedTasks] =
        useState<number[]>(normalizedTasks);

    useEffect(() => {
        setSelectedTasks(normalizedTasks);
    }, [props.dataItem.TaskId]);

    const handleChange = (e: SelectChangeEvent<any>) => {
        const value =
            typeof e.target.value === "string"
                ? e.target.value
                      .split(",")
                      .map((x) => Number(x))
                : (e.target.value as number[]);

        setSelectedTasks(value);

        // IMPORTANT
        props.dataItem.TaskId = value.join(",");
    };

    return (
        <td>
            <FormControl fullWidth size="small">
                <Select
                    multiple
                    value={selectedTasks}
                    onChange={handleChange}
                    displayEmpty
                    renderValue={(selected) => {
                        const selectedNames = matchedTasks
                            .filter((x) =>
                                (selected as number[]).includes(x.TaskId)
                            )
                            .map((x) => x.TaskName);

                        return selectedNames.join(", ");
                    }}
                    MenuProps={{
                        PaperProps: {
                            style: {
                                maxHeight: 300,
                            },
                        },
                    }}
                >
                    {matchedTasks.map((item) => (
                        <MenuItem
                            key={item.TaskId}
                            value={item.TaskId}
                        >
                            <Checkbox
                                checked={selectedTasks.includes(item.TaskId)}
                            />
                            <ListItemText primary={item.TaskName} />
                        </MenuItem>
                    ))}
                </Select>
            </FormControl>
        </td>
    );
};
