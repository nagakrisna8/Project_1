  const checkBookmarkLinkPresent = () => BookmarkService.checkBookmarkLinkPresent(editorViewRef);

  const bookmarkCtx = { editorViewRef, getHtml, getEditorHtml, IsNonDynamicTab, tabIndex, item };

  const handleAddBookMark = (bookMarkInput, rowId = 0) => {
    BookmarkService.handleAddBookMark(bookmarkCtx, bookMarkInput, userBemsId, reportId, saveTabDetails, setOpenBookMarkPopup, rowId);
