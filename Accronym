  // Bookmark functions 
  const handleBookmarkActions = (value: string, action: string) => {
    setShowPrompt(false);
    let isTabDirty = storageService.getApplicationDataByKey(`${EnvDetail.ParentAppName}-${EnvDetail.AppName}`, 'IsTabDirty');
    const selection = editorViewRef.current.view.state.selection;
    if (isTabDirty && !selection.empty) {
