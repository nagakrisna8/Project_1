const initialValue =
    props.dataItem[canonicalField] ??
    props.dataItem["TaskId"] ??
    props.dataItem["Task"] ??
    [];

const normalizedTasks = String(initialValue)
    .split(",")
    .map((x) => Number(x.trim()))
    .filter((x) => !isNaN(x));

const [selectedTasks, setSelectedTasks] =
    useState<number[]>(normalizedTasks);
