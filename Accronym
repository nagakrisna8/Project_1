          // Reset all editor borders
          const allEditors = document.querySelectorAll('.k-editor');
          allEditors.forEach(editor => {
            if (editor !== rootEl) {
              (editor as HTMLElement).style.border = 'none';
            }
          });
          
          // Scroll editor into view for both paragraph and table
          if (rootEl) {
            const rect = rootEl.getBoundingClientRect();
            const scrollTop = window.pageYOffset + rect.top - (window.innerHeight / 3);
            window.scrollTo({ top: scrollTop, behavior: 'smooth' });
