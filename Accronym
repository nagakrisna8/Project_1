function Startup(jwtToken) {
    $("#shell-main-section").show();
    var userTokenProvider = new UserToken();
    // Set Shell level token
    userTokenProvider.setAppToken(jwtToken);
    // Initiate SignalR
    notificationHub.intiateConnection();
    notificationHub.startConnection();

    // Hide panel in case user is not Admin
    let userToken = new UserToken();

    // Set Cache If its not available
    let shellSharedCache = storageService.getApplicationData(fullShellAppName);
    if (!shellSharedCache) {
        storageService.setApplicationData(fullShellAppName, shellSharedData);
        if (userToken.isCurrentUserAdmin()) {
            storageService.setApplicationDataByKey(`${process.env.REACT_APP_ROOT_NAME}-${process.env.REACT_APP_NAME}`, 'AppRouteValues', WorkAppRouteValues);
        }
    }

    loadProfileData(jwtToken);
    loadHeaderData(jwtToken);
    loadTermsofuseData(jwtToken);
    loadHelpGuideOption(jwtToken);
    ShowBellIconCount(jwtToken);

    console.log("Container Env: ", process.env.REACT_APP_ENV);
    // Hide Menu and Submenu on first page load
    setMenuSectionVisibility(false);
    isBuITAR = new UserToken().isCurrentBusinessUnitITAR();
    // Hide or Show ITAR Warning Message on Home page load based on selected Business Unit
    setHomePageItarWarningVisibility(isBuITAR);
    // Register Work Applications
    //new RegisterWorkApplication().register();
    populateLayout();
    const container = document.querySelector(".skeleton_container");
    const cardTemplate = document.getElementById("card-template");
    for (let i = 0; i < 10; i++) {
        container.append(cardTemplate.cloneNode(true));
    }
    // singleSpa.start();
    // Register Element Event using JQuery
    registerElementEvents(jwtToken);
    handleRolesForHomepageWorkApp();
    updateFavoriteIconsVisibility();

}

function setConfigData(jwtToken) {
    $.ajax({
        url: `${process.env.REACT_APP_ROOT_BASE_API_URL}` + 'ossshell/GetAdobeConfigData',
        headers: { "Authorization": `Bearer ${jwtToken}` },
        method: 'GET',
        dataType: 'text',
        async: false,
        success: (response) => {
            if (response && typeof (response) === 'string') {
                if (Object.getOwnPropertyNames(JSON.parse(response)).length !== 0) {
                    let adobeConfigData = JSON.parse(response);
                    if (window.adobe) {
                        if (adobeConfigData.AdobeWorkAppConfigData) {
                            window.adobe.adobeConfigData = adobeConfigData.AdobeWorkAppConfigData;
                        }
                        if (adobeConfigData.AdobeDataKey) {
                            window.adobe.adobeDataKey = adobeConfigData.AdobeDataKey;
                        }
                    }
                    setUserAdobeData(jwtToken);
                    logApplicationView();
                    logPageViewEvent();
                }
            }
        }
    })

}
