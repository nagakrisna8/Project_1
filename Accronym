<div className="form-row">
    <label>Active</label>
    <input
        type="checkbox"
        name="isActive"
        checked={!!formData.isActive}
        onChange={(e) => {
            const updated = {
                ...formData,
                isActive: e.target.checked
            };
            setFormData(updated);

            // mark dirty
            setDirtyFlag?.(true);

            onFormChange?.(updated);
        }}
    />
</div>
