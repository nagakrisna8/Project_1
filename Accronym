const handleChange = (e: any) => {
    const updated = {
        ...formData,
        [e.target.name]: e.target.value
    };

    setFormData(updated);

    // ✅ Immediately mark form dirty
    onFormChange?.(updated);
};



const handleFormChange = useCallback((id: number, data: any) => {
    formDataMapRef.current[id] = data;

    // ✅ Mark tab dirty immediately
    props.setDirtyFlag?.(true);
}, [props]);
