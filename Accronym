          };
          if (headerData && headerData.EditEnabledFlag == "Y") {
            toolsArray.push([renderAITool]);
          };
          return toolsArray;
        }
      }
      // Create new report/ saved Parent report
      toolsArray.push([Strikethrough]);
      // Show Comment button
      if (headerData?.CommentEnabledFlag === "Y") {
        toolsArray.push([CustomAddCommentButton]);
      }
      toolsArray.push([CustomAcronymButton]);
      // Show Revision button in case of Revised report
