        let isHelpGuidePopupOpened = $('#oss-home-guidePopup')[0].checkVisibility();
        let userHelpGuideData = "";
        if (!isHelpGuidePopupOpened) {
            $.ajax({
                url: `${process.env.REACT_APP_ROOT_BASE_API_URL}` + 'ossshell/GetUserHelpGuideData',
                headers: { "Authorization": `Bearer ${jwtToken}` },
                method: 'GET',
                dataType: 'text',
                async: false,
                success: (response) => {
                    let isCancelAutoTour = false;
                    let disableAutoTourCheck = document.querySelector('#oss-disable-autoTourCheck')
                    if (response && typeof (response) === 'string') {
                        if (Object.getOwnPropertyNames(JSON.parse(response)).length !== 0) {
                            userHelpGuideData = JSON.parse(response);
                            isCancelAutoTour = userHelpGuideData && userHelpGuideData.cancelAutoTour && userHelpGuideData.cancelAutoTour == 'Y' ? true : false;
                            if (disableAutoTourCheck) {
                                disableAutoTourCheck.checked = !isCancelAutoTour;
                            }
                        }
                        else {
                            disableAutoTourCheck.checked = true;
                        }
                    }
                    $('#oss-home-guidePopup').toggle();
                }
            })
        }
        else {
            $('#oss-home-guidePopup').toggle();
        }
        event.stopPropagation(); // Prevent event from bubbling up to document
    });
