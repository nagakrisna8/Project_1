    //}

    else if (value === "Cert Tool") {
        $('#oss-menu-breadcrums').html('');
        $('#oss-menu-breadcrums')
            .append($('<a>').text('Home').attr("href", "#").addClass("homeBreadcurm"))
            .append($('<div>').addClass("gg-chevron-right"))
            .append($('<div>').addClass("breadcrumsStyles").text('Cert Tool').attr("id", `easa-certtool-breadcrums`)
                .click(() => handleBreadcrumsClick(`easa-certtool-breadcrums`)));
    }
    else if (value === "BILDR Tool") {
        // Get BradCrumb Detail
        setMenuSectionVisibility(false);
        EASAMenuSubmenu.setMenuSectionVisibility(true);
        const storageServiceTemp = new StorageService();
        const currentTitle = storageServiceTemp.getApplicationDataByKey(`${process.env.REACT_APP_ROOT_NAME}-easaActiveSubMenu`, 'easaActiveSubMenuTitle');
        const currentProject = storageServiceTemp.getApplicationDataByKey(`${process.env.REACT_APP_ROOT_NAME}-easaActiveSubMenu`, 'currentProjectBreadcrumbs');
        const currentActiveDesignDocTab = storageServiceTemp.getApplicationDataByKey(`${process.env.REACT_APP_ROOT_NAME}-easaActiveSubMenu`, 'easaActiveSubMenu');
        const bildrTitle = storageServiceTemp.getApplicationDataByKey(`${process.env.REACT_APP_ROOT_NAME}-easaActiveSubMenu`, 'bildrTitle');
        const docNumber = storageServiceTemp.getApplicationDataByKey(process.env.REACT_APP_ROOT_NAME + '-' + process.env.REACT_APP_FIND_CSR, 'DocNumber');
        $('#oss-menu-breadcrums').html('');
        $('#oss-menu-breadcrums')
            .append($('<a>').text('Home').attr("id", "idhomeBreadcurm").addClass("homeBreadcurm")
                .click(() => handleHomeBreadcrumsClick(event)))
            .append($('<div>').addClass("gg-chevron-right"))
            .append($('<div>').addClass("breadcrumsStyles").text('EASA My Workspace').attr("id", `oss-csrsearch-breadcrums`)
                .click(() => singleSpa.navigateToUrl(WorkAppRoutes.PMDB_ProjectRegister.APP_ROOT + "/#" + WorkAppRoutes.PMDB_ProjectRegister.EASA_WORKSPACE_HOME)))
            .append($('<div>').addClass("gg-chevron-right"))
            .append($('<div>').addClass("breadcrumsStyles").text(currentProject).attr("id", `oss-csrsearch-breadcrums`).click(() => {
                EASAMenuSubmenu.handleSubMenuButtonClick("projectdetailsbttn");
            }))
            .append($('<div>').addClass("gg-chevron-right"))
            .append($('<div>').addClass("breadcrumsStyles").text(currentTitle).attr("id", `oss-csrsearch-breadcrums`).click(() => {
                EASAMenuSubmenu.handleSubMenuButtonClick(currentActiveDesignDocTab);
                // singleSpa.navigateToUrl(WorkAppRoutes.FIND_CSR.APP_ROUTE + "/#" + WorkAppRoutes.FIND_CSR.CSR_LIST_SEARCH.replace(':groupId', currentActiveDesignDocTab));
            }))
            .append($('<div>').addClass("gg-chevron-right"))
            .append($('<div>').addClass("breadcrumsStyles").text(`Document Number: ${docNumber ? docNumber : ''}`).attr("id", `oss-csr-docnumber`).click(() => {
                let reportId = storageService.getApplicationDataByKey(process.env.REACT_APP_ROOT_NAME + '-' + process.env.REACT_APP_FIND_CSR, 'reportId');
                singleSpa.navigateToUrl(WorkAppRoutes.FIND_CSR.APP_ROUTE + "/#" + WorkAppRoutes.FIND_CSR.CSR_REPORT + "/" + reportId);
            }))
            .append($('<div>').addClass("gg-chevron-right"))
            .append($('<div>').addClass("breadcrumsStyles").text(bildrTitle).attr("id", `oss-csrsearch-breadcrums`));
    }
    else if (value === "HOME" || value === "ShellAdmin" || value === "SearchResult") {
        $('#oss-menu-breadcrums').html('');
    }
    else if (value === "Project Schedule") {
        if (!window.projectId) {
            let routeDataArray = window.location.hash.split('/');
            window.projectId = routeDataArray[routeDataArray.length - 3];
        }
        checkProjectIdFromRoute().then(({ projectId, itarStatus }) => {
            $('#oss-menu-breadcrums').html('');
            $('#oss-menu-breadcrums')
                .append($('<a>').text('Home').attr("href", "#").addClass("homeBreadcurm"))
                .append($('<div>').addClass("gg-chevron-right"))
                .append($('<div>').addClass("breadcrumsStyles").text('My Workspace').attr("id", `oss-myworkspace-breadcrums`).click(() => handleBreadcrumsClick(`oss-myworkspace-breadcrums`)))
                .append($('<div>').addClass("gg-chevron-right"))
            // Project Number with ITAR condition
            let projectElement = $('<div>')
                .attr("id", "oss-projectId-breadcrumb")
                .addClass("breadcrumsStyles")
                .text(`Project Number ${projectId}`)
                .click(() => handleBreadcrumsClick(`oss-projectschedule-breadcrums`));

            $('#oss-menu-breadcrums')
                .append(projectElement)
                .append($('<div>').addClass("gg-chevron-right"))
                .append($('<div>').addClass("breadcrumsStyles").text('Project Schedule').attr("id", `oss-projectschedule-breadcrums`)
                    .click(() => handleBreadcrumsClick(`oss-projectschedule-breadcrums`)));
        });
    }
    updateFavoriteIconsVisibility();
}
