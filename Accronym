            storageService.setApplicationDataByKey(fullShellAppName, "CurrentAcronym", currentDiMatch.Acronym);
            $('select[id^="oss-navbarNavDropdownDiscipline"] option:selected').attr("selected", null);
            let selectedDisciplineId = getSelectedDisciplineId(userBuDiList, currentBuMatch.BusinessUnitName, currentDiMatch.DisciplineName);
            $(`select[id^="oss-navbarNavDropdownDiscipline"] option[value='${selectedDisciplineId}']`).attr("selected", "selected");
            $(`select[id^="oss-navbarNavDropdownDiscipline"] option[value='${selectedDisciplineId}']`).text(currentDiMatch.Acronym + " : " + currentDiMatch.DisciplineName);
            return [currentDiMatch.BusinessUnitId, currentDiMatch.DisciplineId];
        }
        else
            return null;
    } else
        return null;
}
