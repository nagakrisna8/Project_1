<MenuItem
    key={t.TaskId}
    value={Number(t.TaskId)}
    sx={{
        paddingTop: "2px",
        paddingBottom: "2px",
        minHeight: "28px"
    }}
>
    <Checkbox
        checked={selectedTasks.includes(
            Number(t.TaskId)
        )}
        sx={{
            padding: "2px",
            marginRight: "2px"
        }}
    />

    <ListItemText
        primary={t.TaskName}
        sx={{
            margin: 0
        }}
    />
</MenuItem>
