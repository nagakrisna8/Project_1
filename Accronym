function uploadimgData(ossShellToken) {
    var fileInput = document.getElementById('oss-sign-fileInput');
    var file = fileInput.files[0];

    if (!file) {
        showSnackbar("Please select a file to upload.", "error");
        return;
    }

    var formData = new FormData();
    formData.append("file", file);
    let pathName = window.location?.pathname;

    $.ajax({
        type: 'POST',
        url: `${process.env.REACT_APP_ROOT_BASE_API_URL}ossshell/UploadSignature`,
        headers: { "Authorization": `Bearer ${ossShellToken}` },
        data: formData,
        processData: false,
        contentType: false,
        success: function (response) {
            // Close Upload Signature Popup
            $("#oss-uploadSignatureModal").modal('toggle');
            // TODO: Show Success Message

            showSnackbar("Signature has uploaded successfully.", "success");
            if (pathName && pathName.indexOf(`${WorkAppRoutes.FIND_CSR.APP_ROUTE}`) > -1) {
                // On success upload send details to CSR Revision via PubSub
                let dataToShare = {
                    Action: 'UploadSignatureData',
                    Detail: {
                        Result: "Success",
                        BemsId: response
                    }
                };
                PubSub.publish(PubSubEvent.Upload_Signature_Data_Event, dataToShare);
            }
            //console.log('Success:', response);
        },
        error: function (error) {
            if (pathName && pathName.indexOf(`${WorkAppRoutes.FIND_CSR.APP_ROUTE}`) > -1) {
                // On success upload send details to CSR Revision via PubSub
                let dataToShare = {
                    Action: 'UploadSignatureData',
                    Detail: {
                        Result: "Error"
                    }
                };
                PubSub.publish(PubSubEvent.Upload_Signature_Data_Event, dataToShare);
            }
            //console.log('Error fetching data:', error);
        }
    });
}

function showSnackbar(message, type) {
    const snackbar = $("#snackbar");

    // SVG icon strings (use small inline SVGs; stroke/fill use currentColor so they adapt to text color)
    const icons = {
        success: '<svg xmlns="http://www.w3.org/2000/svg" height="24" width="24" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1.5 15l-4.5-4.5 1.41-1.41L10.5 14.67l6.59-6.59L18.5 9l-8 8z"/></svg>',
        error: '<svg xmlns="http://www.w3.org/2000/svg" height="24" width="24" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm5 13.59L15.59 17 12 13.41 8.41 17 7 15.59 10.59 12 7 8.41 8.41 7 12 10.59 15.59 7 17 8.41 13.41 12 17 15.59z"/></svg>',
        info: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M12 8v.01" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/><path d="M11 12h1v4h1" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2"/></svg>'
    };

    //snackbar.text(message);
    snackbar.find("#snackbar-message").text(message);
    // Adjust snackbar styles based on type
    if (type === "error") {
        snackbar.find("#snackbar-icon").html(icons.error);
        snackbar.removeClass("snackbar-success snackbar-info").addClass("snackbar-error");
    } else if (type === "success") {
        snackbar.find("#snackbar-icon").html(icons.success);
        snackbar.removeClass("snackbar-error snackbar-info").addClass("snackbar-success");
    } else if (type === "info") {
        snackbar.find("#snackbar-icon").html(icons.info);
        snackbar.removeClass("snackbar-error snackbar-success").addClass("snackbar-info");
    }

    snackbar.addClass("show");
    snackbar.fadeIn();

    // Hide after 3 seconds
    setTimeout(() => {
        snackbar.fadeOut(() => {
            snackbar.removeClass("show");
        });
    }, 7000);
    // Close button functionality
    snackbar.find(".btn-close").off("click").on("click", function () {
        snackbar.fadeOut(() => {
            snackbar.removeClass("show");
        });
    });
}

