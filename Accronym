window.addEventListener("single-spa:routing-event", () => {
    let isLogout = false;
    isLogout = window.location.pathname.includes('logout');
    WorkAppRequest.eventCount = 0;
    WorkAppRequest.eventAppName = [];
    if (isLogout) {
        WorkAppRequest.isRouteChanged = false;
        window.location.href = 'logout.html';
        return;
    }
    WorkAppRequest.setAppCount(singleSpa.getMountedApps().length);
    WorkAppRequest.isRouteChanged = true;
    let userOSSToken = new UserToken();
    let ossShellAuthToken = userOSSToken.getAppToken();
    let tempWorkApp = "";
    if (window.location.pathname.endsWith(`/${process.env.REACT_APP_SUB_PATH}`) || window.location.pathname.endsWith(`/${process.env.REACT_APP_SUB_PATH}/`)
        || window.location.pathname == '/') {
        tempWorkApp = "Home Page";
        toggleFirstFavoriteIcon(false);
        currentWorkApp = tempWorkApp;
    }
    else {
        tempWorkApp = helpGuideService.getWorkAppForRoute(window.location.href);
        if (tempWorkApp === "") {
            tempWorkApp = "Home Page"
        }
        tempWorkApp = tempWorkApp.replaceAll('_', ' ');
        currentWorkApp = tempWorkApp;
    }
    if (!isLogout && (currentWorkApp !== prevWorkApp)) {
        ShowBellIconCount(ossShellAuthToken);
        prevWorkApp = currentWorkApp;
    }
    updateFavoriteIconsVisibility();
})

