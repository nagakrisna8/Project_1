            } else if (view && view.dom) {
              view.focus();
            }
          } else {
            // For paragraph: focus the ProseMirror view
            if (view && view.dom) {
              view.focus();
            }
          }
          
          // Show toolbar and set proper borders
          if (toolbarEl) {
            (toolbarEl as HTMLElement).style.display = 'block';
            (toolbarEl as HTMLElement).style.borderTop = '1px solid rgba(0, 0, 0, 0.23)';
            (toolbarEl as HTMLElement).style.zIndex = '1';
            // Add mousedown listener to prevent toolbar from hiding on click
