  const handleInsertBookmarkLink = (anchorId, bookmarkText = "", linkTargetId = 0, tabId = 0, linkBookmarkId = 0, rowId = 0) => {
    BookmarkService.handleInsertBookmarkLink(editorViewRef, anchorId, bookmarkText, linkTargetId, tabId, linkBookmarkId, rowId);
