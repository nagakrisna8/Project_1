useEffect(() => {
    console.log("AUTO CREATE FLAG:", shouldAutoCreateFocal);
    console.log("ORG TYPE:", selectedOrgId);
    console.log("ORG ID:", selectedOrganizationId);

    if (
        selectedPage === "Focal Management" &&
        selectedOrganizationId &&
        selectedOrgId
    ) {
        const load = async () => {
            await fetchFocal(selectedOrgId, selectedOrganizationId);

            console.log("AFTER FETCH, FLAG:", shouldAutoCreateFocal);

            if (shouldAutoCreateFocal) {
                const newFocal = {
                    ID: new Date().getTime(),
                    NAME: "",
                    PHONENO: "",
                    ADDRESS: "",
                    EMAIL: "",
                    POSITION: "",
                    TITLE: "",
                    newFlag: true,
                    SORT_ORDER: 1,
                    ISACTIVE: true,
                };

                console.log("ADDING NEW FOCAL ROW");

                setFocalData(prev => [newFocal, ...prev]);
                setShouldAutoCreateFocal(false);
            }
        };

        load();
    }
}, [selectedPage, selectedOrganizationId, selectedOrgId, shouldAutoCreateFocal]);
