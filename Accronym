//Function to get CSR Project Number
function extractProjectNoFromCsrUrl(url) {
    try {
        // Remove hash fragment if present
        const urlWithoutHash = url.split('#')[1] || '';
        // Split the hash fragment by '/'
        const parts = urlWithoutHash.split('/').filter(Boolean); // filter(Boolean) removes empty strings

        // Find the index of 'csr-report'
        const csrIndex = parts.indexOf('csr-report');
        if (csrIndex !== -1 && parts.length > csrIndex + 1) {
            // The next segment after 'csr-report' is the project number
            return parts[csrIndex + 1];
        }
        return null;
    } catch (error) {
        showSnackbar('Error extracting project number from CSR URL: ' + error.responseText, "error");
        return null;
    }
}

