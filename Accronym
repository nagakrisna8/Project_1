// Updated: hides first favorite icon when:
//  - there are no breadcrumbs
//  - breadcrumbs do NOT start with "Home" followed by a workspace variant
//  - breadcrumbs are exactly "Home" + "My Workspace" (or "Home" + "EASA My Workspace")
// Shows the first favorite icon when:
//  - there are additional breadcrumb pieces beyond the initial "Home" + "Workspace"
//  - OR the workspace element contains leftover/extra text (treated as additional piece)
function updateFavoriteIconsVisibility() {
    const breadcrumbContainer =
        document.getElementById('oss-menu-breadcrums') ||
        document.getElementById('oss-myworkspace-breadcrums');

    // Default: hide first favorite when no container
    if (!breadcrumbContainer) {
        toggleFirstFavoriteIcon(false);
        toggleSecondFavoriteIcon(true);
        return;
    }

    // Helper: treat nodes that are only separators or whitespace as not meaningful
    function isSeparatorNode(node) {
        if (node.nodeType === Node.ELEMENT_NODE) {
            const el = node;
            const cls = (el.className || '').toString().toLowerCase();
            if (cls.includes('gg-chevron') || cls.includes('chevron') || cls.includes('breadcrumb-sep')) return true;
            var txt = '';
            if (el.childNodes[0] != undefined && el.childNodes[0].alt != undefined) {
                txt = el.childNodes[0].alt;
            }
            else {
                txt = (el.textContent || '').trim();
            }
            return txt === '' || /^[▸›>»→|\/-]+$/.test(txt);
        }
        if (node.nodeType === Node.TEXT_NODE) {
            const t = node.textContent.replace(/\s+/g, '');
            return t === '' || /^[▸›>»→|\/-]+$/.test(t);
        }
        return false;
    }

    // Collect meaningful breadcrumb items in visual order.
    // If a workspace element contains extra text besides "EASA My Workspace" or "My Workspace",
    // treat the leftover as an additional item.
    const items = [];
    breadcrumbContainer.childNodes.forEach(node => {
        if (isSeparatorNode(node)) return;
        var text = '';
        if (node.childNodes[0] != undefined && node.childNodes[0].alt != undefined) {
            text = node.childNodes[0].alt;
        }
        else {
            text = (node.textContent || '').trim();
        }
        if (!text) return;

        const workspaceMatch = text.match(/\b((easa\s+)?my workspace)\b/i);
        if (workspaceMatch) {
            // push the workspace phrase
            items.push(workspaceMatch[0].toLowerCase());
            // leftover counts as an additional crumb (causes button to show)
            const leftover = text.replace(workspaceMatch[0], '').trim();
            if (leftover) items.push(leftover.toLowerCase());
        } else {
            items.push(text.toLowerCase());
        }
    });

    // Normalize and unique
    const meaningful = items
        .map(i => (i || '').replace(/\s+/g, ' ').trim())
        .filter(i => i && !/^[▸›>»→|\/-]+$/.test(i));
    const uniqueItems = [...new Set(meaningful)];

    // If no meaningful breadcrumbs -> hide
    if (uniqueItems.length === 0) {
        toggleFirstFavoriteIcon(false);
        toggleSecondFavoriteIcon(true);
        return;
    }

    // Check that breadcrumbs start with "home" then a workspace variant.
    // We require the FIRST meaningful item to include "home" and the SECOND meaningful item to be workspace.
    const firstItem = uniqueItems[0] || '';
    const secondItem = uniqueItems[1] || ''; // may be undefined if only one item
    const startsWithHome = /\bhome\b/.test(firstItem);
    const secondIsWorkspace = /\b(my workspace|easa my workspace|easa workspace|workspace)\b/.test(secondItem);

    // If breadcrumbs don't start with Home + Workspace, hide the first favorite icon.
    if (!startsWithHome || !secondIsWorkspace) {
        toggleFirstFavoriteIcon(false);
        toggleSecondFavoriteIcon(true);
        return;
    }

    // At this point we know the breadcrumb begins with Home + Workspace.
    // If there are exactly those two items -> hide first favorite icon.
    // If there are more than two items (or workspace had leftover text that produced an extra item) -> show.
    if (uniqueItems.length <= 2) {
        toggleFirstFavoriteIcon(false);
    } else {
        toggleFirstFavoriteIcon(true);
    }

    toggleSecondFavoriteIcon(true);
}

// OPTIONAL: ensure the check runs after DOM is ready and when breadcrumbs change.
(function initBreadcrumbWatcher() {
    function runUpdateDebounced() {
        if (runUpdateDebounced._t) clearTimeout(runUpdateDebounced._t);
        runUpdateDebounced._t = setTimeout(() => {
            updateFavoriteIconsVisibility();
            runUpdateDebounced._t = null;
        }, 80); // small debounce to allow async rendering
    }

    function attachObserverIfPresent() {
        const container = document.getElementById('oss-menu-breadcrums') || document.getElementById('oss-myworkspace-breadcrums');
        if (!container) return;
        // Run once immediately for current DOM
        updateFavoriteIconsVisibility();
        // Observe for changes
        if (!container.__breadcrumbObserver) {
            const observer = new MutationObserver(runUpdateDebounced);
            observer.observe(container, { childList: true, subtree: true, characterData: true });
            container.__breadcrumbObserver = observer;
        }
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', attachObserverIfPresent);
    } else {
        attachObserverIfPresent();
    }
})();

