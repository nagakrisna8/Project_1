function highLightMainMenu(mainMenuId) {
    // storing data in activeMainMenuId local storage
    localStorage.setItem('activeMainMenuId', mainMenuId);
    for (let j = 0; j < shellHeaderData.MenuDetailEntity.length; j++) {
        const menuUIId = shellHeaderData.MenuDetailEntity[j].MenuUIId;
        const mainMenuTabId = `#nav-OSS-${menuUIId}-tab`;
        const mainMenuContainerId = `#nav-OSS-${menuUIId}`;
        if (menuUIId === mainMenuId) {
            $(mainMenuTabId).addClass("active").attr("aria-selected", "true");
            $(mainMenuContainerId).addClass("active show");
            // Ensure submenu visibility/highlighting within that menu is updated
            setSubMenuSectionVisibility(shellHeaderData.MenuDetailEntity[j].SubMenuDetailEntityList);
        } else {
            $(mainMenuTabId).removeClass("active").attr("aria-selected", "false");
            $(mainMenuContainerId).removeClass("active show");
        }
    }

}

function highLightSubMenu(subMenuId) {
    localStorage.setItem('activeTest2SubMenuId', subMenuId);
    const storedActiveTest2SubMenuId = localStorage.getItem('activeTest2SubMenuId');
    if (storedActiveTest2SubMenuId) {
        $('[id^="nav-div-"][id$="-wrap"]').removeClass('activeSubmenuBtn');
        $(`#nav-div-${storedActiveTest2SubMenuId}-wrap`).addClass('activeSubmenuBtn');
    }
}

