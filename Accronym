const fetchFocal = async (orgName: number, orgTypeId: number) => {
    let masterdataType = 4;

    EasaListService.getAdminMasterDetailsTypeFocals(masterdataType, orgName, orgTypeId)
        .then((response) => {
            let result: FocalMasterTable[] = response?.data.map(x => ({
                ID: x.ID,
                NAME: x.NAME,
                PHONENO: x.PHONENO,
                ADDRESS: x.ADDRESS,
                EMAIL: x.EMAIL,
                POSITION: x.POSITION,
                TITLE: x.TITLE,
                ISACTIVE: x.ISACTIVE === "Y",
            }));

            setFocalData(prev => {
                const newRow = prev.find(r => r.newFlag);

                if (newRow) {
                    return [newRow, ...result.reverse()];
                }

                return [...result].reverse();
            });

            setOriginalFocalData([...result].reverse());
        })
        .catch((err) => console.error(err));
};
