            layoutSerializedObj["col"], layoutSerializedObj["row"]);
    }

    // Override gridster heights: App1 & App3 = 100%, App2 = 40%, App4 = 60%
    // Gridster takes full remaining viewport height
    var fullHeight = availableHeight;
    var splitAvailable = availableHeight - widgetMarginY; // only gap between App2/App4
    var heightApp2 = Math.floor(splitAvailable * 0.4);
    var heightApp4 = splitAvailable - heightApp2;

    var heightMap = {
        'App1': fullHeight,
        'App2': heightApp2,
        'App3': fullHeight,
        'App4': heightApp4
    };

    for (var appId in heightMap) {
        var el = document.getElementById(appId);
        if (el) {
            el.style.setProperty('height', heightMap[appId] + 'px', 'important');
        }
    }

    // Reposition App4 directly below App2 to eliminate extra gap
    var app2El = document.getElementById('App2');
    var app4El = document.getElementById('App4');
    if (app2El && app4El) {
        var app4Top = app2El.offsetTop + heightApp2 + widgetMarginY;
        app4El.style.setProperty('top', app4Top + 'px', 'important');
    }

