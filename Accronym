useEffect(() => {
    if (
        selectedPage === "Focal Management" &&
        selectedOrganizationId &&
        selectedOrgId
    ) {
        const load = async () => {
            await fetchFocal(selectedOrgId, selectedOrganizationId);

            if (shouldAutoCreateFocal) {
                CreateFocal();
                setShouldAutoCreateFocal(false);
            }
        };

        load();
    }
}, [selectedPage, selectedOrganizationId, selectedOrgId]);
