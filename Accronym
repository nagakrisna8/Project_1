function handleRolesForHomepageWorkApp() {
    // Hide Skeleton loader in case of no access
    var workapps = new UserToken().getWorkapps();
    let selectedBusinessUnit = storageService.getApplicationDataByKey(fullShellAppName, 'CurrentBusinessUnit');
    let selectedDiscipline = storageService.getApplicationDataByKey(fullShellAppName, 'CurrentDiscipline');
    //console.log("handleRolesForHomepageWorkApp", selectedDiscipline,selectedBusinessUnit)
    // Start MyPending Task WorkApp
    let pendingTaskResult = workapps.filter(workAppItem => {
        let hasPermisionToWorkApp = false;
        let BusinessUnitDisciplineList = workAppItem.BusinessUnitDisciplineList;
        for (let i = 0; i < BusinessUnitDisciplineList.length; i++) {
            let buDisciplineList = BusinessUnitDisciplineList[i];

            if (buDisciplineList.hasOwnProperty("BusinessunitName") &&
                buDisciplineList["BusinessunitName"]?.toLowerCase() == selectedBusinessUnit?.toLowerCase()) {

                for (let k = 0; k < buDisciplineList.DisciplineNameList.length; k++) {
                    let disciplineItem = buDisciplineList.DisciplineNameList[k];

                    if ((selectedDiscipline.toLowerCase() == disciplineItem.toLowerCase() ||
                        disciplineItem.toLowerCase() == "all") &&
                        workAppItem.AppName.toLowerCase() + workAppItem.WorkappName.toLowerCase() == `${process.env.REACT_APP_MY_PENDING_TASKS_DETAIL}`.toLowerCase()) {

                        hasPermisionToWorkApp = true;
                        break;
                    }
                }
                if (hasPermisionToWorkApp == true) {
                    break;
                }
            }
        }
        return hasPermisionToWorkApp;
    });

    if (pendingTaskResult && pendingTaskResult.length == 0) {
        document.getElementById("single-spa-application:SmartSheetMyPendingTaskApp").innerHTML = '<label style={{marginLeft:"2px",position:"relative",marginBottom:"10px,color:#253746"}}>My Pending Tasks</label>'
    }
    // End MyPending Task WorkApp
}

