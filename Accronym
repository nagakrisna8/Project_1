const mocdropdownlist = (props: GridCellProps) => {
        const canonicalField = props.field ?? "MOC";
        const selectedIds = new Set(gridSelectableMOCs);
        const matchedMocs = moc.filter(m => selectedIds.has(m.Moc_Id));
        const currentValue = props.dataItem[canonicalField] ?? props.dataItem["Moc"] ?? [];
        const valueArray = Array.isArray(currentValue) ? currentValue : (currentValue ? [currentValue] : []);

        const handleChange = (e: SelectChangeEvent<string[]>) => {
            if (props.onChange) {
                // Build a GridItemChangeEvent; ensure `field` is a string
                const fieldName: string = canonicalField;
                props.onChange({
                    dataIndex: props.dataIndex,
                    dataItem: props.dataItem,
                    field: fieldName,
                    syntheticEvent: e as unknown as SyntheticEvent,
                    value: e.target.value,
                } as GridItemChangeEvent);
                _handleDirtyFlag(true);
            }
        };

        return (
            <td title={valueArray.join(', ')}>
                <Select
                    className="moc-dropdownlist"
                    size="small"
                    value={valueArray}
                    onChange={handleChange}
                    disabled={allControlEnable}
                >
                    {
                        matchedMocs.length > 0 && (
                            <MenuItem value="">
                            </MenuItem>
                        )
                    }
                    {matchedMocs.map((m) => (
                        <MenuItem key={m.Moc_Id} value={m.Moc}>
                            <ListItemText
                                primary={m.Moc}
                                primaryTypographyProps={{ sx: { fontSize: '14px', color: '#253746' } }}
                            />
                        </MenuItem>
                    ))}
                </Select>
            </td>
        );
    };
