        headers: { "Authorization": `Bearer ${ossShellToken}` },
        method: 'GET',
        dataType: 'json',
        async: false,
        success: async function (data) {
            if (!data || data.length === 0) {
                // handle no data case
                FavouriteDetails = [];
                // favouriteLimit = 5; // fallback
                return;
            }
            // Clear existing favorites list before appending new items or message
            const favouriteList = document.getElementById('favouriteList');
            if (favouriteList) {
                while (favouriteList.firstChild) {
                    favouriteList.removeChild(favouriteList.firstChild);
                }
            }

            if (!data || data.length === 0 || !data[0].favouriteDetails || data[0].favouriteDetails.length === 0) {
                // Show "No Favourites" message if no data
                const noFavMsg = document.createElement('li');
                noFavMsg.textContent = "No Favorite";
                noFavMsg.style.fontWeight = "normal";
                noFavMsg.style.fontSize = "14px";
                noFavMsg.style.color = "#253746";
                noFavMsg.style.textAlign = "center";
                noFavMsg.style.marginLeft = "100px";
                favouriteList.appendChild(noFavMsg);
                return;
            }
            FavouriteDetails = data[0].favouriteDetails;
            // favouriteLimit = data[0].favourite_limit || 5;

            let easadata = await GetEASAWorkspaceData(ossShellToken, businessUnitId, disciplineId);

            for (const FavouriteDetail of FavouriteDetails) {

                let dataUrl = window.location.origin + FavouriteDetail.Fav_URL;
                let displayValue = FavouriteDetail.Fav_Value;
                let extractedNumber;
                const csrDoc = "CSR";

                if (FavouriteDetail.Fav_URL.includes(WorkAppRoutes.FIND_CSR.CSR_REPORT)) {
                    const reportNumber = extractProjectNoFromCsrUrl(dataUrl);
                    try {
                        const csrData = await getCSRReportNumber(reportNumber, ossShellToken);
                        if (csrData) {
                            extractedNumber = csrData;
                        }
                        else {
                            extractedNumber = reportNumber;
                        }
                    } catch (error) {
                        showSnackbar('Error fetching CSR report number: ' + error.responseText, "error");
                    }

                    if (FavouriteDetail.Group_Id && FavouriteDetail.EASA_ProjectNo) {
                        let groupname;
                        groupname = easadata.filter(workspacedata => workspacedata.groupId == FavouriteDetail.Group_Id).map(item => item.groupTitle).toString();
                        displayValue = groupname + ' ' + FavouriteDetail.Fav_Value;
                    }
                    else {
                        displayValue = csrDoc + ' ' + FavouriteDetail.Fav_Value;
                    }
                }
                else if (FavouriteDetail.Fav_URL.includes(App_paths.csr_list_search)) {
                    let groupname;
                    if (FavouriteDetail.Group_Id) {
                        groupname = easadata.filter(workspacedata => workspacedata.groupId == FavouriteDetail.Group_Id).map(item => item.groupTitle).toString();
                        extractedNumber = groupname + '-' + FavouriteDetail.EASA_ProjectNo + '-' + FavouriteDetail.EASA_RevNo;
                    } else {
                        extractedNumber = extractProjectNoFromUrl(dataUrl);
                    }
                }
                else if (FavouriteDetail.Fav_URL.includes(App_paths.easa_project_register)) {
                    extractedNumber = FavouriteDetail.EASA_ProjectNo + '-' + FavouriteDetail.EASA_RevNo;
                }
                else if (FavouriteDetail.Fav_URL.includes(App_paths.fpq_checklist_entry) &&
                    FavouriteDetail.FAA_RevNo != null &&
                    FavouriteDetail.FAA_RevNo.trim() !== "") {
                    extractedNumber = FavouriteDetail.FAA_RevNo;
                }
                else {
                    extractedNumber = extractProjectNoFromUrl(dataUrl);
                }

                if (!extractedNumber) {
                    return; // Skip this iteration
                }

                let easaProjectId = "";
                if (FavouriteDetail.EASA_ProjectNo) {
                    easaProjectId = FavouriteDetail.EASA_ProjectNo;
                }
                let easaRevNo = "";
                if (FavouriteDetail.EASA_RevNo) {
                    easaRevNo = FavouriteDetail.EASA_RevNo;
                }
                let easaGroupId = "";
                if (FavouriteDetail.Group_Id) {
                    easaGroupId = FavouriteDetail.Group_Id;
                }

                const li = document.createElement('li');
                li.className = 'favourite-list mb-2 align-items-center';

                li.innerHTML = `
           
               <div style="float:left">${displayValue}</div>
              <div style="float:left">
                <button type="button" style="font-size:14px;padding-left: 8px; color: #0078B8;" class="btn navigate-btn text-decoration-none" title="${extractedNumber}" aria-label="Navigate ${extractedNumber}" data-url="${dataUrl}" data-projectid="${FavouriteDetail.Project_Id}" data-type="${displayValue}" data-easa-project-id="${easaProjectId}" data-easa-rev-no="${easaRevNo}" data-easa-group-id="${easaGroupId}">${extractedNumber}</button>
              </div>
            
            <div style="float:right">
            <button type="button" class="btn delete-btn" aria-label="Delete ${extractedNumber}" data-project="${displayValue}" data-resolved-number="${extractedNumber}" data-type="${displayValue}" data-url="${FavouriteDetail.Fav_URL}">
              <svg xmlns="http://www.w3.org/2000/svg"  viewBox="0 0 24 24" width="18px" height="18px" fill="#a7a7a7"><path d="M 10 2 L 9 3 L 4 3 L 4 5 L 5 5 L 5 20 C 5 20.522222 5.1913289 21.05461 5.5683594 21.431641 C 5.9453899 21.808671 6.4777778 22 7 22 L 17 22 C 17.522222 22 18.05461 21.808671 18.431641 21.431641 C 18.808671 21.05461 19 20.522222 19 20 L 19 5 L 20 5 L 20 3 L 15 3 L 14 2 L 10 2 z M 7 5 L 17 5 L 17 20 L 7 20 L 7 5 z M 9 7 L 9 18 L 11 18 L 11 7 L 9 7 z M 13 7 L 13 18 L 15 18 L 15 7 L 13 7 z"/></svg>
            </button>
            </div>
          `;

                if (favouriteList) {
                    favouriteList.prepend(li);
                } else {
                    showSnackbar("Element with id 'favoriteList' not found.", "error");
                    FavouriteDetails = [];
                    // favouriteLimit = 5; // fallback
                }
            }
        },
        error: function (error) {
            WorkAppRequest.shellActiveApiCall = WorkAppRequest.shellActiveApiCall - 1;
            console.log('Error fetching data:', error);
        }
    });
