useEffect(() => {
  const storageServ = new StorageService();

  const key = `${process.env.REACT_APP_ROOT_NAME}-${process.env.REACT_APP_FIND_CSR}`;

  const isNav = storageServ.getApplicationDataByKey(key, "isFromNavigation");

  setIsFromNavigation(!!isNav);

  // 🔥🔥 EXACT FIX (CLEAR IT)
  storageServ.setApplicationDataByKey(key, "isFromNavigation", false);

  // OR EVEN BETTER:
  // localStorage.removeItem("isFromNavigation");

}, []);
