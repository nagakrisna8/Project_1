const OrganizationNameCell: React.ComponentType<GridCellProps> = (cellProps) => {
  const value = cellProps.dataItem.ORGANIZATIONNAME ?? "";

  const handleChange = (event: React.ChangeEvent<HTMLInputElement>) => {
    if (cellProps.onChange) {
      const updatedItem = {
        ...cellProps.dataItem,
        ORGANIZATIONNAME: event.target.value,
      };

      cellProps.onChange({
        dataIndex: cellProps.dataIndex,
        dataItem: updatedItem,
        field: "ORGANIZATIONNAME",
        syntheticEvent: event,
        value: event.target.value,
      });
    }
  };

  return (
    <td>
      <TextField fullWidth size="small" value={value} onChange={handleChange} />
    </td>
  );
};




