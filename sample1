const handleChange = (e: any) => {

    // update the same object instead of creating a new one
    dataItem.ISACTIVE = e.target.checked;

    cellProps.onChange?.({
        dataIndex: cellProps.dataIndex,
        dataItem: dataItem,
        field: cellProps.field,
        syntheticEvent: e,
        value: e.target.checked
    });
};
