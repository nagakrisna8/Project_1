import React, { memo, useCallback, useRef, useEffect, useState } from "react";
import { SupplierActivityMasterTable, SortByData } from "../AdminModal";
import { getter, State, process } from "@progress/kendo-data-query";
import {
  Grid as DataGrid,
  GridCellProps,
  GridColumn,
  GridDataStateChangeEvent,
  GridItemChangeEvent,
  GridToolbar,
} from "@progress/kendo-react-grid";
import {
  Button,
  Card,
  MenuItem,
  Select,
  TextField,
  Typography,
} from "@mui/material";
import AddCircleOutlineIcon from "@mui/icons-material/AddCircleOutline";
import SettingsIcon from "@mui/icons-material/Settings";
import ArrowUpwardIcon from "@mui/icons-material/ArrowUpward";
import ArrowDownwardIcon from "@mui/icons-material/ArrowDownward";
import SortIcon from "@mui/icons-material/Sort";
import { filterIcon } from "@progress/kendo-svg-icons";

const editField = "inEdit";

interface SupplierActivityTableProps {
  KEY: string;
  columnPropsBuilder: (field: any) => {
    field: any;
    columnMenu: (props: any) => JSX.Element;
    headerClassName: string;
  };
  supplierActivityData: SupplierActivityMasterTable[];
  dataState: State;
  dataStateChange: (event: GridDataStateChangeEvent) => void;
  itemChange: (event: GridItemChangeEvent) => void;
  createSupplierActivity: () => void;
  saveSupplierActivity: () => void;
  dragStart: (dataItem: SupplierActivityMasterTable) => void;
  reorder: (dataItem: SupplierActivityMasterTable) => void;
  sortBy: "custom" | "asc" | "desc" | undefined;
  handleSortByChange: (
    key: keyof SortByData,
    value: "custom" | "asc" | "desc",
    setScreenDirty?: boolean
  ) => void;
}

const SupplierActivityTable: React.FC<SupplierActivityTableProps> = memo(
  (props) => {
    const gridRefBuilder = useRef<any>(null);

    // ------------------- Activity Category Cell -------------------
    const SupplierActivityCell: React.ComponentType<GridCellProps> =
      useCallback((cellProps) => {
        const field = cellProps.field || "";
        const dataValue = cellProps.dataItem[field] ?? "";

        const handleChange = (
          event: React.ChangeEvent<HTMLInputElement>
        ) => {
          const updatedDataItem: SupplierActivityMasterTable = {
            ...cellProps.dataItem,
          };

          updatedDataItem.ACTIVITYCATEGORY = event.target.value;

          cellProps.onChange?.({
            dataIndex: cellProps.dataIndex,
            dataItem: updatedDataItem,
            field: cellProps.field,
            syntheticEvent: event,
            value: event.target.value,
          });
        };

        return (
          <td title={dataValue}>
            <TextField
              fullWidth
              value={dataValue}
              onChange={handleChange}
            />
          </td>
        );
      }, []);

    // ------------------- Description Cell -------------------
    const SupplierActivityDescCell: React.ComponentType<GridCellProps> =
      useCallback((cellProps) => {
        const field = cellProps.field || "";
        const dataValue = cellProps.dataItem[field] ?? "";

        const handleChange = (
          event: React.ChangeEvent<HTMLInputElement>
        ) => {
          const updatedDataItem: SupplierActivityMasterTable = {
            ...cellProps.dataItem,
          };

          updatedDataItem.ACTIVITYDESCRIPTION = event.target.value;

          cellProps.onChange?.({
            dataIndex: cellProps.dataIndex,
            dataItem: updatedDataItem,
            field: cellProps.field,
            syntheticEvent: event,
            value: event.target.value,
          });
        };

        return (
          <td title={dataValue}>
            <TextField
              fullWidth
              value={dataValue}
              onChange={handleChange}
            />
          </td>
        );
      }, []);

    // ------------------- Drag Cell -------------------
    const DragCell: React.ComponentType<GridCellProps> = (dragProps) => {
      return (
        <td
          onDragOver={(e) => {
            e.preventDefault();
            e.dataTransfer.dropEffect = "copy";
            props.reorder(dragProps.dataItem);
          }}
        >
          <span
            draggable
            style={{
              cursor: "move",
              color: "#737373",
              display: "flex",
              justifyContent: "center",
            }}
            onDragStart={(e) => {
              props.dragStart(dragProps.dataItem);
              e.dataTransfer.setData("dragging", "");
            }}
          >
            <SortIcon />
          </span>
        </td>
      );
    };

    // ------------------- Active Checkbox -------------------
    const ActiveCheckbox: React.ComponentType<GridCellProps> =
      (cellProps) => {
        const dataItem = cellProps.dataItem;

        const handleChange = (
          e: React.ChangeEvent<HTMLInputElement>
        ) => {
          const updatedDataItem: SupplierActivityMasterTable = {
            ...dataItem,
            ISACTIVE: e.target.checked,
          };

          cellProps.onChange?.({
            dataIndex: cellProps.dataIndex,
            dataItem: updatedDataItem,
            field: cellProps.field,
            syntheticEvent: e,
            value: e.target.checked,
          });
        };

        return (
          <td title={dataItem.ISACTIVE ? "True" : "False"}>
            <div
              style={{
                width: "100%",
                display: "flex",
                justifyContent: "center",
              }}
            >
              <input
                type="checkbox"
                checked={!!dataItem.ISACTIVE}
                onChange={handleChange}
                style={{ cursor: "pointer" }}
              />
            </div>
          </td>
        );
      };

    return (
      <div style={{ height: "calc(100vh - 320px)" }}>
        <Card
          style={{
            borderLeft: "4px solid #0033A1",
            marginLeft: "22px",
            overflow: "hidden",
            maxHeight: "calc(100vh - 320px)",
          }}
        >
          <DataGrid
            id="kgrid-oss-admin-table-supplierActivity"
            ref={gridRefBuilder}
            data={process(
              props.supplierActivityData,
              props.dataState
            ).data}
            editField={editField}
            onItemChange={props.itemChange}
            dataItemKey={props.KEY}
            scrollable="scrollable"
            sortable={false}
            rowHeight={30}
            {...props.dataState}
            onDataStateChange={props.dataStateChange}
            columnMenuIcon={filterIcon}
          >
            <GridToolbar>
              <div
                style={{
                  display: "flex",
                  width: "100%",
                  justifyContent: "space-between",
                  alignItems: "center",
                }}
              >
                <div style={{ display: "flex", gap: 8 }}>
                  <Button
                    startIcon={<AddCircleOutlineIcon />}
                    onClick={props.createSupplierActivity}
                    variant="outlined"
                    size="small"
                    color="inherit"
                  >
                    Create New
                  </Button>

                  <Button
                    onClick={props.saveSupplierActivity}
                    variant="outlined"
                    size="small"
                    color="inherit"
                  >
                    Save
                  </Button>
                </div>

                <div
                  style={{
                    display: "inline-flex",
                    gap: 8,
                    alignItems: "center",
                  }}
                >
                  <p style={{ margin: 0 }}>Sort Order :</p>

                  <Select
                    value={props.sortBy || "custom"}
                    onChange={(e) =>
                      props.handleSortByChange(
                        "supplierActivity",
                        e.target.value as "custom" | "asc" | "desc"
                      )
                    }
                  >
                    <MenuItem value="custom">
                      <SettingsIcon
                        style={{
                          color: "#737373",
                          height: 16,
                          width: 16,
                          marginRight: 8,
                        }}
                      />
                      Customize
                    </MenuItem>

                    <MenuItem
                      disabled={props.sortBy === undefined}
                      value="asc"
                    >
                      <ArrowUpwardIcon
                        style={{
                          color: "#737373",
                          height: 16,
                          width: 16,
                          marginRight: 8,
                        }}
                      />
                      Supplier Activity: Ascending
                    </MenuItem>

                    <MenuItem
                      disabled={props.sortBy === undefined}
                      value="desc"
                    >
                      <ArrowDownwardIcon
                        style={{
                          color: "#737373",
                          height: 16,
                          width: 16,
                          marginRight: 8,
                        }}
                      />
                      Supplier Activity: Descending
                    </MenuItem>
                  </Select>
                </div>
              </div>
            </GridToolbar>

            {props.sortBy === "custom" && (
              <GridColumn title="" width="50px" cell={DragCell} />
            )}

            <GridColumn
              {...props.columnPropsBuilder("ACTIVITYCATEGORY")}
              title="Activity Category"
              cell={SupplierActivityCell}
              width="450px"
            />

            <GridColumn
              {...props.columnPropsBuilder("ACTIVITYDESCRIPTION")}
              title="Activity Description"
              cell={SupplierActivityDescCell}
              width="350px"
            />

            <GridColumn
              {...props.columnPropsBuilder("ISACTIVE")}
              title="Active"
              cell={ActiveCheckbox}
              width="165px"
            />
          </DataGrid>
        </Card>
      </div>
    );
  }
);

export default SupplierActivityTable;
