const SupplierActivityDescCell: React.ComponentType<GridCellProps> = (cellProps) => {
  const field = cellProps.field || "";
  const dataValue = cellProps.dataItem[field] ?? "";

  const handleChange = (event: React.ChangeEvent<HTMLInputElement>) => {
    if (cellProps.onChange) {
      cellProps.onChange({
        dataIndex: cellProps.dataIndex,
        dataItem: {
          ...cellProps.dataItem,
          [field]: event.target.value   // ✅ IMPORTANT FIX
        },
        field: field,
        syntheticEvent: event,
        value: event.target.value,
      });
    }
  };

  return (
    <td>
      <TextField
        fullWidth
        value={dataValue}
        onChange={handleChange}
      />
    </td>
  );
};
