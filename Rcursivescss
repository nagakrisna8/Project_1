.csr-layout {
    .k-toolbar.k-toolbar-md.k-editor-toolbar {
        display: none;
    }
    .k-editor {
        position: relative !important;
        overflow: visible !important;
        height: auto !important;
    }
    .k-editor-toolbar {
        position: sticky !important;
        z-index: 1000 !important;
        top: 46px !important;
    }
    .k-editor-toolbar {
        display: none;
        position: relative;
        z-index: 10;
        /* Adjust as needed */
        background-color: #FFFFFF;
        padding: 0px;
    }
    .MuiAccordion-region .k-editor {
        max-width: 100% !important;
        min-width: 100% !important;
    }
    .k-editor-table-wizard-window {
        position: fixed !important;
        width: 540px !important;
        height: 245px !important;
        top: 70px !important;
    }
    .ProseMirror tr:first-child td {
       // font-weight: 600;
        background-color: #D1D1D1;
        background-clip: padding-box !important;
        text-align: center;
        padding-left: 7.68px !important;
        padding-right: 7.68px !important;
    }
    .k-content {
        font-family: "Roboto", sans-serif !important;
        font-size: 14px;
        color: #253746;
    }
    .k-editor-resize-wrap-element {
        display: inline-block !important;
        position: relative !important;
    }
    
    .ProseMirror td {
        border: 0.5px solid black !important;
        padding-left: 7.68px !important;
        padding-right: 7.68px !important;
    }
    .ProseMirror.resize-cursor-vertical {
        cursor: row-resize !important;
    }
    .ProseMirror.resize-cursor {
        cursor: col-resize !important;
    }
    .ProseMirror-trailingBreak {
        line-height: normal !important;
    }
    ul,
    li {
        list-style: unset;
        margin: 0px;
    }
    .k-editor li {
        margin-bottom: 1rem;
    }
}

