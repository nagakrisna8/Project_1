.suggestion-item-list {
    border: 1px solid #9E9E9E;
    border-left: 3px solid #FFD800;
    box-sizing: border-box;
    padding: 0px;
    border-radius: 4px;
    //box-shadow: inset 0px 1px 8px -3px #ABABAB;
    box-shadow: 2px 2px 4px hsl(0deg 0% 0% / 0.2);
    background: #fefefe;
    cursor: text;
    animation: fadeInLeft 300ms;
    transition: background-color 300ms ease;
    text-align: center;
    width: 220px;
}

.suggestion-item {
    transition: 0.4s cubic-bezier(.27, 1.27, .48, .56);
    font-size: 14px;
    padding-block: 5.5px;
    cursor: pointer;
}

.suggestion-item-active {
    background-color: #EFF4FA;
    font-weight: bold;
