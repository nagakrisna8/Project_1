        //     if (item.value != value)
        //         item.removeAttribute("checked");
        // });

        let dynamicRootHtmlElement;
        // Traverse up until we find the div element with below matching name
        for (; target; target = target.parentElement) {
            if (target.tagName === 'DIV' &&
                (target.getAttribute("name") === StaticTable.HTML_TABLE_WITHOUT_TITLE
                    || target.getAttribute("name") === StaticTable.STATIC_TABLE_CODE)) {
                // Return the found div element
                dynamicRootHtmlElement = target;
                break;
            }
        }

        if (dynamicRootHtmlElement) {
            let contentId = dynamicRootHtmlElement.parentElement.getAttribute("id");
            let updatedDynamicHtmlContent = dynamicRootHtmlElement.parentElement.innerHTML;
            // Extract script tag and append again with HTML 
            // Select the script tag with the custom attribute
            const scriptTag = document.querySelector(`script[script-contentid='${contentId}']`);
            // Get the raw text content
