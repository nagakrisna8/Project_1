            if (editorDataResult && editorDataResult.data) {
                let addIsExpandedFlag_IsTextBoxEmptyFlag = (nestedArray) => {
                    return nestedArray.map(item => {
                        item = { ...item, IsExpanded: true, IsError: false }
                        item.SubSectionData = addIsExpandedFlag_IsTextBoxEmptyFlag(item.SubSectionData)
                        return item;
                    })
                }
                let result = addIsExpandedFlag_IsTextBoxEmptyFlag([editorDataResult.data]);
                dispatch(showSnackbar({ snackbarOpen: true, snackbarType: "success", snackbarMessage: `Layout changed to ${layoutMode} sucessfully.` }));
                syncEditorDataWithOrientationData(result, getScrollHeight);
            }
        } catch (err) {
            setIconToggles(prev => ({ ...prev, [key]: prevRotated }));
            dispatch(showSnackbar({ snackbarOpen: true, snackbarType: "error", snackbarMessage: `Failed to apply layout changes. Please try again.` }));
