useEffect(() => {
  const templateId = storageService.getApplicationDataByKey(
    `${EnvDetail.ParentAppName}-${EnvDetail.AppName}`,
    "selectedTemplateId"
  );

  const groupId = storageService.getApplicationDataByKey(
    `${EnvDetail.ParentAppName}-${EnvDetail.AppName}`,
    "selectedGroupId"
  );

  // ✅ SET GROUP (with GroupTitle from API, no hardcoding)
  if (groupId && defaultReportGroups?.length > 0) {
    const matchedGroup = defaultReportGroups.find(
      (g) => g.GroupId === groupId
    );

    if (matchedGroup) {
      setSelectedReportGroup(matchedGroup);
    }
  }

  // ✅ SET TEMPLATE (already correct)
  if (templateId && groupTemplates?.length > 0) {
    const matchedTemplate = groupTemplates.find(
      (t) => t.TemplateId === templateId
    );

    if (matchedTemplate) {
      setSelectedTemplate(matchedTemplate);
    }
  }

}, [groupTemplates, defaultReportGroups]);
